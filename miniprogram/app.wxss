/* app.wxss - 全局样式 */
page {
  background-color: #0d1117;
  color: #c9d1d9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ===== 公共弹窗（位置选择 / 段位选择共用） ===== */
.pos-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.pos-modal {
  width: 100%;
  background-color: #1a1f2b;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 36rpx 64rpx;
  box-sizing: border-box;
}

.pos-modal-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.pos-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #e6edf3;
}

.pos-modal-close {
  font-size: 44rpx;
  color: #7d8590;
  line-height: 1;
  padding: 8rpx 16rpx;
}

.pos-modal-confirm {
  width: 100%;
  height: 92rpx;
  border-radius: 14rpx;
  background-color: #1f6feb;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pos-modal-confirm:active { opacity: 0.85; }
.pos-modal-confirm-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.pos-modal-body {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  margin-bottom: 48rpx;
}

/* ===== 圆形选择按钮（位置/星数共用） ===== */
.pm-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pm-circle.pm-def {
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background-color: transparent;
}
.pm-circle.pm-def .pm-num { color: #8b949e; font-size: 34rpx; font-weight: 700; }

.pm-circle.pm-sel-1 { background-color: rgba(231, 76, 60, 0.2); border: 2rpx solid #e74c3c; }
.pm-circle.pm-sel-1 .pm-num { color: #e74c3c; font-size: 34rpx; font-weight: 700; }

.pm-circle.pm-sel-2 { background-color: rgba(243, 156, 18, 0.2); border: 2rpx solid #f39c12; }
.pm-circle.pm-sel-2 .pm-num { color: #f39c12; font-size: 34rpx; font-weight: 700; }

.pm-circle.pm-sel-3 { background-color: rgba(39, 174, 96, 0.2); border: 2rpx solid #27ae60; }
.pm-circle.pm-sel-3 .pm-num { color: #27ae60; font-size: 34rpx; font-weight: 700; }

.pm-circle.pm-sel-4 { background-color: rgba(52, 152, 219, 0.2); border: 2rpx solid #3498db; }
.pm-circle.pm-sel-4 .pm-num { color: #3498db; font-size: 34rpx; font-weight: 700; }

.pm-circle.pm-sel-5 { background-color: rgba(155, 89, 182, 0.2); border: 2rpx solid #9b59b6; }
.pm-circle.pm-sel-5 .pm-num { color: #9b59b6; font-size: 34rpx; font-weight: 700; }

.pm-num {
  font-size: 34rpx;
  font-weight: 700;
}

/* ===== 段位选择弹窗（共用） ===== */
.rank-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.rank-cell {
  width: calc(33.33% - 16rpx);
  margin: 0 8rpx 16rpx 8rpx;
  height: 80rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.03);
  box-sizing: border-box;
}

.rank-cell:active { opacity: 0.7; }

.rank-cell-active {
  border-color: #d4a03a;
  background-color: rgba(212, 160, 58, 0.15);
  box-shadow: 0 0 16rpx rgba(212, 160, 58, 0.15);
}

.rank-cell-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #c9d1d9;
}

.rank-cell-active .rank-cell-text {
  color: #e8b84a;
}

/* ===== 星数选择区 ===== */
.star-section {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-top: 8rpx;
}

.star-section .pos-modal-confirm {
  margin-top: 40rpx;
}

.star-label {
  display: block;
  font-size: 26rpx;
  color: #8b949e;
  margin-bottom: 24rpx;
  text-align: center;
}

.star-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

/* ===== 公共状态 ===== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #484f58;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
