/* pages/announce-manage/announce-manage.wxss */
.page { min-height: 100vh; background-color: #0d1117; padding-bottom: 40rpx; }

/* 权限拦截 */
.perm-deny { display: flex; flex-direction: column; align-items: center; padding-top: 300rpx; }
.perm-deny-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.perm-deny-text { font-size: 28rpx; color: #8b949e; }

/* 顶部操作栏 */
.am-topbar {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  padding: 24rpx 36rpx; border-bottom: 1rpx solid #21262d;
}
.am-title { font-size: 34rpx; font-weight: 700; color: #e6edf3; }
.am-add-btn {
  padding: 10rpx 24rpx; border-radius: 10rpx;
  background-color: rgba(39,174,96,0.15); border: 1rpx solid rgba(39,174,96,0.25);
  font-size: 24rpx; color: #27ae60;
}
.am-add-btn:active { background-color: rgba(39,174,96,0.25); }

/* 公告列表 */
.am-list { padding: 0 36rpx; }
.am-item {
  padding: 20rpx 24rpx; margin-bottom: 16rpx;
  background-color: #161b22; border: 1rpx solid #21262d;
  border-radius: 14rpx;
}
.am-item-top {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.am-item-badges { display: flex; flex-direction: row; align-items: center; gap: 8rpx; }
.am-badge { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 6rpx; }
.am-badge-pin { background-color: rgba(243,156,18,0.15); color: #f39c12; }
.am-item-order { font-size: 20rpx; color: #484f58; }
.am-item-actions { display: flex; flex-direction: row; gap: 8rpx; }
.am-act {
  font-size: 20rpx; color: #3498db; padding: 4rpx 14rpx;
  border-radius: 6rpx; background-color: rgba(52,152,219,0.08);
}
.am-act-del { color: #e74c3c; background-color: rgba(231,76,60,0.08); }
.am-act:active { opacity: 0.7; }
.am-item-content { display: block; font-size: 28rpx; color: #c9d1d9; line-height: 1.6; margin-bottom: 8rpx; }
.am-item-time { font-size: 20rpx; color: #484f58; }

/* 排序提示 */
.am-sort-hint { padding: 16rpx 36rpx; }
.am-sort-hint text { font-size: 22rpx; color: #484f58; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-text { font-size: 28rpx; color: #8b949e; }
.empty-hint { font-size: 22rpx; color: #484f58; margin-top: 8rpx; }
.loading-state { display: flex; justify-content: center; padding: 120rpx 0; font-size: 28rpx; color: #8b949e; }

/* 弹窗 */
.am-modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.6); z-index: 100;
}
.am-modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background-color: #161b22; border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 36rpx 48rpx; z-index: 101;
}
.amm-title { font-size: 32rpx; font-weight: 700; color: #e6edf3; margin-bottom: 20rpx; text-align: center; }
.amm-textarea {
  width: 100%; min-height: 200rpx; padding: 20rpx; box-sizing: border-box;
  background-color: rgba(255,255,255,0.04); border-radius: 12rpx;
  font-size: 28rpx; color: #e6edf3; line-height: 1.6;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.amm-actions {
  display: flex; flex-direction: row; gap: 20rpx; margin-top: 24rpx;
}
.amm-btn {
  flex: 1; padding: 20rpx 0; text-align: center;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 500;
}
.amm-cancel { background-color: rgba(255,255,255,0.04); color: #8b949e; border: 1rpx solid rgba(255,255,255,0.08); }
.amm-cancel:active { background-color: rgba(255,255,255,0.08); }
.amm-confirm { background-color: rgba(52,152,219,0.15); color: #3498db; border: 1rpx solid rgba(52,152,219,0.25); }
.amm-confirm:active { background-color: rgba(52,152,219,0.25); }
