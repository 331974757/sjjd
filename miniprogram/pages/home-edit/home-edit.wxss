/* pages/home-edit/home-edit.wxss */
.page { min-height: 100vh; background-color: #0d1117; padding-bottom: 40rpx; }

/* 权限拦截 */
.perm-deny { display: flex; flex-direction: column; align-items: center; padding-top: 300rpx; }
.perm-deny-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.perm-deny-text { font-size: 28rpx; color: #8b949e; }

/* 顶部操作栏 */
.he-topbar {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  padding: 24rpx 36rpx; border-bottom: 1rpx solid #21262d;
}
.he-title { font-size: 34rpx; font-weight: 700; color: #e6edf3; }
.he-actions { display: flex; flex-direction: row; gap: 12rpx; }
.he-btn {
  padding: 10rpx 28rpx; border-radius: 10rpx; font-size: 26rpx; font-weight: 500;
}
.he-btn-cancel { background-color: rgba(255,255,255,0.04); color: #8b949e; border: 1rpx solid rgba(255,255,255,0.08); }
.he-btn-cancel:active { background-color: rgba(255,255,255,0.08); }
.he-btn-save { background-color: rgba(39,174,96,0.15); color: #27ae60; border: 1rpx solid rgba(39,174,96,0.3); }
.he-btn-save:active { background-color: rgba(39,174,96,0.25); }
.he-btn-full { display: flex; justify-content: center; padding: 16rpx 0; font-size: 30rpx; }

/* 提示 */
.he-hint { padding: 16rpx 36rpx; }
.he-hint text { font-size: 22rpx; color: #484f58; }

/* 内容区块列表 */
.he-blocks { padding: 0 36rpx; }
.he-block {
  margin-bottom: 20rpx; padding: 16rpx;
  background-color: #161b22; border: 1rpx solid #21262d;
  border-radius: 14rpx;
}

/* 区块工具栏 */
.hb-toolbar {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.hb-type { font-size: 22rpx; color: #8b949e; }
.hb-actions { display: flex; flex-direction: row; gap: 8rpx; }
.hb-act {
  font-size: 20rpx; color: #3498db; padding: 4rpx 14rpx;
  border-radius: 6rpx; background-color: rgba(52,152,219,0.1);
}
.hb-act-del { color: #e74c3c; background-color: rgba(231,76,60,0.1); }
.hb-act:active { opacity: 0.7; }

/* 文字编辑区 */
.he-textarea {
  width: 100%; min-height: 120rpx; padding: 16rpx; box-sizing: border-box;
  background-color: rgba(255,255,255,0.03); border-radius: 10rpx;
  font-size: 28rpx; color: #e6edf3; line-height: 1.6;
  border: 1rpx solid rgba(255,255,255,0.06);
}

/* 图片预览 */
.he-preview { display: block; width: 100%; border-radius: 10rpx; margin-bottom: 12rpx; }
.he-upload-area {
  padding: 40rpx 0; text-align: center;
  background-color: rgba(255,255,255,0.03); border: 2rpx dashed rgba(255,255,255,0.1);
  border-radius: 10rpx; font-size: 24rpx; color: #3498db;
}
.he-upload-area:active { background-color: rgba(52,152,219,0.06); }

/* 空状态 */
.he-empty { padding: 120rpx 0; text-align: center; }
.he-empty-text { font-size: 26rpx; color: #484f58; }

/* 添加按钮栏 */
.he-add-bar { display: flex; flex-direction: row; padding: 24rpx 36rpx; gap: 16rpx; }
.he-add-btn {
  flex: 1; padding: 20rpx 0; text-align: center;
  background-color: rgba(52,152,219,0.08); border: 1rpx solid rgba(52,152,219,0.15);
  border-radius: 12rpx; font-size: 26rpx; color: #3498db;
}
.he-add-btn:active { background-color: rgba(52,152,219,0.15); }

/* 底部保存 */
.he-bottom-save { padding: 24rpx 36rpx; }
