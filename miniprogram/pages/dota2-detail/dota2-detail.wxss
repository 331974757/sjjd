/* pages/dota2-detail/dota2-detail.wxss */
.detail-page {
  min-height: 100vh;
  background-color: #0d1b2a;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.detail-card {
  background-color: #1b263b;
  border-radius: 20rpx;
  overflow: hidden;
}

.field-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.field-row:last-child {
  border-bottom: none;
}

.field-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.field-label {
  font-size: 24rpx;
  color: #778da9;
}

.field-val {
  font-size: 30rpx;
  color: #e0e1dd;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #f39c12;
}

.current-score {
  color: #3498db;
  font-size: 44rpx;
}

.field-edit {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.edit-icon {
  font-size: 32rpx;
  color: #415a77;
}

/* 位置标签 */
.pos-display {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  flex-wrap: wrap;
}

.pos-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.pos-tag.pos-1 { background-color: #e74c3c; }
.pos-tag.pos-2 { background-color: #f39c12; }
.pos-tag.pos-3 { background-color: #27ae60; }
.pos-tag.pos-4 { background-color: #3498db; }
.pos-tag.pos-5 { background-color: #9b59b6; }

/* 加载中 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #778da9;
}

/* 删除 */
.delete-section {
  margin-top: 48rpx;
  padding-bottom: 60rpx;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background-color: rgba(231, 76, 60, 0.15);
  border: 1rpx solid rgba(231, 76, 60, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn:active {
  background-color: rgba(231, 76, 60, 0.3);
}

.delete-text {
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: 600;
}
