/* pages/dota2-detail/dota2-detail.wxss */
.detail-page {
  min-height: 100vh;
  background-color: #0d1117;
  padding: 0 32rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 页面标题 ===== */
.page-header {
  padding: 48rpx 0 40rpx;
  text-align: center;
  border-bottom: 2rpx solid #21262d;
  margin-bottom: 24rpx;
}
.page-header-title {
  display: inline-block;
  font-size: 42rpx;
  font-weight: 700;
  color: #f0f6fc;
  letter-spacing: 6rpx;
  position: relative;
}
.page-header-title::after {
  content: '';
  display: block;
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(135deg, #4f8cff, #7c5cfc);
  margin: 16rpx auto 0;
}
.page-header-sub {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-top: 12rpx;
  letter-spacing: 3rpx;
}

/* ===== 头像区 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.detail-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(212, 160, 58, 0.3);
  background-color: #161b22;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

/* 空头像占位：显示默认图标 */
.detail-avatar-empty {
  opacity: 0.35;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="38" r="22" fill="%238b949e"/><ellipse cx="50" cy="85" rx="35" ry="22" fill="%238b949e"/></svg>');
  background-size: 60%;
  background-position: center;
  background-repeat: no-repeat;
}

.avatar-tip {
  font-size: 22rpx;
  color: #484f58;
  margin-top: 16rpx;
}

/* ===== 卡片 ===== */
.detail-card {
  background-color: #161b22;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  animation: detailFadeIn 0.35s ease;
}

@keyframes detailFadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.field-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.field-row:last-child { border-bottom: none; }

.field-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.field-label {
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 6rpx;
}

.field-val {
  font-size: 30rpx;
  color: #e6edf3;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-val.dim {
  color: #484f58;
}

/* 段位金色 */
.rank-gold {
  color: #d4a03a !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
}

/* 编辑图标 */
.field-edit {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: rgba(255, 255, 255, 0.04);
  margin-left: 16rpx;
}
.field-edit:active {
  background-color: rgba(255, 255, 255, 0.1);
}

.edit-icon {
  font-size: 26rpx;
  color: #58a6ff;
}

/* 位置标签 */
.pos-display {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.pos-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.pos-tag.pos-1 { background-color: rgba(231, 76, 60, 0.85); }
.pos-tag.pos-2 { background-color: rgba(243, 156, 18, 0.85); }
.pos-tag.pos-3 { background-color: rgba(39, 174, 96, 0.85); }
.pos-tag.pos-4 { background-color: rgba(52, 152, 219, 0.85); }
.pos-tag.pos-5 { background-color: rgba(155, 89, 182, 0.85); }

/* ===== 加载骨架屏 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

/* 旋转加载动画 */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.08);
  border-top-color: #58a6ff;
  border-radius: 50%;
  margin-bottom: 20rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #484f58;
}

/* ===== 删除按钮 ===== */
.delete-section {
  margin-top: 48rpx;
  padding-bottom: 20rpx;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background-color: rgba(218, 54, 51, 0.08);
  border: 1rpx solid rgba(218, 54, 51, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn:active {
  opacity: 0.75;
  background-color: rgba(218, 54, 51, 0.16);
}

.delete-text {
  font-size: 30rpx;
  color: #f85149;
  font-weight: 600;
}

/* ===== 无权限提示 ===== */
.no-edit-tip {
  margin-top: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background-color: rgba(31, 111, 235, 0.06);
  border: 1rpx solid rgba(31, 111, 235, 0.12);
  text-align: center;
  font-size: 24rpx;
  color: #58a6ff;
  line-height: 1.6;
}

.tip-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(88, 166, 255, 0.6);
}

/* 弹窗/段位/星数 → 见 app.wxss 公共样式 */

/* ===== 行内编辑 ===== */
.field-edit-inline {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(79,140,255,0.4);
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #e6edf3;
  box-sizing: border-box;
}

.field-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.12s ease;
}
.field-btn:active {
  transform: scale(0.9);
}

.field-confirm {
  background: rgba(63,185,80,0.15);
  border: 2rpx solid rgba(63,185,80,0.35);
}
.field-confirm text {
  font-size: 30rpx;
  color: #3fb950;
  font-weight: 700;
  font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
}
.field-confirm:active {
  background: rgba(63,185,80,0.3);
}

.field-cancel {
  background: rgba(139,148,158,0.12);
  border: 2rpx solid rgba(139,148,158,0.25);
}
.field-cancel text {
  font-size: 30rpx;
  color: #8b949e;
  font-weight: 400;
  font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
}
.field-cancel:active {
  background: rgba(139,148,158,0.25);
}

/* ===== 可滑动段位编辑 ===== */
.rank-scroll {
  width: 100%;
  white-space: nowrap;
}

.rank-scroll-inner {
  display: inline-flex;
  flex-direction: row;
  padding: 4rpx 0;
}

.rank-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  height: 48rpx;
  padding: 0 20rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.12);
  transition: all 0.2s;
}

.rank-chip-active {
  background: linear-gradient(135deg, #d4a03a, #e8c776);
  border-color: #d4a03a;
}

.rank-chip-text {
  font-size: 22rpx;
  color: #c9d1d9;
  white-space: nowrap;
}

.rank-chip-active .rank-chip-text {
  color: #0d1117;
  font-weight: 600;
}

.star-row-inline {
  margin-top: 4rpx;
  margin-bottom: 10rpx;
}

.star-label-inline {
  display: block;
  font-size: 22rpx;
  color: #8b949e;
  margin-bottom: 12rpx;
}

.star-select-row {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  gap: 14rpx;
}

/* 星数小圆按钮覆盖 */
.star-select-row .pm-circle {
  width: 48rpx;
  height: 48rpx;
}

.star-select-row .pm-circle .pm-num {
  font-size: 22rpx;
}


