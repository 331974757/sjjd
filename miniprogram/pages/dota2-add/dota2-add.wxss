/* pages/dota2-add/dota2-add.wxss */
.add-page {
  min-height: 100vh;
  background-color: #0d1b2a;
  padding-bottom: 60rpx;
}

.form-section {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #e0e1dd;
  margin-bottom: 16rpx;
}

.required {
  color: #e74c3c;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  color: #e0e1dd;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 位置选择器 */
.pos-selector {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 10rpx;
}

.pos-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 6rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 14rpx;
  background-color: rgba(255, 255, 255, 0.03);
  flex: 1;
}

.pos-card.pos-selected {
  border-color: #415a77;
  background-color: rgba(65, 90, 119, 0.2);
}

.pos-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.pos-icon-1 { background-color: #e74c3c; }
.pos-icon-2 { background-color: #f39c12; }
.pos-icon-3 { background-color: #27ae60; }
.pos-icon-4 { background-color: #3498db; }
.pos-icon-5 { background-color: #9b59b6; }

.pos-label {
  font-size: 20rpx;
  color: #778da9;
}

.pos-card.pos-selected .pos-label {
  color: #e0e1dd;
}

/* Picker */
.picker-display {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
}

.picker-text {
  font-size: 28rpx;
  color: #e0e1dd;
}

.picker-arrow {
  font-size: 28rpx;
  color: #778da9;
}

/* 提交 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  background-color: #3498db;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
}

.submit-btn:active {
  background-color: #2980b9;
}

.btn-disabled {
  opacity: 0.6;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
