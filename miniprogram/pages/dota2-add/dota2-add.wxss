/* pages/dota2-add/dota2-add.wxss */
.add-page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 80rpx;
}

/* ===== 页面标题 ===== */
.page-header {
  padding: 40rpx 32rpx 36rpx;
  text-align: center;
  border-bottom: 2rpx solid #21262d;
  margin-bottom: 24rpx;
}
.page-header-title {
  display: inline-block;
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f6fc;
  letter-spacing: 6rpx;
  position: relative;
}
.page-header-title::after {
  content: '';
  display: block;
  width: 44rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: linear-gradient(135deg, #4f8cff, #7c5cfc);
  margin: 14rpx auto 0;
}
.page-header-sub {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-top: 12rpx;
  letter-spacing: 3rpx;
}

/* ===== 头像区 ===== */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 32rpx 20rpx;
}

.avatar-upload {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(212, 160, 58, 0.3);
  background-color: #161b22;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  font-size: 48rpx;
  color: #484f58;
  font-weight: 300;
  line-height: 1;
}

.avatar-hint {
  font-size: 18rpx;
  color: #484f58;
  margin-top: 6rpx;
}

/* ===== 表单 ===== */
.form-section {
  padding: 16rpx 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #c9d1d9;
  margin-bottom: 12rpx;
}

.required {
  color: #f85149;
  font-size: 28rpx;
}

.optional {
  color: #8b949e;
  font-size: 24rpx;
  font-weight: 400;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background-color: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: rgba(31, 111, 235, 0.4);
}

/* ===== 圆形位置按钮 ===== */
.pos-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.pos-circle + .pos-circle {
  margin-left: 0;
}

.pos-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 默认态 */
.pos-circle.pos-def {
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background-color: transparent;
}

.pos-circle.pos-def .pos-num {
  color: #8b949e;
  font-size: 30rpx;
  font-weight: 600;
}

/* 选中态 - 各位置颜色 */
.pos-circle.pos-sel-1 { background-color: rgba(231, 76, 60, 0.2); border: 2rpx solid #f85149; }
.pos-circle.pos-sel-1 .pos-num { color: #f85149; }

.pos-circle.pos-sel-2 { background-color: rgba(243, 156, 18, 0.2); border: 2rpx solid #f39c12; }
.pos-circle.pos-sel-2 .pos-num { color: #f39c12; }

.pos-circle.pos-sel-3 { background-color: rgba(39, 174, 96, 0.2); border: 2rpx solid #3fb950; }
.pos-circle.pos-sel-3 .pos-num { color: #3fb950; }

.pos-circle.pos-sel-4 { background-color: rgba(52, 152, 219, 0.2); border: 2rpx solid #58a6ff; }
.pos-circle.pos-sel-4 .pos-num { color: #58a6ff; }

.pos-circle.pos-sel-5 { background-color: rgba(155, 89, 182, 0.2); border: 2rpx solid #9b59b6; }
.pos-circle.pos-sel-5 .pos-num { color: #9b59b6; }

.pos-num {
  font-size: 30rpx;
  font-weight: 700;
}

/* ===== Picker ===== */
.picker-display {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background-color: rgba(255, 255, 255, 0.04);
}

.picker-text {
  font-size: 28rpx;
  color: #8b949e;
}

.picker-arrow {
  font-size: 28rpx;
  color: #484f58;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1f6feb, #2563eb);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 111, 235, 0.3);
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-disabled {
  opacity: 0.55;
  box-shadow: none;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 弹窗/段位/星数 → 见 app.wxss 公共样式 */

/* ===== 可滑动段位选择 ===== */
.rank-scroll {
  width: 100%;
  white-space: nowrap;
}

.rank-scroll-inner {
  display: inline-flex;
  flex-direction: row;
  padding: 4rpx 0;
}

.rank-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.12);
  transition: all 0.2s;
}

.rank-chip-active {
  background: linear-gradient(135deg, #d4a03a, #e8c776);
  border-color: #d4a03a;
}

.rank-chip-text {
  font-size: 24rpx;
  color: #c9d1d9;
  white-space: nowrap;
}

.rank-chip-active .rank-chip-text {
  color: #0d1117;
  font-weight: 600;
}

.rank-grid-inline {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.rank-grid-inline .rank-cell {
  margin: 0 10rpx 14rpx 10rpx;
}

.star-row-inline {
  margin-top: 8rpx;
}

.star-label-inline {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
}

.star-select-row {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  gap: 16rpx;
}

/* 星数小圆按钮覆盖 */
.star-select-row .pm-circle {
  width: 56rpx;
  height: 56rpx;
}

.star-select-row .pm-circle .pm-num {
  font-size: 24rpx;
}
