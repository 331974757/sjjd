/* ============================================================
   pages/event-detail/event-detail.wxss
   赛事详情 - 阶段式Tab分栏重构版 样式
   深色主题(#0d1117)，完全复用原有风格
   ============================================================ */

/* ===== 页面标题 ===== */
.page-header {
  padding: 40rpx 32rpx 36rpx;
  text-align: center;
  background-color: #0d1117;
}
.page-header-title {
  display: inline-block;
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f6fc;
  letter-spacing: 6rpx;
  position: relative;
}
.page-header-title::after {
  content: '';
  display: block;
  width: 44rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: linear-gradient(135deg, #4f8cff, #7c5cfc);
  margin: 14rpx auto 0;
}
.page-header-sub {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-top: 12rpx;
  letter-spacing: 3rpx;
}

/* ===== 基础 ===== */
.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 60rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #8b949e;
}

/* ===== 赛事信息卡片 ===== */
.event-card {
  margin: 24rpx 32rpx 16rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #161b22 0%, #1a1f2e 100%);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
}

.event-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.event-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #e6edf3;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 赛事名：编辑笔图标 */
.edit-pencil {
  font-size: 24rpx;
  color: #484f58;
  padding: 2rpx 6rpx;
  flex-shrink: 0;
}
.edit-pencil:active { color: #58a6ff; }
.edit-pencil-sm { font-size: 24rpx; }

/* 赛事名：编辑名次图标 */
.event-rank-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  margin-left: 4rpx;
  opacity: 0.55;
}

.event-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 12rpx;
  padding-top: 4rpx;
}

.event-name-editing {
  flex-direction: row;
  gap: 8rpx;
  max-width: 480rpx;
}

.event-name-input {
  flex: 1;
  height: 56rpx;
  border: 1rpx solid rgba(31,111,235,0.4);
  border-radius: 10rpx;
  background: rgba(255,255,255,0.04);
  color: #e6edf3;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 14rpx;
}

.edit-done {
  font-size: 26rpx;
  color: #3fb950;
  font-weight: 700;
  padding: 4rpx 10rpx;
  flex-shrink: 0;
}
.edit-done:active { color: #2ea043; }

.edit-cancel {
  font-size: 26rpx;
  color: #f85149;
  font-weight: 700;
  padding: 4rpx 10rpx;
  flex-shrink: 0;
}
.edit-cancel:active { color: #da3633; }

.event-status {
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 右侧区域：状态 + 删除组 */
.event-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 8rpx;
}

/* 删除入口（与比赛时间同行右侧） */
.event-del-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.event-del-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(248,81,73,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.event-del-btn .icon-img-sm {
  width: 22rpx;
  height: 22rpx;
}
.event-del-btn:active {
  background: rgba(248,81,73,0.25);
}
.event-del-hint-text {
  font-size: 22rpx;
  color: #6e7681;
  white-space: nowrap;
}

/* 赛事详情刷新按钮 */
.event-refresh {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  margin-left: 8rpx;
  margin-top: 2rpx;
  transition: all 0.15s ease;
}
.event-refresh:active {
  background-color: rgba(31, 111, 235, 0.3);
  transform: scale(0.92);
}
.event-refresh .icon-img-sm {
  width: 28rpx;
  height: 28rpx;
}

/* 状态颜色 */
.s-draft    { background: rgba(139,148,158,0.15); color: #8b949e; }
.s-open     { background: rgba(39,174,96,0.15);  color: #3fb950; border: 1rpx solid rgba(39,174,96,0.2); }
.s-closed   { background: rgba(243,156,18,0.15); color: #f39c12; border: 1rpx solid rgba(243,156,18,0.2); }
.s-locked   { background: rgba(52,152,219,0.15); color: #3498db; border: 1rpx solid rgba(52,152,219,0.2); }
.s-fighting { background: rgba(231,76,60,0.15);  color: #e74c3c; border: 1rpx solid rgba(231,76,60,0.2); }
.s-archived { background: rgba(119,141,169,0.12); color: #778da9; border: 1rpx solid rgba(119,141,169,0.2); }

.event-meta {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
}

.event-meta-left {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: #484f58;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 26rpx;
  color: #c9d1d9;
}

.meta-count {
  color: #58a6ff;
  font-weight: 600;
}

.meta-sub {
  font-size: 20rpx;
  color: #f0883e;
}

/* 已报名：管理员可点击修改上限 */
.meta-clickable {
  padding: 8rpx 14rpx;
  margin: -4rpx -8rpx;
  border-radius: 10rpx;
  border: 1rpx dashed rgba(31,111,235,0.25);
  transition: all 0.15s;
}

.meta-clickable:active {
  background: rgba(31,111,235,0.08);
  border-color: rgba(31,111,235,0.5);
}

.meta-edit-icon {
  font-size: 20rpx;
  color: #58a6ff;
}

/* 比赛时间：可编辑态（直接点击弹出选择器） */
.meta-time-editable {
  padding: 6rpx 12rpx;
  margin: -2rpx -6rpx;
  border-radius: 8rpx;
  border: 1rpx dashed rgba(31,111,235,0.25);
  transition: all 0.15s;
}

.meta-time-editable:active {
  background: rgba(31,111,235,0.08);
  border-color: rgba(31,111,235,0.5);
}

.archived-banner {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(119,141,169,0.08);
  border-radius: 10rpx;
  border: 1rpx solid rgba(119,141,169,0.12);
}

.ab-text {
  font-size: 22rpx;
  color: #8b949e;
}

/* ===== Tab 导航栏 ===== */
.tab-bar {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.tab-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-right: 8rpx;
  border-bottom: 3rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}

.tab-label {
  font-size: 26rpx;
  color: #484f58;
  font-weight: 500;
}

.tab-item.tab-active {
  border-bottom-color: #58a6ff;
}

.tab-item.tab-active .tab-label {
  color: #58a6ff;
  font-weight: 600;
}

.tab-item.tab-locked .tab-label {
  color: #30363d;
}

.tab-lock-icon {
  font-size: 22rpx;
  margin-left: 4rpx;
}

/* ===== Tab 内容 ===== */
.tab-content {
  padding: 24rpx 32rpx;
}

/* ================================================================
   Tab1: 赛事概览
   ================================================================ */
.overview-section {
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: #161b22;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.os-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
  margin-bottom: 12rpx;
}

/* 简介标题行：标题 + 编辑笔 */
.os-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}
.os-title-row .os-title {
  margin-bottom: 0;
  flex: 1;
}

.os-desc {
  display: block;
  font-size: 26rpx;
  color: #8b949e;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.os-desc-editable {
  padding: 8rpx 12rpx;
  border: 1rpx dashed rgba(255,255,255,0.06);
  border-radius: 10rpx;
  transition: border-color 0.2s;
}
.os-desc-editable:active {
  border-color: rgba(31,111,235,0.3);
}

/* 简介编辑态 */
.os-desc-editing {
  margin-bottom: 16rpx;
}

.os-desc-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(31,111,235,0.4);
  border-radius: 12rpx;
  background: rgba(255,255,255,0.04);
  color: #c9d1d9;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.os-desc-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 12rpx;
}

.os-creator, .os-time {
  display: block;
  font-size: 22rpx;
  color: #484f58;
  margin-top: 4rpx;
}

/* 归档信息区（历史赛事概览专属） */
.os-archive-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.os-archive {
  display: block;
  font-size: 22rpx;
  color: #c68642;
  margin-top: 4rpx;
}

/* ===== 概览页操作按钮区 ===== */
.overview-action {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  text-align: center;
}

/* 开始报名：绿色 */
.ova-start-block {
  background: linear-gradient(135deg, rgba(39,174,96,0.08), rgba(46,160,67,0.04));
  border: 2rpx solid rgba(39,174,96,0.2);
}

/* 取消赛事：红色 */
.ova-cancel-block {
  background: linear-gradient(135deg, rgba(248,81,73,0.06), rgba(218,54,51,0.03));
  border: 2rpx solid rgba(248,81,73,0.2);
}

.ova-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.ova-btn-start {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #fff;
}

.ova-btn-danger {
  background: linear-gradient(135deg, #da3633, #f85149);
  color: #fff;
}

.ova-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8b949e;
  line-height: 1.5;
}

.ova-hint-danger {
  color: rgba(248,81,73,0.7);
}

/* ===== 赛事进度条 ===== */
.progress-section {
  padding: 0;
  margin-bottom: 24rpx;
}

.progress-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #8b949e;
  margin-bottom: 20rpx;
  display: block;
}

.progress-track {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 4rpx;
}

.progress-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}

.ps-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #484f58;
  position: relative;
  z-index: 1;
}

.ps-label {
  font-size: 20rpx;
  color: #484f58;
  text-align: center;
  white-space: nowrap;
}

/* 连接线 - 从当前 step 向左右延伸 */
.ps-line-right {
  position: absolute;
  top: 22rpx;
  left: 50%;
  right: -50%;
  height: 2rpx;
  background: rgba(255,255,255,0.08);
  z-index: 0;
}

.ps-line-left {
  position: absolute;
  top: 22rpx;
  left: -50%;
  right: 50%;
  height: 2rpx;
  background: rgba(255,255,255,0.08);
  z-index: 0;
}

/* 已完成 - 绿 */
.ps-done .ps-dot {
  background: rgba(39,174,96,0.2);
  border-color: #2ea043;
  color: #2ea043;
}
.ps-done .ps-label {
  color: #2ea043;
}
.ps-done .ps-line-right {
  background: rgba(39,174,96,0.3);
}

/* 当前 - 蓝 */
.ps-active .ps-dot {
  background: rgba(31,111,235,0.2);
  border-color: #1f6feb;
  color: #58a6ff;
}
.ps-active .ps-label {
  color: #58a6ff;
  font-weight: 600;
}

/* 已归档（最后一步激活=归档成功）- 绿 */
.ps-archived .ps-dot {
  background: rgba(39,174,96,0.2);
  border-color: #2ea043;
  color: #2ea043;
}
.ps-archived .ps-label {
  color: #2ea043;
  font-weight: 600;
}

/* ===== 快捷跳转按钮（单按钮，根据赛事阶段动态显示） ===== */
.overview-jump {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(31,111,235,0.08), rgba(56,139,253,0.04));
  border: 2rpx solid rgba(31,111,235,0.2);
  border-radius: 18rpx;
  text-align: center;
}

.oj-single-btn {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, #1f6feb, #388bfd);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.oj-single-btn::after {
  border: none;
}

.oj-single-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8b949e;
  line-height: 1.5;
}

/* ===== 底部统计 ===== */
.overview-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 14rpx;
  gap: 0;
}

.om-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.om-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6edf3;
}

.om-label {
  font-size: 22rpx;
  color: #8b949e;
}

.om-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.08);
}

/* ===== Tab2 管理员操作按钮 ===== */
.signup-admin-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.saa-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.saa-btn-primary {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #fff;
}

.saa-btn-warn {
  background: linear-gradient(135deg, #da3633, #f85149);
  color: #fff;
}

.saa-btn-danger {
  background: transparent;
  color: #f85149;
  border: 1rpx solid rgba(248,81,73,0.35);
  font-size: 24rpx;
}

.signup-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #fff;
}

.btn-cancel {
  background: rgba(231,76,60,0.15);
  color: #e74c3c;
  border: 1rpx solid rgba(231,76,60,0.3);
}

.btn-disabled {
  background: rgba(255,255,255,0.04);
  color: #484f58;
}

.signup-done {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: rgba(39,174,96,0.08);
  border-radius: 16rpx;
}

.done-icon {
  color: #3fb950;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 8rpx;
}

.done-text {
  font-size: 28rpx;
  color: #e6edf3;
}

/* ================================================================
   Tab2: 报名管理
   ================================================================ */
.signup-stats {
  margin-bottom: 20rpx;
}
.ss-count { font-size: 26rpx; color: #c9d1d9; }
.ss-num { color: #58a6ff; font-weight: 700; }
.ss-full { font-size: 22rpx; color: #f0883e; margin-left: 12rpx; }

/* 管理员搜索区 */
.signup-admin-area {
  margin-bottom: 24rpx;
}

.sa-search-bar {
  position: relative;
  margin-bottom: 12rpx;
}

.sa-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 72rpx 0 24rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

.sa-search-clear {
  position: absolute;
  right: 0;
  top: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b949e;
  font-size: 28rpx;
}

/* 搜索结果 */
.sa-search-results {
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.sa-result-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.sar-title { font-size: 24rpx; color: #8b949e; }

.sa-result-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.03);
}
.sa-result-item.sar-disabled { opacity: 0.4; }

.sari-name { font-size: 26rpx; color: #c9d1d9; flex: 1; }
.sari-rank { font-size: 22rpx; color: #8b949e; margin-right: 12rpx; }
.sari-tag { font-size: 20rpx; color: #f39c12; padding: 2rpx 10rpx; background: rgba(243,156,18,0.1); border-radius: 6rpx; }

.sari-add-btn {
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: 22rpx !important;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 20rpx;
  background: #238636 !important;
  color: #fff !important;
  border: none !important;
  border-radius: 8rpx;
}

.sa-no-result { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #484f58; }

/* 报名列表 */
.signup-list-section {
  margin-top: 8rpx;
}
.sls-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.sls-title { font-size: 28rpx; color: #e6edf3; font-weight: 600; }
.sls-count { font-size: 24rpx; color: #484f58; }

.signup-list { }
.signup-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #161b22;
