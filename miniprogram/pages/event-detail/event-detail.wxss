/* pages/event-detail/event-detail.wxss */
/* 【赛事详情页样式】深色主题，与项目主色调保持一致 */

.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 80rpx;
}

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
.loading-text {
  color: #8b949e;
  font-size: 28rpx;
}

/* ===== 赛事信息卡片 ===== */
.event-card {
  margin: 24rpx 24rpx 16rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #161b22, #1c2333);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.event-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6edf3;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.event-status {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}
/* 状态颜色映射（与现有段位风格统一） */
.s-draft  { background: rgba(139,148,158,0.15); color: #8b949e; }
.s-open   { background: rgba(63,185,80,0.15);  color: #3fb950; }
.s-closed { background: rgba(218,54,51,0.15);  color: #f85149; }
.s-locked { background: rgba(210,153,34,0.15);  color: #d29922; }
.s-fighting { background: rgba(31,111,235,0.15); color: #58a6ff; }
.s-archived { background: rgba(139,148,158,0.1); color: #6e7681; }

.event-meta {
  display: flex;
  flex-direction: row;
  gap: 40rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.meta-label {
  font-size: 22rpx;
  color: #8b949e;
}
.meta-value {
  font-size: 26rpx;
  color: #c9d1d9;
}
.meta-count {
  font-weight: 700;
  color: #58a6ff;
}

/* ===== 报名操作区域 ===== */
.signup-area {
  margin: 0 24rpx 24rpx;
}

/* 管理员操作按钮 */
.admin-actions {
  margin-bottom: 20rpx;
}

.admin-btn-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.admin-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
}

.btn-status {
  background: #238636;
  color: #ffffff;
}
.btn-status::after { border: none; }

.btn-danger {
  background: #da3633;
  color: #ffffff;
}
.btn-danger::after { border: none; }

.btn-manage {
  background: rgba(31,111,235,0.15);
  color: #58a6ff;
}
.btn-manage::after { border: none; }

.btn-disabled {
  opacity: 0.4 !important;
  pointer-events: none;
}

/* 普通用户报名 */
.user-signup {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signup-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  padding: 0;
}

.btn-primary {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(35,134,54,0.3);
}
.btn-primary::after { border: none; }

.btn-cancel {
  width: auto;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: rgba(248,81,73,0.12);
  color: #f85149;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 10rpx;
}
.btn-cancel::after { border: none; }

.btn-disabled {
  background: rgba(48,54,61,0.6);
  color: #484f58;
}

.signup-hint {
  margin-top: 12rpx;
  text-align: center;
}
.signup-hint text {
  font-size: 24rpx;
  color: #8b949e;
}

/* 已报名状态 */
.signup-done {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 20rpx 28rpx;
  background: rgba(63,185,80,0.08);
  border: 1rpx solid rgba(63,185,80,0.15);
  border-radius: 14rpx;
}

.signup-done-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.done-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #238636;
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
}

.done-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #3fb950;
}

.done-type {
  font-size: 22rpx;
  color: #8b949e;
}

/* 已取消报名 */
.signup-cancelled {
  padding: 20rpx 0;
  text-align: center;
}
.cancelled-text {
  font-size: 26rpx;
  color: #f85149;
}

/* ===== 已报名选手列表 ===== */
.signup-list-section {
  margin: 0 24rpx 40rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6edf3;
}

.section-count {
  font-size: 24rpx;
  color: #8b949e;
}

.signup-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.signup-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.si-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
  background: #1c2333;
}

.si-info {
  flex: 1;
  min-width: 0;
}

.si-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.si-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.si-type-tag {
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}
.type-self  { background: rgba(88,166,255,0.15); color: #58a6ff; }
.type-admin { background: rgba(210,153,34,0.15); color: #d29922; }

.si-rank-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.si-rank {
  font-size: 24rpx;
  color: #8b949e;
}

.si-star {
  font-size: 22rpx;
  color: #d29922;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #484f58;
}

.empty-sub {
  font-size: 24rpx;
  color: #30363d;
  margin-top: 8rpx;
}

/* ===== 弹窗（二次确认） ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-box {
  width: 580rpx;
  background: #161b22;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  padding: 40rpx 36rpx 28rpx;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 16rpx;
}

.modal-content {
  display: block;
  font-size: 26rpx;
  color: #8b949e;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-secondary {
  background: rgba(255,255,255,0.08);
  color: #c9d1d9;
}

.btn-danger {
  background: #da3633;
  color: #ffffff;
}

.btn-primary-confirm {
  background: #238636;
  color: #ffffff;
}
