  font-size: 20rpx;
  color: #8b949e;
  white-space: nowrap;
  flex-shrink: 0;
}

.rank-members-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.rank-member-tag {
  width: calc(50% - 4rpx);
  box-sizing: border-box;
  font-size: 20rpx;
  color: #8b949e;
  background: rgba(255,255,255,0.05);
  padding: 4rpx 8rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-team-mmr {
  font-size: 22rpx;
  color: #58a6ff;
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(88,166,255,0.06);
  border-radius: 8rpx;
}

.rank-empty {
  text-align: center;
  padding: 60rpx 20rpx;
}
.rank-empty-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.rank-empty-text { font-size: 26rpx; color: #8b949e; }

/* 归档按钮 */
.archive-btn-area {
  margin-top: 28rpx;
  text-align: center;
}

.archive-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #9a59b5, #bb86fc);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.archive-btn-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #484f58;
}

.archive-done-tip {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(119,141,169,0.06);
  border-radius: 10rpx;
  text-align: center;
}
.ad-text { font-size: 24rpx; color: #8b949e; }

/* ===== 通用空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}
.empty-state.mini { padding: 30rpx 20rpx; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #8b949e; }
.empty-sub { font-size: 22rpx; color: #484f58; margin-top: 8rpx; }

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.modal-mask::before,
.modal-mask::after {
  content: '';
  flex: 1;
  min-height: 0;
}

.modal-box {
  flex-shrink: 0;
  width: 92%;
  max-width: 600rpx;
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin: 0 auto;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 16rpx;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
}

.modal-content {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  line-height: 1.6;
  margin-bottom: 24rpx;
  white-space: pre-wrap;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary { background: rgba(255,255,255,0.06); color: #8b949e; }
.btn-danger { background: rgba(231,76,60,0.15); color: #e74c3c; border: 1rpx solid rgba(231,76,60,0.3); }
.btn-primary-confirm { background: linear-gradient(135deg, #1f6feb, #58a6ff); color: #fff; }

/* ── 对战确认弹窗 ── */
.bcm-list {
  margin-bottom: 16rpx;
}
.bcm-row {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 10rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.bcm-num {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #58a6ff;
  background: rgba(31,111,235,0.12);
  border-radius: 8rpx;
  margin-right: 16rpx;
}
.bcm-text {
  font-size: 26rpx;
  color: #e6edf3;
  line-height: 1.4;
}
.bcm-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(248,81,73,0.75);
  padding: 12rpx 16rpx;
  background: rgba(248,81,73,0.06);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

/* ===== 修改报名人数上限弹窗（匹配创建赛事 UI） ===== */

/* 当前已报名提示 */
.slim-count-hint {
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 20rpx;
}
.slim-count-num {
  color: #58a6ff;
  font-weight: 700;
}

/* 选项行 */
.limit-pick-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.limit-pick-opt {
  flex: 1;
  min-width: 120rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
  color: #8b949e;
  transition: all 0.15s;
}
.limit-pick-opt:active {
  background-color: rgba(255, 255, 255, 0.08);
}

.limit-pick-on {
  background-color: rgba(31, 111, 235, 0.15) !important;
  border-color: rgba(31, 111, 235, 0.4) !important;
  color: #58a6ff !important;
  font-weight: 600 !important;
}

/* 自定义输入行 */
.limit-pick-custom-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  gap: 12rpx;
}
.limit-pick-input {
  width: 200rpx;
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}
.limit-pick-input::placeholder { color: #4a5568; font-size: 24rpx; }

.limit-pick-unit {
  font-size: 24rpx;
  color: #8b949e;
}

/* 状态确认弹窗：报名人数上限选择器 */
.modal-label {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
}
.limit-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(31,111,235,0.25);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
}
.limit-picker-val {
  font-size: 30rpx;
  color: #58a6ff;
  font-weight: 600;
}
.limit-picker-arrow {
  font-size: 22rpx;
  color: #58a6ff;
  opacity: 0.6;
}
.limit-custom-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}
.limit-custom-input {
  width: 180rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(31,111,235,0.5);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #e6edf3;
  padding: 0 16rpx;
}
.limit-custom-unit {
  font-size: 26rpx;
  color: #8b949e;
}
.modal-btns-bottom {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

/* 自动分队：组数输入弹窗 */
.tcm-box {
  max-width: 520rpx;
}

.tcm-input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tcm-input {
  width: 200rpx;
  height: 80rpx;
  border: 1rpx solid rgba(31,111,235,0.3);
  border-radius: 14rpx;
  background: rgba(255,255,255,0.06);
  color: #58a6ff;
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  padding: 0 16rpx;
}

.tcm-unit {
  font-size: 28rpx;
  color: #8b949e;
  font-weight: 500;
}

.tcm-hint {
  display: block;
  font-size: 22rpx;
  color: #484f58;
  text-align: center;
  margin-bottom: 24rpx;
}

/* 胜负判定弹窗 */
.judge-modal .judge-prompt {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  margin-bottom: 16rpx;
}

.judge-options {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.judge-option {
  flex: 1;
  padding: 24rpx 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx;
  text-align: center;
}
.judge-option:active {
  background: rgba(31,111,235,0.12);
  border-color: rgba(31,111,235,0.3);
}

.jo-name {
  display: block;
  font-size: 24rpx;
  color: #e6edf3;
  font-weight: 600;
}
.jo-captain {
  display: block;
  font-size: 20rpx;
  color: #8b949e;
  margin-top: 4rpx;
}
.jo-mmr {
  display: block;
  font-size: 22rpx;
  color: #58a6ff;
  margin-top: 6rpx;
}

/* ── 换队选择弹窗 ── */
.swap-team-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.swap-team-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 12rpx;
  transition: all 0.15s;
}

.swap-team-item:active {
  background: rgba(31,111,235,0.1);
  border-color: rgba(31,111,235,0.3);
}

/* 已出战队伍高亮边框 */
.sti-inmatch {
  border-color: rgba(240,173,78,0.35);
  background: rgba(240,173,78,0.06);
}

.sti-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.sti-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.sti-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sti-score {
  font-size: 22rpx;
  color: #3fb950;
  font-weight: 600;
}
.sti-mmr {
  font-size: 20rpx;
  color: #8b949e;
  margin-top: 2rpx;
}

.sti-captain {
  font-size: 20rpx;
  color: #c68642;
}

/* 出战状态标记 */
.sti-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.sti-free {
  color: #3fb950;
  background: rgba(63,185,80,0.1);
}

.sti-busy {
  color: #f0ad4e;
  background: rgba(240,173,78,0.12);
}

.swap-team-hint {
  text-align: center;
  font-size: 24rpx;
  color: #484f58;
  padding: 24rpx 0 8rpx;
}

/* 换队弹窗：对战区/自由区分组标题 */
.swap-zone {
  margin-bottom: 8rpx;
}
.swap-zone-title {
  display: block;
  font-size: 22rpx;
  color: #8b949e;
  padding: 8rpx 0 6rpx;
}




