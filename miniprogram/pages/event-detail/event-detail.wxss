/* ============================================================
   pages/event-detail/event-detail.wxss
   赛事详情 - 阶段式Tab分栏重构版 样式
   深色主题(#0d1117)，完全复用原有风格
   ============================================================ */

/* ===== 基础 ===== */
.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 60rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #8b949e;
}

/* ===== 赛事信息卡片 ===== */
.event-card {
  margin: 24rpx 32rpx 16rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #161b22 0%, #1a1f2e 100%);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
}

.event-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.event-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #e6edf3;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.event-status {
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 状态颜色 */
.s-draft    { background: rgba(139,148,158,0.15); color: #8b949e; }
.s-open     { background: rgba(39,174,96,0.15);  color: #3fb950; border: 1rpx solid rgba(39,174,96,0.2); }
.s-closed   { background: rgba(243,156,18,0.15); color: #f39c12; border: 1rpx solid rgba(243,156,18,0.2); }
.s-locked   { background: rgba(52,152,219,0.15); color: #3498db; border: 1rpx solid rgba(52,152,219,0.2); }
.s-fighting { background: rgba(231,76,60,0.15);  color: #e74c3c; border: 1rpx solid rgba(231,76,60,0.2); }
.s-archived { background: rgba(119,141,169,0.12); color: #778da9; border: 1rpx solid rgba(119,141,169,0.2); }

.event-meta {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: #484f58;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 26rpx;
  color: #c9d1d9;
}

.meta-count {
  color: #58a6ff;
  font-weight: 600;
}

.archived-banner {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(119,141,169,0.08);
  border-radius: 10rpx;
  border: 1rpx solid rgba(119,141,169,0.12);
}

.ab-text {
  font-size: 22rpx;
  color: #8b949e;
}

/* ===== Tab 导航栏 ===== */
.tab-bar {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.tab-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-right: 8rpx;
  border-bottom: 3rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}

.tab-label {
  font-size: 26rpx;
  color: #484f58;
  font-weight: 500;
}

.tab-item.tab-active {
  border-bottom-color: #58a6ff;
}

.tab-item.tab-active .tab-label {
  color: #58a6ff;
  font-weight: 600;
}

.tab-item.tab-locked .tab-label {
  color: #30363d;
}

.tab-lock-icon {
  font-size: 22rpx;
  margin-left: 4rpx;
}

/* ===== Tab 内容 ===== */
.tab-content {
  padding: 24rpx 32rpx;
}

/* ================================================================
   Tab1: 赛事概览
   ================================================================ */
.overview-section {
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: #161b22;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.os-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
  margin-bottom: 12rpx;
}

.os-desc {
  display: block;
  font-size: 26rpx;
  color: #8b949e;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.os-creator, .os-time {
  display: block;
  font-size: 22rpx;
  color: #484f58;
  margin-top: 4rpx;
}

/* 归档信息区（历史赛事概览专属） */
.os-archive-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.os-archive {
  display: block;
  font-size: 22rpx;
  color: #c68642;
  margin-top: 4rpx;
}

/* 主操作按钮 */
.overview-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.oa-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.oa-btn-status {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #fff;
}

.oa-btn-warn {
  background: linear-gradient(135deg, #da3633, #f85149);
  color: #fff;
}

.oa-btn-archive {
  background: linear-gradient(135deg, #9a59b5, #bb86fc);
  color: #fff;
}

/* 普通用户报名入口 */
.overview-signup {
  margin-top: 16rpx;
}

.signup-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #238636, #2ea043);
  color: #fff;
}

.btn-cancel {
  background: rgba(231,76,60,0.15);
  color: #e74c3c;
  border: 1rpx solid rgba(231,76,60,0.3);
}

.btn-disabled {
  background: rgba(255,255,255,0.04);
  color: #484f58;
}

.signup-done {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: rgba(39,174,96,0.08);
  border-radius: 16rpx;
}

.sd-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.done-icon {
  color: #3fb950;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 8rpx;
}

.done-text {
  font-size: 28rpx;
  color: #e6edf3;
}

.done-type {
  font-size: 22rpx;
  color: #8b949e;
  margin-left: 8rpx;
}

.signup-hint {
  padding: 12rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: #484f58;
}

.signup-cancelled {
  padding: 20rpx;
  text-align: center;
}
.cancelled-text { font-size: 26rpx; color: #8b949e; }

/* ================================================================
   Tab2: 报名管理
   ================================================================ */
.signup-stats {
  margin-bottom: 20rpx;
}
.ss-count { font-size: 26rpx; color: #c9d1d9; }
.ss-num { color: #58a6ff; font-weight: 700; }

/* 管理员搜索区 */
.signup-admin-area {
  margin-bottom: 24rpx;
}

.sa-search-bar {
  position: relative;
  margin-bottom: 12rpx;
}

.sa-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 72rpx 0 24rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

.sa-search-clear {
  position: absolute;
  right: 0;
  top: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b949e;
  font-size: 28rpx;
}

/* 搜索结果 */
.sa-search-results {
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.sa-result-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.sar-title { font-size: 24rpx; color: #8b949e; }
.sar-batch-btn { font-size: 22rpx !important; background: #238636 !important; color: #fff !important; }

.sa-result-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.03);
}
.sa-result-item.sar-disabled { opacity: 0.4; }
.sa-result-item.sar-selected { background: rgba(31,111,235,0.1); }

.sari-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: transparent;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.sari-checkbox.cb-on { background: #238636; border-color: #238636; color: #fff; }
.sari-checkbox.cb-disabled { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.06); }

.sari-name { font-size: 26rpx; color: #c9d1d9; flex: 1; }
.sari-rank { font-size: 22rpx; color: #8b949e; margin-right: 12rpx; }
.sari-tag { font-size: 20rpx; color: #f39c12; padding: 2rpx 10rpx; background: rgba(243,156,18,0.1); border-radius: 6rpx; }

.sa-no-result { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #484f58; }

/* 报名列表 */
.signup-list-section {
  margin-top: 8rpx;
}
.sls-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.sls-title { font-size: 28rpx; color: #e6edf3; font-weight: 600; }
.sls-count { font-size: 24rpx; color: #484f58; }

.signup-list { }
.signup-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #161b22;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
}

.si-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
  border: 2rpx solid rgba(255,255,255,0.08);
}

.si-info { flex: 1; overflow: hidden; }
.si-name-row { display: flex; flex-direction: row; align-items: center; margin-bottom: 4rpx; }
.si-name { font-size: 26rpx; color: #e6edf3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 240rpx; }
.si-type-tag { margin-left: 8rpx; padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 20rpx; }
.type-admin { color: #58a6ff; background: rgba(31,111,235,0.1); }
.type-self { color: #3fb950; background: rgba(39,174,96,0.1); }
.si-rank-row { display: flex; flex-direction: row; align-items: center; }
.si-rank { font-size: 22rpx; color: #8b949e; }
.si-star { font-size: 20rpx; color: #f39c12; margin-left: 4rpx; }

.si-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e74c3c;
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 底部固定报名按钮 */
.tab2-bottom-signup {
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.05);
}

/* ================================================================
   Tab3: 分组编组
   ================================================================ */
.team-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ta-btn {
  flex: 1;
  height: 72rpx;
  background: rgba(52,152,219,0.12);
  color: #3498db;
  border: 1rpx solid rgba(52,152,219,0.25);
  border-radius: 14rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ta-btn-auto {
  background: rgba(39,174,96,0.12);
  color: #3fb950;
  border: 1rpx solid rgba(39,174,96,0.25);
}

.ta-btn-lock {
  background: linear-gradient(135deg, #da3633, #f85149);
  color: #fff;
  border: none;
  font-weight: 600;
}

/* 自由选手池 */
.team-section {
  margin-bottom: 24rpx;
}

.ts-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.ts-title {
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 600;
}

.ts-count {
  font-size: 22rpx;
  color: #484f58;
}

.free-agent-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.fa-item {
  padding: 8rpx 18rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.fa-name { font-size: 24rpx; color: #c9d1d9; }
.fa-rank { font-size: 20rpx; color: #8b949e; }
.fa-score { font-size: 20rpx; color: #484f58; }

/* 队伍卡片 */
.team-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.team-card {
  padding: 20rpx;
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.05);
  border-radius: 14rpx;
}

.tc-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tc-name {
  font-size: 28rpx;
  color: #e6edf3;
  font-weight: 600;
}

.tc-mmr {
  font-size: 24rpx;
  color: #58a6ff;
}

.tc-members {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tcm-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 6rpx 14rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 8rpx;
  gap: 4rpx;
}

.tcm-captain { font-size: 22rpx; }
.tcm-name { font-size: 24rpx; color: #c9d1d9; }
.tcm-rank { font-size: 20rpx; color: #8b949e; }

.team-readonly-tip {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #484f58;
}

/* ================================================================
   Tab4: 对阵对战
   ================================================================ */
.match-admin-bar {
  margin-bottom: 20rpx;
}

.ma-btn {
  width: 100%;
  height: 76rpx;
  background: linear-gradient(135deg, #1f6feb, #58a6ff);
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 轮次切换 */
.round-tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 4rpx 0;
}

.round-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 28rpx;
  margin-right: 12rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
  min-width: 120rpx;
}

.round-tab.rt-active {
  background: rgba(31,111,235,0.12);
  border-color: rgba(31,111,235,0.3);
}

.round-tab.rt-done {
  opacity: 0.6;
}

.rt-label {
  font-size: 24rpx;
  color: #c9d1d9;
  font-weight: 600;
}

.rt-active .rt-label { color: #58a6ff; }

.rt-progress {
  font-size: 20rpx;
  color: #8b949e;
  margin-top: 4rpx;
}

.rt-check {
  color: #3fb950;
  font-size: 22rpx;
}

/* 对战卡片 */
.match-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.match-card {
  padding: 20rpx;
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.05);
  border-radius: 14rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  position: relative;
}

.match-card.mc-clickable:active {
  background: #1c2333;
  border-color: rgba(31,111,235,0.2);
}

.mc-team {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
}

.mc-team.mc-winner {
  background: rgba(255,215,0,0.06);
  border-radius: 10rpx;
}

.mct-name {
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 600;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.mct-mmr {
  font-size: 22rpx;
  color: #8b949e;
  margin-top: 4rpx;
}

.mct-win-badge {
  font-size: 28rpx;
  margin-top: 4rpx;
}

.mc-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.mc-vs {
  font-size: 24rpx;
  color: #484f58;
  font-weight: 700;
}

.mc-status {
  font-size: 20rpx;
  margin-top: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.mc-status.s-done { color: #3fb950; background: rgba(39,174,96,0.1); }
.mc-status.s-pending { color: #f39c12; background: rgba(243,156,18,0.1); }

.mc-time {
  font-size: 18rpx;
  color: #484f58;
  margin-top: 4rpx;
}

.mc-admin-hint {
  position: absolute;
  bottom: 6rpx;
  right: 12rpx;
  font-size: 20rpx;
  color: #58a6ff;
}

/* 对战操作按钮 */
.battle-actions {
  margin-top: 20rpx;
}

.ba-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.ba-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ba-btn-next {
  background: linear-gradient(135deg, #1f6feb, #58a6ff);
  color: #fff;
}

.ba-btn-end {
  background: linear-gradient(135deg, #da3633, #f85149);
  color: #fff;
}

/* ================================================================
   Tab5: 名次归档
   ================================================================ */
.rank-section { }

.rank-section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.rank-section-title {
  font-size: 30rpx;
  color: #e6edf3;
  font-weight: 700;
}

.rank-edit-btn {
  font-size: 24rpx !important;
  background: rgba(52,152,219,0.12) !important;
  color: #3498db !important;
  border: 1rpx solid rgba(52,152,219,0.2) !important;
}

.rank-cancel-btn {
  font-size: 24rpx !important;
  background: rgba(255,255,255,0.05) !important;
  color: #8b949e !important;
}

/* 编辑模式 */
.rank-edit-area { }
.rank-slot-list { display: flex; flex-direction: column; gap: 14rpx; }

.rank-slot {
  padding: 18rpx 20rpx;
  background: #161b22;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.rank-slot-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.rank-slot-label {
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 600;
}

.rank-slot-remove {
  color: #e74c3c;
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.rank-picker {
  padding: 14rpx 18rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 10rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
}

.rank-picker-empty { color: #484f58; }
.rank-picker-filled { color: #e6edf3; }

.rank-picker-arrow {
  font-size: 20rpx;
  color: #8b949e;
}

.rank-add-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-top: 12rpx;
  border: 1rpx dashed rgba(255,255,255,0.1);
  border-radius: 14rpx;
}
.ram-icon { font-size: 32rpx; color: #58a6ff; margin-right: 8rpx; }
.ram-text { font-size: 24rpx; color: #8b949e; }

.rank-save-row {
  margin-top: 24rpx;
  text-align: center;
}
.rank-save-btn {
  width: 100%;
  height: 76rpx;
  background: linear-gradient(135deg, #1f6feb, #58a6ff);
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.rank-hint { font-size: 22rpx; color: #484f58; }

/* 查看模式 */
.rank-display { }
.rank-podium { display: flex; flex-direction: column; gap: 12rpx; }

.rank-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #161b22;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.rank-item.rank-gold   { background: rgba(255,215,0,0.06); border-color: rgba(255,215,0,0.15); }
.rank-item.rank-silver { background: rgba(192,192,192,0.05); border-color: rgba(192,192,192,0.1); }
.rank-item.rank-bronze { background: rgba(205,127,50,0.05); border-color: rgba(205,127,50,0.1); }

.rank-badge {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-badge-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #c9d1d9;
}

.rank-badge-medal {
  font-size: 42rpx;
}

.rank-info { flex: 1; }

.rank-team-name {
  font-size: 28rpx;
  color: #e6edf3;
  font-weight: 600;
}

.rank-team-mmr {
  font-size: 22rpx;
  color: #8b949e;
  margin-top: 4rpx;
}

.rank-empty {
  text-align: center;
  padding: 60rpx 20rpx;
}
.rank-empty-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.rank-empty-text { font-size: 26rpx; color: #8b949e; }

/* 归档按钮 */
.archive-btn-area {
  margin-top: 28rpx;
  text-align: center;
}

.archive-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #9a59b5, #bb86fc);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.archive-btn-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #484f58;
}

.archive-done-tip {
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(119,141,169,0.06);
  border-radius: 10rpx;
  text-align: center;
}
.ad-text { font-size: 24rpx; color: #8b949e; }

/* ===== 通用空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}
.empty-state.mini { padding: 30rpx 20rpx; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #8b949e; }
.empty-sub { font-size: 22rpx; color: #484f58; margin-top: 8rpx; }

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-box {
  width: 100%;
  max-width: 600rpx;
  background: #161b22;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 16rpx;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 16rpx;
}

.modal-content {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  line-height: 1.6;
  margin-bottom: 24rpx;
  white-space: pre-wrap;
}

.modal-btns {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary { background: rgba(255,255,255,0.06); color: #8b949e; }
.btn-danger { background: rgba(231,76,60,0.15); color: #e74c3c; border: 1rpx solid rgba(231,76,60,0.3); }
.btn-primary-confirm { background: linear-gradient(135deg, #1f6feb, #58a6ff); color: #fff; }

/* 胜负判定弹窗 */
.judge-modal .judge-prompt {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  margin-bottom: 16rpx;
}

.judge-options {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.judge-option {
  flex: 1;
  padding: 24rpx 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx;
  text-align: center;
}
.judge-option:active {
  background: rgba(31,111,235,0.12);
  border-color: rgba(31,111,235,0.3);
}

.jo-name {
  display: block;
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 600;
}
.jo-mmr {
  display: block;
  font-size: 22rpx;
  color: #8b949e;
  margin-top: 6rpx;
}
