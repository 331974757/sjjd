<!--pages/event-detail/event-detail.wxml-->
<!--【赛事详情页】展示赛事信息 + 报名区域 + 管理员操作按钮 + 已报名选手列表 -->
<view class="page">

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{!loaded}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{loaded && event}}">

    <!-- ====== 赛事信息卡片 ====== -->
    <view class="event-card">
      <view class="event-header">
        <text class="event-name">{{event.event_name}}</text>
        <view class="event-status {{event._statusClass}}">
          <text>{{event._statusName}}</text>
        </view>
      </view>
      <view class="event-meta">
        <view class="meta-item">
          <text class="meta-label">比赛时间</text>
          <text class="meta-value">{{event._timeLabel}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-label">已报名</text>
          <text class="meta-value meta-count">{{signupCount}} 人</text>
        </view>
      </view>
    </view>

    <!-- ====== 报名操作区域 ====== -->
    <view class="signup-area">

      <!-- 管理员操作按钮组 -->
      <view class="admin-actions" wx:if="{{isAdmin}}">
        <view class="admin-btn-row">
          <!-- 开启报名/截止报名按钮（根据当前状态动态展示） -->
          <button
            class="admin-btn btn-status {{event.event_status >= 2 ? 'btn-disabled' : ''}}"
            wx:if="{{event.event_status === 0}}"
            bindtap="showStatusConfirm"
            loading="{{loading}}"
          >开启报名</button>
          <button
            class="admin-btn btn-status btn-danger {{event.event_status >= 2 ? 'btn-disabled' : ''}}"
            wx:if="{{event.event_status === 1}}"
            bindtap="showStatusConfirm"
            loading="{{loading}}"
          >截止报名</button>
          <!-- 报名人员管理按钮 -->
          <button
            class="admin-btn btn-manage"
            bindtap="goSignupManage"
          >报名人员管理</button>
        </view>
      </view>

      <!-- 普通用户报名字段 -->
      <view class="user-signup">
        <!-- 状态：报名中 + 未报名 → 显示报名按钮 -->
        <button
          class="signup-btn btn-primary"
          wx:if="{{event.event_status === 1 && (!mySignup || !mySignup.signedUp)}}"
          bindtap="doSignup"
          loading="{{loading}}"
        >立即报名</button>

        <!-- 状态：报名中 + 已报名 → 显示已报名状态 + 取消按钮 -->
        <view class="signup-done" wx:if="{{event.event_status === 1 && mySignup && mySignup.signedUp}}">
          <view class="signup-done-left">
            <text class="done-icon">✓</text>
            <text class="done-text">已报名</text>
            <text class="done-type" wx:if="{{mySignup.signupType === 'admin_add'}}">（管理员添加）</text>
          </view>
          <button class="signup-btn btn-cancel" bindtap="showCancelConfirm">取消报名</button>
        </view>

        <!-- 状态：非报名中 + 未报名 → 灰化按钮 + 提示原因 -->
        <button
          class="signup-btn btn-disabled"
          wx:if="{{event.event_status !== 1 && (!mySignup || !mySignup.signedUp)}}"
          disabled
        >立即报名</button>
        <view class="signup-hint" wx:if="{{event.event_status !== 1 && (!mySignup || !mySignup.signedUp)}}">
          <text>{{getBtnDisabledReason()}}</text>
        </view>

        <!-- 状态：非报名中 + 已报名（如已截止后）→ 仅展示已报名状态 -->
        <view class="signup-done" wx:if="{{event.event_status !== 1 && mySignup && mySignup.signedUp}}">
          <view class="signup-done-left">
            <text class="done-icon">✓</text>
            <text class="done-text">已报名</text>
            <text class="done-type" wx:if="{{mySignup.signupType === 'admin_add'}}">（管理员添加）</text>
          </view>
        </view>

        <!-- 曾经取消过报名 -->
        <view class="signup-cancelled" wx:if="{{mySignup && mySignup.wasCancelled && !mySignup.signedUp}}">
          <text class="cancelled-text">您已取消报名</text>
        </view>
      </view>
    </view>

    <!-- ====== 已报名选手列表 ====== -->
    <view class="signup-list-section">
      <view class="section-header">
        <text class="section-title">已报名选手</text>
        <text class="section-count">共 {{signupCount}} 人</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{signups.length === 0}}">
        <text class="empty-icon">👥</text>
        <text class="empty-text">暂无报名选手</text>
        <text class="empty-sub" wx:if="{{event.event_status === 1}}">等待选手报名中...</text>
      </view>

      <!-- 选手列表 -->
      <view class="signup-list" wx:if="{{signups.length > 0}}">
        <view class="signup-item" wx:for="{{signups}}" wx:key="signup_id">
          <image class="si-avatar" src="{{item.avatar_url || '/assets/default-avatar.png'}}" mode="aspectFill" />
          <view class="si-info">
            <view class="si-name-row">
              <text class="si-name">{{item.wx_nickname || '未知选手'}}</text>
              <view class="si-type-tag {{item._typeClass}}">
                <text>{{item._typeLabel}}</text>
              </view>
            </view>
            <view class="si-rank-row">
              <text class="si-rank">{{item.calibrate_rank_name || '未定段'}}</text>
              <text class="si-star" wx:if="{{item.calibrate_rank_star > 0}}">{{item.calibrate_rank_star}}★</text>
            </view>
          </view>
        </view>
      </view>
    </view>

  </block>

  <!-- 赛事不存在 -->
  <view class="empty-state" wx:if="{{loaded && !event}}">
    <text class="empty-icon">🏆</text>
    <text class="empty-text">赛事不存在或已删除</text>
  </view>

  <!-- ====== 取消报名二次确认弹窗 ====== -->
  <view class="modal-mask" wx:if="{{showCancelConfirm}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">取消报名</text>
      <text class="modal-content">确定取消当前赛事的报名吗？<br/>取消后可重新报名。</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideCancelConfirm"><text>再想想</text></view>
        <view class="modal-btn btn-danger" bindtap="doCancelSignup"><text>确认取消</text></view>
      </view>
    </view>
  </view>

  <!-- ====== 状态变更二次确认弹窗 ====== -->
  <view class="modal-mask" wx:if="{{showStatusConfirm}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">{{_confirmTitle}}</text>
      <text class="modal-content">{{_confirmMsg}}</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideStatusConfirm"><text>取消</text></view>
        <view class="modal-btn btn-primary-confirm" bindtap="doChangeStatus"><text>确认</text></view>
      </view>
    </view>
  </view>

</view>
