<!--pages/event-detail/event-detail.wxml-->
<!--【赛事详情 - 阶段式Tab分栏重构版】5个Tab按业务流程排列，随赛事状态递进解锁-->
<!-- 页面标题 -->
<view class="page-header">
  <text class="page-header-title">赛事详情</text>
  <text class="page-header-sub">赛事全流程管理</text>
</view>

<view class="page">

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{!loaded}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{loaded && event}}">

    <!-- ====== 赛事基本信息头部 ====== -->
    <view class="event-card">
      <view class="event-header">
        <!-- 左侧：赛事名 + 编辑图标 -->
        <view class="event-name-row" wx:if="{{!editingName}}">
          <text class="event-name">{{event.event_name}}</text>
          <text class="edit-pencil" wx:if="{{isAdmin && !isArchived}}" bindtap="startEditName">✎</text>
        </view>
        <view class="event-name-row event-name-editing" wx:else>
          <input class="event-name-input" value="{{editNameValue}}" placeholder="赛事名称" bindinput="onEditNameInput" focus="{{true}}" maxlength="50"/>
          <text class="edit-done" bindtap="confirmEditName">✓︎</text>
          <text class="edit-cancel" bindtap="cancelEditName">✕︎</text>
        </view>

        <!-- 右侧区域：状态 + 删除组 + 刷新 -->
        <view class="event-header-right">
          <view class="event-status {{event._statusClass}}">
            <text>{{event._statusName}}</text>
          </view>
        </view>
        <!-- 刷新按钮 -->
        <view class="event-refresh" bindtap="onRefreshTap">
          <image class="icon-img-sm" src="/images/icons/refresh.svg" mode="aspectFit"/>
        </view>
      </view>

      <view class="event-meta">
        <view class="event-meta-left">
          <view class="meta-item">
            <text class="meta-label">比赛时间<text wx:if="{{isAdmin && !isArchived && event.event_status < 4}}" class="meta-edit-icon"> ✎</text></text>
            <picker wx:if="{{isAdmin && !isArchived && event.event_status < 4}}" mode="multiSelector" range="{{editDateTimeRange}}" value="{{editDateTimeIndex}}" bindchange="onEditDateTimeChange" bindcolumnchange="onEditDateTimeColumnChange">
              <view class="meta-value meta-time-editable">{{event._timeLabel}}</view>
            </picker>
            <text wx:else class="meta-value">{{event._timeLabel}}</text>
          </view>
          <!-- 报名人数：状态>0才显示，状态0时由按钮区提示上限 -->
          <view wx:if="{{event.event_status > 0}}" class="meta-item {{isAdmin && !isArchived && event.event_status < 3 ? 'meta-clickable' : ''}}" bindtap="{{isAdmin && !isArchived && event.event_status < 3 ? 'showEditSignupLimit' : ''}}">
            <text class="meta-label">已报名<text wx:if="{{isAdmin && !isArchived && event.event_status < 3}}" class="meta-edit-icon"> ✎</text></text>
            <text class="meta-value meta-count">{{signupCount}}<text wx:if="{{event.signup_limit && event.signup_limit > 0}}">/{{event.signup_limit}}</text> 人</text>
            <text class="meta-sub" wx:if="{{event.signup_limit && event.signup_limit > 0 && signupCount >= event.signup_limit}}">（已满）</text>
          </view>
        </view>
        <!-- 删除入口：与比赛时间同列高度，右侧 -->
        <view class="event-del-group" wx:if="{{event.event_status < 4 && isSuperAdmin && !isArchived}}">
          <text class="event-del-hint-text">对阵前可删除</text>
          <view class="event-del-btn" bindtap="showCancelEvent">
            <image class="icon-img-sm" src="/images/icons/trash.svg" mode="aspectFit"/>
          </view>
        </view>
      </view>
      <!-- 历史/归档只读提示 -->
      <view class="archived-banner" wx:if="{{isArchived}}">
        <text class="ab-text">{{readonly ? '📋 历史赛事 · 纯只读查看 · 所有数据已归档固化' : '🔒 赛事已归档，所有数据为只读状态'}}</text>
      </view>
    </view>

    <!-- ====== Tab 导航栏 ====== -->
    <scroll-view class="tab-bar" scroll-x="true" enable-flex>
      <view
        class="tab-item {{activeTab === item.key ? 'tab-active' : ''}} {{item._locked && !readonly ? 'tab-locked' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        bindtap="switchTab"
        data-tab="{{item.key}}"
      >
        <text class="tab-label">{{item.label}}</text>
        <text class="tab-lock-icon" wx:if="{{item._locked && !readonly}}">🔒</text>
      </view>
    </scroll-view>

    <!-- ====== Tab 内容区域 ====== -->

    <!--  ================================================================
          Tab1: 赛事概览
          ================================================================ -->
    <view class="tab-content" wx:if="{{activeTab === 'overview'}}">
      <!-- 赛事简介 -->
      <view class="overview-section">
        <view class="os-title-row">
          <text class="os-title">📋 赛事简介</text>
          <text class="edit-pencil edit-pencil-sm" wx:if="{{isAdmin && !isArchived && !editingDesc}}" bindtap="startEditDesc">✎</text>
        </view>
        <text class="os-desc {{isAdmin && !isArchived ? 'os-desc-editable' : ''}}" wx:if="{{!editingDesc}}" bindtap="{{isAdmin && !isArchived ? 'startEditDesc' : ''}}">{{event.event_desc || '暂无简介'}}</text>
        <view class="os-desc-editing" wx:else>
          <textarea class="os-desc-textarea" value="{{editDescValue}}" placeholder="请输入赛事简介..." bindinput="onEditDescInput" focus="{{true}}" auto-height maxlength="500"/>
          <view class="os-desc-actions">
            <text class="edit-done" bindtap="confirmEditDesc">✓︎</text>
            <text class="edit-cancel" bindtap="cancelEditDesc">✕︎</text>
          </view>
        </view>
        <text class="os-creator" wx:if="{{event.creator_nickname}}">创建人：{{event.creator_nickname}}</text>
        <text class="os-time" wx:if="{{event._createdAtText}}">{{event._createdAtText}}</text>
        <view class="os-archive-info" wx:if="{{isArchived}}">
          <text class="os-archive" wx:if="{{_archiveTimeText}}">{{_archiveTimeText}}</text>
          <text class="os-archive" wx:if="{{_archiveByText}}">{{_archiveByText}}</text>
        </view>
      </view>

      <!-- 概览操作按钮区 -->
      <!-- 状态0：开始报名 -->
      <view class="overview-action ova-start-block" wx:if="{{event.event_status === 0 && isAdmin && !isArchived && actions.change_status.allowed}}">
        <button class="ova-btn ova-btn-start" bindtap="showStatusConfirm" loading="{{loading}}">
          📝 开始报名
        </button>
        <text class="ova-hint" wx:if="{{!event.signup_limit || event.signup_limit <= 0}}">点击开启报名，可设置人数上限让选手自助报名</text>
        <text class="ova-hint" wx:else>上限 {{event.signup_limit}} 人，点击确认即可开启</text>
      </view>



      <!-- 赛事进度条 -->
      <view class="progress-section">
        <text class="progress-title">🏁 赛事进度</text>
        <view class="progress-track">
          <view
            class="progress-step {{item.state === 'active' ? 'ps-active' : ''}} {{item.state === 'done' ? 'ps-done' : ''}} {{item.label === '已归档' && item.state === 'active' ? 'ps-archived' : ''}}"
            wx:for="{{progressSteps}}"
            wx:key="label"
          >
            <view class="ps-dot">
              <text wx:if="{{item.state === 'done'}}">✓︎</text>
              <text wx:else>{{index + 1}}</text>
            </view>
            <view class="ps-line-right" wx:if="{{index < 6}}"></view>
            <view class="ps-line-left" wx:if="{{index > 0}}"></view>
            <text class="ps-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 快捷跳转按钮（根据赛事阶段动态显示单个按钮） -->
      <view class="overview-jump" wx:if="{{_overviewJump && !isArchived}}">
        <button class="oj-single-btn" bindtap="switchTab" data-tab="{{_overviewJump.tab}}">
          {{_overviewJump.label}}
        </button>
        <text class="oj-single-hint">{{_overviewJump.desc}}</text>
      </view>
      <!-- 归档赛事：克隆按钮 -->
      <view class="overview-jump" wx:if="{{readonly || isArchived}}">
        <button class="oj-single-btn oj-clone-btn" bindtap="cloneEvent" loading="{{_cloning}}">
          {{_cloning ? '克隆中...' : '📋 克隆此赛事'}}
        </button>
        <text class="oj-single-hint">复制赛事信息到新赛事（含章程）</text>
      </view>

      <!-- 底部统计 -->
      <view class="overview-meta" wx:if="{{event.event_status > 0}}">
        <view class="om-item">
          <text class="om-num">{{signupCount}}</text>
          <text class="om-label">已报名</text>
        </view>
        <view class="om-divider"></view>
        <view class="om-item" wx:if="{{teams.length > 0 || event.event_status >= 2}}">
          <text class="om-num">{{teams.length || 0}}</text>
          <text class="om-label">队伍数</text>
        </view>
        <view class="om-divider" wx:if="{{event.event_status >= 5 || isArchived}}"></view>
        <view class="om-item" wx:if="{{event.event_status >= 5 || isArchived}}">
          <text class="om-num">{{ranks.length || 0}}</text>
          <text class="om-label">已排名</text>
        </view>
      </view>
    </view>

    <!--  ================================================================
          Tab2: 报名管理
          ================================================================ -->
    <view class="tab-content" wx:if="{{activeTab === 'signups'}}">
      <!-- 管理员操作区：状态流转 -->
      <view class="signup-admin-actions" wx:if="{{actions.change_status.allowed && !isArchived}}">
        <!-- 状态0: 开启报名 -->
        <button class="saa-btn saa-btn-primary" wx:if="{{event.event_status === 0}}" bindtap="showStatusConfirm" loading="{{loading}}">📝 开启报名</button>
        <!-- 状态1: 截止报名 -->
        <button class="saa-btn saa-btn-warn" wx:if="{{event.event_status === 1}}" bindtap="showStatusConfirm" loading="{{loading}}">🚫 截止报名</button>

      </view>

      <!-- 顶部统计 -->
      <view class="signup-stats">
        <text class="ss-count">已报名：<text class="ss-num">{{signupCount}}</text><text wx:if="{{event.signup_limit && event.signup_limit > 0}}">/{{event.signup_limit}}</text> 人</text>
        <text class="ss-full" wx:if="{{event.signup_limit && event.signup_limit > 0 && signupCount >= event.signup_limit}}">⚠ 名额已满</text>
      </view>

      <!-- 管理员操作区：搜索选手添加 -->
      <view class="signup-admin-area" wx:if="{{actions.manage_signups.allowed && !isArchived}}">
        <view class="sa-search-bar">
          <input class="sa-search-input" placeholder="搜索选手昵称..." value="{{searchKeyword}}" bindinput="onSearchInput" />
          <view class="sa-search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕︎</view>
        </view>

        <!-- 搜索结果 -->
        <view class="sa-search-results" wx:if="{{searchResults.length > 0}}">
          <view class="sa-result-header">
            <text class="sar-title">搜索结果</text>
          </view>
          <view
            class="sa-result-item {{item._alreadySigned ? 'sar-disabled' : ''}}"
            wx:for="{{searchResults}}"
            wx:key="_id"
          >
            <text class="sari-name">{{item.wx_nickname || '未知'}}</text>
            <text class="sari-rank">{{item.calibrate_rank_name || '未定段'}}</text>
            <text class="sari-tag" wx:if="{{item._alreadySigned}}">已报名</text>
            <button class="sari-add-btn" wx:if="{{!item._alreadySigned}}" catchtap="doSingleAdd" data-pid="{{item._id}}" size="mini">添加</button>
          </view>
        </view>
        <view class="sa-no-result" wx:if="{{searchKeyword && searchKeyword.length > 0 && !searchLoading && searchResults.length === 0}}">
          <text>未找到匹配选手</text>
        </view>
      </view>

      <!-- 报名人员列表 -->
      <view class="signup-list-section">
        <view class="sls-header"><text class="sls-title">报名人员列表</text><text class="sls-count">共 {{signupTotal}} 人</text></view>
        <view class="empty-state" wx:if="{{signups.length === 0}}">
          <text class="empty-icon">👥</text>
          <text class="empty-text">暂无报名选手</text>
        </view>
        <view class="signup-list" wx:if="{{signups.length > 0}}">
          <view class="signup-item" wx:for="{{signups}}" wx:key="signup_id">
            <image class="si-avatar" src="{{item.avatar_url || ''}}" mode="aspectFill" />
            <view class="si-info">
              <view class="si-name-row">
                <text class="si-name">{{item.wx_nickname || '未知选手'}}</text>
                <view class="si-type-tag {{item._typeClass}}"><text>{{item._typeLabel}}</text></view>
              </view>
              <view class="si-rank-row">
                <text class="si-rank">{{item.calibrate_rank_name || '未定段'}}</text>
                <text class="si-star" wx:if="{{item.calibrate_rank_star > 0}}">{{item.calibrate_rank_star}}★</text>
              </view>
            </view>
            <!-- 管理员剔除按钮 -->
            <view class="si-remove" wx:if="{{actions.manage_signups.allowed && !isArchived && event.event_status < 3}}" bindtap="showRemoveSignup" data-sid="{{item.signup_id}}">
              <text>✕︎</text>
            </view>
          </view>
        </view>

        <!-- 分页控件 -->
        <view class="signup-pagination" wx:if="{{signupTotal > signupPageSize}}">
          <view class="sp-btn sp-prev {{signupPage <= 1 ? 'sp-disabled' : ''}}" bindtap="goSignupPage" data-page="{{signupPage - 1}}">
            <text>上一页</text>
          </view>
          <view class="sp-info">
            <text class="sp-current">{{signupPage}}</text>
            <text class="sp-sep">/</text>
            <text class="sp-total">{{signupTotalPages}}</text>
          </view>
          <view class="sp-btn sp-next {{!signupHasMore ? 'sp-disabled' : ''}}" bindtap="goSignupPage" data-page="{{signupPage + 1}}">
            <text>下一页</text>
          </view>
        </view>
      </view>

      <!-- 普通用户报名按钮（底部固定） -->
      <view class="tab2-bottom-signup" wx:if="{{!readonly && !isArchived}}">
        <button class="signup-btn btn-primary" wx:if="{{signupBtn.allowed && mySignupLoaded && (!mySignup || !mySignup.isActive)}}" bindtap="doSignup" loading="{{loading}}">我要报名</button>
        <view class="signup-done" wx:if="{{mySignup && mySignup.isActive}}">
          <text class="done-icon">✓︎</text>
          <text class="done-text">已报名</text>
          <button class="signup-btn btn-cancel" wx:if="{{cancelSignupBtn.allowed}}" bindtap="showCancelSignup">取消报名</button>
        </view>
      </view>
    </view>

    <!--  ================================================================
          Tab3: 分组编组
          ================================================================ -->
    <view class="tab-content" wx:if="{{activeTab === 'teams'}}">

      <!-- 操作提示（仅管理员可编辑时） -->
      <view class="team-hint" wx:if="{{actions.manage_teams.allowed && !isArchived && event.event_status < 3}}">
        <text>👆 点击自由选手选中，再点击队伍卡片放入 · 点击队员 × 移回自由区 · 点击 ♔ 设为队长</text>
      </view>

      <!-- 操作按钮区 -->
      <!-- 状态2: 编辑阶段 → 自动分队 + 新建队伍 -->
      <view class="team-actions" wx:if="{{actions.manage_teams.allowed && !isArchived && event.event_status === 2}}">
        <button class="ta-btn ta-btn-auto" bindtap="doAutoAllocate" loading="{{allocating}}">🤖 自动分队</button>
        <button class="ta-btn" bindtap="addTeam">+ 新建队伍</button>
      </view>
      <!-- 保存编组：独占一行在下方 -->
      <view class="team-actions" wx:if="{{actions.manage_teams.allowed && !isArchived && teams.length > 0 && event.event_status === 2}}">
        <button class="ta-btn ta-btn-save" bindtap="saveTeams" loading="{{teamsSaving}}">💾 保存编组</button>
      </view>
      <!-- 分隔线 -->
      <view class="team-actions-divider" wx:if="{{actions.lock_teams.allowed && !isArchived && teams.length > 0}}">
        <view class="tad-line"></view>
        <text class="tad-label">— 确认编组无误后 —</text>
        <view class="tad-line"></view>
      </view>
      <!-- 状态2: 有队伍 → 锁定开赛（进入对战预备） -->
      <view class="team-actions team-actions-lock" wx:if="{{actions.lock_teams.allowed && !isArchived && teams.length > 0}}">
        <button class="ta-btn ta-btn-lock" bindtap="doLockTeams" loading="{{locking}}" disabled="{{teamsDirty}}">🔒 锁定开赛</button>
        <view class="ta-lock-hint" wx:if="{{teamsDirty}}">⚠ 请先保存编组</view>
      </view>

      <!-- 自由选手池 -->
      <view class="team-section">
        <view class="ts-header">
          <text class="ts-title">🏊 自由选手</text>
          <text class="ts-count">{{freeAgents.length}} 人</text>
        </view>
        <view class="free-agent-list" wx:if="{{freeAgents.length > 0}}">
          <view
            class="fa-item {{selectedPlayerId === item.id ? 'fa-selected' : ''}}"
            wx:for="{{freeAgents}}"
            wx:key="id"
            wx:if="{{item.id}}"
            bindtap="{{actions.manage_teams.allowed && !isArchived && event.event_status < 3 ? 'selectFreeAgent' : ''}}"
            data-player-id="{{item.id}}"
          >
            <image class="fa-avatar" src="{{item.avatar_url || ''}}" mode="aspectFill" />
            <view class="fa-info">
              <text class="fa-name">{{item.wx_nickname || item.nickName || '未知'}}</text>
              <text class="fa-rank">{{item.calibrate_rank_name || '未定段'}}{{item.calibrate_rank_star ? ' '+item.calibrate_rank_star+'★' : ''}}</text>
            </view>
            <view class="fa-meta">
              <text class="fa-pos" wx:if="{{item._posText}}">{{item._posText}}</text>
              <text class="fa-score">{{(item.calibrate_mmr || 0)}}分</text>
            </view>
            <view class="fa-check" wx:if="{{selectedPlayerId === item.id}}"><text>✓︎</text></view>
          </view>
        </view>
        <view class="empty-state mini" wx:if="{{freeAgents.length === 0}}">
          <text class="empty-text">所有选手已编组</text>
        </view>
      </view>

      <!-- 队伍列表 -->
      <view class="team-section">
        <view class="ts-header">
          <text class="ts-title">🏴 队伍列表</text>
          <text class="ts-count">{{teams.length}} 队</text>
        </view>
        <view class="empty-state" wx:if="{{teams.length === 0 && teamsLoading}}">
          <text class="empty-text">加载中...</text>
        </view>
        <view class="empty-state" wx:if="{{teams.length === 0 && !teamsLoading}}">
          <text class="empty-icon">🏗</text>
          <text class="empty-text">尚未编组</text>
          <text class="empty-sub" wx:if="{{actions.manage_teams.allowed}}">点击「自动分队」或「新建队伍」开始</text>
        </view>
        <view class="team-list" wx:if="{{teams.length > 0}}">
          <view
            class="team-card {{selectedPlayerId && event.event_status < 3 && !isArchived ? 'tc-droppable' : ''}}"
            wx:for="{{teams}}"
            wx:key="team_id"
            bindtap="{{selectedPlayerId && actions.manage_teams.allowed && !isArchived && event.event_status < 4 ? 'dropToTeam' : ''}}"
            data-team-id="{{item.team_id}}"
          >
            <view class="tc-header">
              <!-- 战队名：编辑模式 -->
              <block wx:if="{{_editingTeamId === item.team_id}}">
                <input class="tc-name-input" value="{{_editTeamNameValue}}" placeholder="输入战队名" bindinput="onEditTeamNameInput" focus="{{true}}" maxlength="50"/>
                <text class="tc-name-confirm" catchtap="confirmEditTeamName">✓︎</text>
                <text class="tc-name-cancel" catchtap="cancelEditTeamName">✕︎</text>
              </block>
              <!-- 战队名：查看模式 -->
              <block wx:else>
                <view class="tc-name-row">
                  <text class="tc-name">{{item.team_name || '未命名'}}</text>
                  <text class="tc-name-edit" wx:if="{{item._canEditName}}" catchtap="startEditTeamName" data-team-id="{{item.team_id}}">✎</text>
                </view>
              </block>
              <view class="tc-header-right">
                <text class="tc-mmr">总分 {{item.total_mmr || 0}}　均分 {{item._avgMmr || 0}}</text>
                <text class="tc-count">{{item._memberCount}}人</text>
                <view class="tc-del-btn" wx:if="{{actions.manage_teams.allowed && !isArchived && event.event_status < 3}}" catchtap="deleteTeam" data-team-id="{{item.team_id}}">
                  <text>×</text>
                </view>
              </view>
            </view>
            <!-- 队长行 -->
            <view class="tc-captain" wx:if="{{item.captain_name || item.captain_id}}">
              <text class="tcc-icon">👑</text>
              <text class="tcc-name">队长：{{item.captain_name || '未知'}}</text>
            </view>
            <view class="tc-captain tc-no-captain" wx:elif="{{actions.manage_teams.allowed && !isArchived && event.event_status < 4 && item._memberCount > 0}}">
              <text class="tcc-name">⚠ 未指定队长</text>
            </view>
            <!-- 队员列表 -->
            <view class="tc-members">
              <view
                class="tcm-item {{m.id === item.captain_id ? 'tcm-captain' : ''}}"
                wx:for="{{item.members || item.players}}"
                wx:key="id"
                wx:for-item="m"
              >
                <image class="tcm-avatar" src="{{m.avatar_url || ''}}" mode="aspectFill" />
                <view class="tcm-info">
                  <text class="tcm-name">{{m.wx_nickname || m.nickName || '未知'}}</text>
                  <text class="tcm-rank">{{m.calibrate_rank_name || m.calibrate_rank_label || '未定段'}}{{m.calibrate_rank_star ? ' '+m.calibrate_rank_star+'★' : ''}}</text>
                </view>
                <view class="tcm-meta">
                  <text class="tcm-pos" wx:if="{{m._posText}}">{{m._posText}}</text>
                  <text class="tcm-mmr">{{(m.calibrate_mmr || 0)}}分</text>
                </view>
                <!-- 操作按钮 -->
                <view class="tcm-actions" wx:if="{{actions.manage_teams.allowed && !isArchived && event.event_status < 3}}">
                  <view class="tcm-set-capt {{m.id === item.captain_id ? 'tcm-is-capt' : ''}}" catchtap="setTeamCaptain" data-team-id="{{item.team_id}}" data-player-id="{{m.id}}">
                    <text>{{m.id === item.captain_id ? '👑' : '♔'}}</text>
                  </view>
                  <view class="tcm-remove" catchtap="removeFromTeam" data-team-id="{{item.team_id}}" data-player-id="{{m.id}}">
                    <text>×</text>
                  </view>
                </view>
              </view>
            </view>
            <!-- 放入提示 -->
            <view class="tc-drop-hint" wx:if="{{selectedPlayerId && actions.manage_teams.allowed && !isArchived && event.event_status < 3}}">
              <text>📥 点击放入此队</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 只读提示（状态≠编辑中） -->
      <view class="team-readonly-tip" wx:if="{{event.event_status !== 2 && (event.event_status >= 3 || isArchived)}}">
        <text wx:if="{{isArchived}}">🔒 赛事已归档，队伍信息为只读</text>
        <text wx:elif="{{event.event_status === 4}}">🔒 对战中，队伍信息为只读状态</text>
        <text wx:elif="{{event.event_status === 3}}">🔒 对战预备，队伍不可修改</text>
        <text wx:else>🔒 队伍信息为只读状态</text>
      </view>
    </view>

    <!--  ================================================================
          Tab4: 对阵对战（积分榜模式）
          流程: 选队 → 自动匹配 → 调整配对 → 确认生成(自动锁队) → 判胜负 → 下一轮/结束
          ================================================================ -->
    <view class="tab-content" wx:if="{{activeTab === 'matches'}}">

      <!-- 加载中 -->
      <view class="empty-state mini" wx:if="{{battleLoading}}">
        <text class="empty-text">加载中...</text>
      </view>

      <block wx:if="{{!battleLoading}}">

      <!-- 返回分组编队按钮（仅状态3且未开始对战时可见） -->
      <view class="back-to-teams-bar" wx:if="{{isAdmin && !isArchived && event.event_status === 3 && battleRoundStatus !== 'fighting'}}">
        <view class="btt-group">
          <view class="btt-btn" bindtap="doBackToTeams">↩ 返回分组编队</view>
          <text class="btt-hint">对战开始前可返回重新编辑队伍</text>
        </view>
      </view>

      <!-- ========== 一、出战队伍（始终展示） ========== -->
      <view class="sb-section" wx:if="{{battleScoreboard.length > 0}}">
        <view class="sb-header">
          <text class="sb-title">⚔️ 出战队伍</text>
          <text class="sb-count">{{battleScoreboard.length}} 队</text>
        </view>
        <text class="sb-hint" wx:if="{{actions.manage_matches.allowed && !isArchived && battleRoundStatus !== 'fighting' && battleRoundStatus !== 'done'}}">👆 点击队伍卡片高亮选中参战队 - 不选择则默认全部参战</text>
        <view class="sb-list sb-grid">
          <view
            class="sb-card {{item._selected ? 'sb-selected' : ''}} {{battleRoundStatus === 'fighting' || battleRoundStatus === 'done' || isArchived ? 'sb-readonly' : ''}}"
            wx:for="{{battleScoreboard}}"
            wx:key="teamId"
            bindtap="{{battleRoundStatus === 'fighting' || battleRoundStatus === 'done' || !actions.manage_matches.allowed || isArchived || (item._matchId && item._matchStatus === 0) ? '' : 'toggleBattleTeam'}}"
            data-team-id="{{item.teamId}}"
          >
            <view class="sbc-info">
              <text class="sbc-name">{{item.teamName || '未命名'}}</text>
              <text class="sbc-captain">👑 {{item.captainName || '未知'}}</text>
            </view>
            <view class="sbc-right">
              <text class="sbc-wins">🏅 {{item.wins || 0}}胜</text>
              <text class="sbc-losses" wx:if="{{item.losses > 0}}">{{item.losses}}负</text>
              <text class="sbc-mmr">📊 均{{item.avgMmr || 0}}分</text>
            </view>
            <!-- 更换队伍按钮 -->
            <view class="sbc-swap" wx:if="{{item._matchId && item._matchStatus === 0 && actions.manage_matches.allowed && !isArchived}}" catchtap="openTeamSwap" data-team-id="{{item.teamId}}">
              <text>⇄ 更换</text>
            </view>
            <view class="sbc-check" wx:if="{{item._selected && battleRoundStatus !== 'fighting' && battleRoundStatus !== 'done'}}">
              <text>✓︎</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 暂无队伍 -->
      <view class="empty-state" wx:if="{{battleScoreboard.length === 0 && !battleRoundHasMatches}}">
        <text class="empty-icon">⚔️</text>
        <text class="empty-text">暂无队伍数据</text>
        <text class="empty-sub">请先在「分组编组」页完成队伍编制</text>
      </view>

      <!-- ========== 二、快捷操作栏（选队/配对阶段） ========== -->
      <view class="bb-quick-bar" wx:if="{{actions.manage_matches.allowed && !isArchived && battleRoundStatus !== 'fighting' && battleRoundStatus !== 'done' && battleScoreboard.length > 0}}">
        <!-- 尚未生成对战：选队模式 -->
        <block wx:if="{{!battleRoundHasMatches}}">
          <view class="bqb-btn bqb-auto" bindtap="doBattleAutoMatch">
            <text>🤖 自动匹配 ({{battleSelectedIds.length > 0 ? battleSelectedIds.length : battleScoreboard.length}}队)</text>
          </view>
          <view class="bqb-btn bqb-manual" bindtap="addManualPair">
            <text>+ 手动添加对战组</text>
          </view>
        </block>
        <!-- 已有对战：可开战/清除 -->
        <block wx:if="{{battleRoundHasMatches && battleRoundStatus === 'pairing'}}">
          <view class="bqb-btn bqb-start" bindtap="doStartRound" loading="{{battleStarting}}">
            <text>🔥 开始对战</text>
          </view>
          <view class="bqb-btn bqb-del" bindtap="doDeleteRoundMatches" loading="{{battleDeleting}}">
            <text>🗑 清除本轮</text>
          </view>
        </block>
      </view>

      <!-- ========== 三、轮次切换栏 ========== -->
      <view class="bb-round-bar" wx:if="{{battleRounds.length > 0}}">
        <scroll-view class="round-tabs" scroll-x="true" enable-flex>
          <view
            class="round-tab {{battleRound === item.roundNum ? 'rt-active' : ''}} {{item.allDone ? 'rt-done' : ''}}"
            wx:for="{{battleRounds}}"
            wx:key="roundNum"
            bindtap="switchRound"
            data-round="{{item.roundNum}}"
          >
            <text class="rt-label">第{{item.roundNum}}轮</text>
            <text class="rt-progress">{{item.completedCount}}/{{item.matchCount}}</text>
            <text class="rt-check" wx:if="{{item.allDone}}">✓︎</text>
          </view>
        </scroll-view>
      </view>

      <!-- ========== 四、本轮对战信息头 ========== -->
      <view class="bb-round-header" wx:if="{{battleRound > 0}}">
        <view class="bb-rh-left">
          <text class="bb-rh-title">⚔️ 第{{battleRound}}轮对战</text>
          <text class="bb-rh-judge-hint" wx:if="{{battleRoundStatus === 'fighting' && actions.manage_matches.allowed && !isArchived}}">👆 点击卡片判定胜负</text>
        </view>
      </view>

      <!-- ========== 五、对战配对展示区（local配对 + DB对战） ========== -->

      <!-- 5a. 对战编排（手动编辑 + 自动匹配结果） -->
      <view class="bb-pair-section" wx:if="{{!battleRoundHasMatches}}">
        <view class="bb-ps-hd">
          <view class="bb-ps-hd-left">
            <text class="bb-ps-title">对战编排</text>
            <text class="bb-ps-count" wx:if="{{battlePairs.length > 0}}">{{battlePairs.length}}组</text>
          </view>
          <text class="bb-ps-hint" wx:if="{{battlePairs.length > 0}}">💡 点击更换队伍</text>
        </view>
        <view class="bb-pair-list">
          <view class="bb-pair-card" wx:for="{{battlePairs}}" wx:key="index">
            <view class="bbpc-vs-row">
              <text class="bbpc-swap-edge" wx:if="{{actions.manage_matches.allowed && !isArchived}}">⇄</text>
              <view class="bbpc-team {{item.teamA ? '' : 'bbpc-empty'}}" bindtap="{{actions.manage_matches.allowed && !isArchived ? 'pickTeamForPair' : ''}}" data-index="{{index}}" data-side="A">
                <block wx:if="{{item.teamA}}">
                  <text class="bbpct-name">{{item.teamA.teamName || '未知'}}</text>
                  <text class="bbpct-score">🏅 {{item.teamA.wins || 0}}胜</text>
                  <text class="bbpct-captain">👑 {{item.teamA.captainName || ''}}</text>
                </block>
                <block wx:else>
                  <text class="bbpct-empty">+</text>
                </block>
              </view>
              <view class="bbpc-vs">
                <text class="bbpc-vs-text">VS</text>
              </view>
              <view class="bbpc-team {{item.teamB ? '' : 'bbpc-empty'}}" bindtap="{{actions.manage_matches.allowed && !isArchived ? 'pickTeamForPair' : ''}}" data-index="{{index}}" data-side="B">
                <block wx:if="{{item.teamB}}">
                  <text class="bbpct-name">{{item.teamB.teamName || '未知'}}</text>
                  <text class="bbpct-score">🏅 {{item.teamB.wins || 0}}胜</text>
                  <text class="bbpct-captain">👑 {{item.teamB.captainName || ''}}</text>
                </block>
                <block wx:else>
                  <text class="bbpct-empty">+</text>
                </block>
              </view>
              <text class="bbpc-swap-edge" wx:if="{{actions.manage_matches.allowed && !isArchived}}">⇄</text>
            </view>
            <view class="bbpc-remove" bindtap="cancelBattlePair" data-index="{{index}}" wx:if="{{actions.manage_matches.allowed && !isArchived}}">
              <text>移除</text>
            </view>
          </view>
        </view>
        <!-- 生成对战按钮 -->
        <view class="bb-gen-wrap" wx:if="{{battlePairs.length > 0 && actions.manage_matches.allowed && !isArchived}}">
          <button class="bb-gen-btn" bindtap="doGenerateMatches" loading="{{battlePairing}}">
            确认生成第{{battleRoundNum}}轮对战（{{battlePairs.length}}组）
          </button>
        </view>
      </view>

      <!-- 5b. DB对战列表（已生成记录） -->
      <view class="bb-match-section" wx:if="{{battleMatches.length > 0}}">
        <view class="bb-match-list">
          <view
            class="bb-match-card {{item.match_status === 2 ? 'bbmc-done' : ''}} {{item.match_status === 1 && actions.manage_matches.allowed && !isArchived ? 'bbmc-clickable' : ''}}"
            wx:for="{{battleMatches}}"
            wx:key="match_id"
            data-match-id="{{item.match_id}}"
          >
            <!-- ===== 状态标签 ===== -->
            <view class="bbmc-status-tag">
              <view class="bbmc-st-tag {{item.match_status === 2 ? 'st-done' : item.match_status === 1 ? 'st-fight' : 'st-wait'}}">
                {{item.match_status === 2 ? '已结束' : item.match_status === 1 ? '待裁决' : '待开战'}}
              </view>
            </view>

            <!-- ===== 对战线 ===== -->
            <view class="bbmc-row">

            <!-- ===== A队 卡片 ===== -->
            <view class="bbmc-team bbmc-team-a {{item.winner_id === item.team_a_id ? 'bbmc-team-win' : ''}} {{item.winner_id && item.winner_id !== item.team_a_id ? 'bbmc-team-lose' : ''}}">
              <view class="bbmc-tap-area" wx:if="{{item.match_status === 0 && actions.manage_matches.allowed && !isArchived}}" catchtap="openSwapModal" data-match-id="{{item.match_id}}" data-side="A">
                <text class="bbmc-swap-hint">⇄ 换队</text>
              </view>
              <text class="bbmc-team-winicon" wx:if="{{item.winner_id === item.team_a_id}}">🏆</text>
              <text class="bbmc-team-name">{{item.team_a_name || '未知队伍'}}</text>
              <text class="bbmc-team-captain" wx:if="{{item.team_a_captain}}">{{item.team_a_captain}}</text>
              <view class="bbmc-team-stats">
                <text class="bbmc-stat-item">{{item.team_a_score || 0}} <text class="bbmc-stat-label">胜</text></text>
                <text class="bbmc-stat-item" wx:if="{{item.team_a_avg_mmr || item.team_a_mmr}}">{{item.team_a_avg_mmr || 0}} <text class="bbmc-stat-label">均分</text></text>
              </view>
            </view>

            <!-- ===== VS 中心 ===== -->
            <view class="bbmc-vs-block">
              <view class="bbmc-vs-ring">
                <text class="bbmc-vs-text">VS</text>
              </view>
            </view>

            <!-- ===== B队 卡片 ===== -->
            <view class="bbmc-team bbmc-team-b {{item.winner_id === item.team_b_id ? 'bbmc-team-win' : ''}} {{item.winner_id && item.winner_id !== item.team_b_id ? 'bbmc-team-lose' : ''}}">
              <view class="bbmc-tap-area" wx:if="{{item.match_status === 0 && actions.manage_matches.allowed && !isArchived}}" catchtap="openSwapModal" data-match-id="{{item.match_id}}" data-side="B">
                <text class="bbmc-swap-hint">⇄ 换队</text>
              </view>
              <text class="bbmc-team-winicon" wx:if="{{item.winner_id === item.team_b_id}}">🏆</text>
              <text class="bbmc-team-name">{{item.team_b_name || '未知队伍'}}</text>
              <text class="bbmc-team-captain" wx:if="{{item.team_b_captain}}">{{item.team_b_captain}}</text>
              <view class="bbmc-team-stats">
                <text class="bbmc-stat-item">{{item.team_b_score || 0}} <text class="bbmc-stat-label">胜</text></text>
                <text class="bbmc-stat-item" wx:if="{{item.team_b_avg_mmr || item.team_b_mmr}}">{{item.team_b_avg_mmr || 0}} <text class="bbmc-stat-label">均分</text></text>
              </view>
            </view>

            </view><!-- /bbmc-row -->

            <!-- ===== 底部操作栏 ===== -->
            <view class="bbmc-actions">
              <!-- 待裁决：裁决按钮（非归档） -->
              <view
                class="bbmc-act-btn bbmc-act-judge"
                wx:if="{{item.match_status === 1 && actions.manage_matches.allowed && !isArchived}}"
                catchtap="openJudgeModal"
                data-match-id="{{item.match_id}}"
              >
                <text>⚖️ 裁决胜负</text>
              </view>
              <!-- 已结束：对战截图 -->
              <view class="bbmc-upload-row" wx:if="{{item.match_status === 2}}">
                <!-- 非归档：撤回判定按钮（5分钟内） -->
                <view
                  class="bbmc-act-btn bbmc-act-revoke"
                  wx:if="{{!isArchived && actions.manage_matches.allowed}}"
                  catchtap="revokeJudgement"
                  data-match-id="{{item.match_id}}"
                >
                  <text>↩️ 撤回</text>
                </view>
                <!-- 归档模式：仅展示图片 -->
                <block wx:if="{{isArchived}}">
                  <image wx:if="{{item.battle_image}}" class="bbmc-upload-img" src="{{item.battle_image}}" mode="aspectFill" catchtap="previewMatchImage" data-url="{{item.battle_image}}"></image>
                </block>
                <!-- 非归档：可上传/替换 -->
                <block wx:else>
                  <block wx:if="{{!item.battle_image}}">
                    <view class="bbmc-upload-btn" catchtap="uploadMatchImage" data-match-id="{{item.match_id}}">
                      <text>📷 上传截图</text>
                    </view>
                  </block>
                  <block wx:if="{{item.battle_image}}">
                    <image class="bbmc-upload-img" src="{{item.battle_image}}" mode="aspectFill" catchtap="previewMatchImage" data-url="{{item.battle_image}}"></image>
                    <view class="bbmc-replace-btn" catchtap="uploadMatchImage" data-match-id="{{item.match_id}}">
                      <text>🔄 换图</text>
                    </view>
                  </block>
                </block>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 无对战数据 -->
      <view class="empty-state mini" wx:if="{{battleRound > 0 && battleMatches.length === 0 && battlePairs.length === 0 && battleRoundStatus !== 'select'}}">
        <text class="empty-text">本轮暂无对战</text>
      </view>

      <!-- 首次编排提示 -->
      <view class="empty-state" wx:if="{{battleRound === 0 && battleScoreboard.length > 0}}">
        <text class="empty-icon">⚔️</text>
        <text class="empty-text">尚未开始对战</text>
        <text class="empty-sub">点「自动匹配」或「手动添加」生成对战编排</text>
      </view>



      <!-- ========== 七、本轮完成 → 下一轮/结束比赛 ========== -->
      <!-- 最新完成轮 → 下一轮 + 结束比赛同一排 -->
      <view class="bb-action-wrap" wx:if="{{battleRoundStatus === 'done' && battleIsLatestRound && actions.manage_matches.allowed && !isArchived}}">
        <text class="bb-action-done">✅ 第{{battleRound}}轮全部完成</text>
        <view class="bb-action-row">
          <button class="bb-action-btn bb-next-btn" wx:if="{{!battleAllDone}}" bindtap="showBattleAction" data-action="next-round">
            下一轮 →
          </button>
          <button class="bb-action-btn bb-end-btn" bindtap="showBattleAction" data-action="end-battle">
            🏁 结束比赛
          </button>
        </view>
        <text class="bb-action-hint" wx:if="{{battleAllDone}}">所有轮次已完成，点击「结束比赛」进入名次归档</text>
      </view>
      <!-- 非最新完成轮 → 结束比赛居中（仅下一轮未开战时） -->
      <view class="bb-action-wrap" wx:if="{{_isRoundDone && !battleIsLatestRound && !_nextRoundHasMatches && actions.manage_matches.allowed && !isArchived}}">
        <button class="bb-action-btn bb-end-btn" bindtap="showBattleAction" data-action="end-battle">
          🏁 结束比赛
        </button>
      </view>

      </block>
    </view>

    <!--  ================================================================
          Tab5: 名次归档
          ================================================================ -->
    <view class="tab-content" wx:if="{{activeTab === 'ranks'}}">
      <view class="rank-section">

        <!-- ===== 队伍展示（网格布局，始终在最上方） ===== -->
        <view class="sb-section" wx:if="{{rankTeamCards.length > 0}}">
          <view class="sb-header">
            <text class="sb-title">队伍展示</text>
            <text class="sb-count">{{rankTeamCards.length}} 队</text>
          </view>
          <text class="sb-hint" wx:if="{{ranksEditing}}">👆 点击队伍卡片自动按顺序填入名次（冠军→亚军→季军…）</text>
          <view class="sb-list sb-grid">
            <view
              class="sb-card {{!ranksEditing ? 'sb-readonly' : ''}} {{ranksEditing && _rankUsedTeamMap[item.teamId] ? 'sb-selected' : ''}}"
              wx:for="{{rankTeamCards}}"
              wx:key="teamId"
              bindtap="{{ranksEditing ? 'selectRankTeam' : ''}}"
              data-team-id="{{item.teamId}}"
            >
              <view class="sbc-info">
                <text class="sbc-name">{{item.teamName || '未命名'}}</text>
                <text class="sbc-captain">👑 {{item.captainName || '未知'}}</text>
              </view>
              <view class="sbc-right">
                <text class="sbc-wins">🏅 {{item.wins || 0}}胜</text>
                <text class="sbc-losses" wx:if="{{item.losses > 0}}">{{item.losses}}负</text>
                <text class="sbc-mmr">📊 均{{item.avgMmr || 0}}分</text>
              </view>
              <view class="sbc-check" wx:if="{{ranksEditing && _rankUsedTeamMap[item.teamId]}}">
                <text>✓︎</text>
              </view>
            </view>
          </view>
        </view>

        <view class="rank-section-header">
          <text class="rank-section-title">🏆 最终排名</text>
          <button class="rank-edit-btn" wx:if="{{actions.manage_ranks.allowed && !ranksEditing && !isArchived}}" bindtap="startEditRanks" size="mini">编辑名次</button>
          <button class="rank-cancel-btn" wx:if="{{isAdmin && ranksEditing}}" bindtap="cancelEditRanks" size="mini">取消编辑</button>
        </view>

        <!-- ===== 编辑模式 ===== -->
        <block wx:if="{{actions.manage_ranks.allowed && ranksEditing}}">

          <!-- 排名区 -->
          <view class="rank-slots-area">
            <text class="rsa-title">📋 排名设置</text>
            <view class="rank-slot-row" wx:for="{{rankEditSlots}}" wx:key="rankNum">
              <view class="rsr-left">
                <view
                  class="rsr-team-box {{item.teamId ? 'rsr-team-filled' : 'rsr-team-empty'}}"
                  bindtap="assignTeamToRank"
                  data-index="{{index}}"
                >
                  <block wx:if="{{item.teamId}}">
                    <text class="rsr-team-name">{{item.teamName || '未知队伍'}}</text>
                    <view class="rsr-team-captain">
                      <text class="rsr-team-captain-tag">👑 {{item.captainName || ''}}</text>
                      <text class="rsr-team-avg">均{{item.avgMmr || 0}}分</text>
                    </view>
                    <view class="rsr-members" wx:if="{{item.members.length > 0}}">
                      <text class="rsr-member" wx:for="{{item.members}}" wx:key="id" wx:for-item="m">{{m.isCaptain ? '👑' : '👤'}}{{m.nickName || '未知'}}</text>
                    </view>
                    <view class="rsr-clear-btn" catchtap="clearRankSlot" data-index="{{index}}">
                      <text>✕︎ 清除</text>
                    </view>
                  </block>
                  <block wx:else>
                    <text class="rsr-placeholder">点击此处填入选中的队伍</text>
                  </block>
                </view>
              </view>
              <view class="rsr-right">
                <view class="rsr-rank-badge {{index === 0 ? 'rsr-gold' : index === 1 ? 'rsr-silver' : index === 2 ? 'rsr-bronze' : ''}}">
                  <text wx:if="{{index === 0}}">🥇</text>
                  <text wx:elif="{{index === 1}}">🥈</text>
                  <text wx:elif="{{index === 2}}">🥉</text>
                  <text wx:else class="rsr-rank-num">{{index + 1}}</text>
                </view>
                <text class="rsr-rank-label">{{index < 3 ? ['冠军', '亚军', '季军'][index] : '第' + (index + 1) + '名'}}</text>
                <text class="rsr-rank-remove" wx:if="{{rankEditSlots.length > 1}}" bindtap="removeRankSlot" data-index="{{index}}">✕︎ 移除此名次</text>
              </view>
            </view>

            <view class="rank-add-more" bindtap="addMoreRankSlots">
              <text class="ram-icon">+</text>
              <text class="ram-text">添加更多名次（第{{rankEditSlots.length + 1}}名）</text>
            </view>
          </view>

          <view class="rank-save-row">
            <button class="rank-save-btn" bindtap="saveRanks" loading="{{ranksSaving}}">💾 保存名次</button>
            <text class="rank-hint">保存后所有用户可见最终排名</text>
          </view>
        </block>

        <!-- ===== 查看模式 ===== -->
        <block wx:if="{{!actions.manage_ranks.allowed || !ranksEditing}}">

          <scroll-view class="rank-scroll-view" scroll-y="true" wx:if="{{ranks.length > 0}}" enhanced show-scrollbar="{{false}}">
            <view class="rank-podium">
              <view class="rank-item {{item.rank_num === 1 ? 'rank-gold' : item.rank_num === 2 ? 'rank-silver' : item.rank_num === 3 ? 'rank-bronze' : ''}}" wx:for="{{ranks}}" wx:key="rank_id">
                <view class="rank-badge">
                  <text class="rank-badge-num" wx:if="{{item.rank_num > 3}}">{{item.rank_num}}</text>
                  <text class="rank-badge-medal" wx:if="{{item.rank_num === 1}}">🥇</text>
                  <text class="rank-badge-medal" wx:if="{{item.rank_num === 2}}">🥈</text>
                  <text class="rank-badge-medal" wx:if="{{item.rank_num === 3}}">🥉</text>
                </view>
                <view class="rank-info">
                  <view class="rank-team-name-row">
                    <text class="rank-team-name">{{item.team_name || '未知队伍'}}</text>
                    <text class="rank-record-text">🏆 {{item.wins || 0}} 胜 · {{item.losses || 0}} 负</text>
                  </view>
                  <view class="rank-team-captain-row" wx:if="{{item.captain_name}}">
                    <text class="rank-team-captain-name">👑 {{item.captain_name}}</text>
                    <text class="rank-team-avg">均{{item.avg_mmr || 0}}分</text>
                  </view>
                  <view class="rank-members-row" wx:if="{{item.members && item.members.length > 0}}">
                    <text class="rank-member-tag" wx:for="{{item.members}}" wx:key="id" wx:for-item="m">{{m.isCaptain ? '👑' : '👤'}}{{m.nickName || ''}}</text>
                  </view>
                </view>
              </view>
            </view>
          </scroll-view>
          <view class="rank-empty" wx:if="{{ranks.length === 0 && !ranksLoading}}">
            <text class="rank-empty-icon">🏆</text>
            <text class="rank-empty-text">{{readonly ? '本次赛事未设置名次' : (isArchived ? '未记录名次' : (event.event_status < 5 ? '比赛结束后可设定名次' : '尚未设定名次'))}}</text>
          </view>
          <view class="rank-empty" wx:if="{{ranksLoading}}">
            <text class="rank-empty-icon">⏳</text>
            <text class="rank-empty-text">加载中...</text>
          </view>

          <view class="archive-btn-area" wx:if="{{actions.archive_event.allowed}}">
            <button class="archive-btn" bindtap="showArchiveBtn">🏁 归档比赛</button>
            <text class="archive-btn-hint">归档后所有数据将固化为只读，不可再修改</text>
          </view>
          <view class="archive-done-tip" wx:if="{{isArchived}}">
            <text class="ad-text">📋 本届赛事数据已归档 · {{_archiveTimeText}}</text>
          </view>
        </block>
      </view>
    </view>

  </block>

  <!-- 赛事不存在 -->
  <view class="empty-state" wx:if="{{loaded && !event}}">
    <text class="empty-icon">🏆</text>
    <text class="empty-text">赛事不存在或已删除</text>
  </view>

  <!-- ====== 弹窗层 ====== -->

  <!-- 取消报名确认 -->
  <view class="modal-mask" wx:if="{{showCancelConfirm}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">取消报名</text>
      <text class="modal-content">确定取消当前赛事的报名吗？<br/>取消后可重新报名。</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideCancelSignup"><text>再想想</text></view>
        <view class="modal-btn btn-danger" bindtap="doCancelSignup"><text>确认取消</text></view>
      </view>
    </view>
  </view>

  <!-- 状态变更确认（截止报名等） -->
  <view class="modal-mask" wx:if="{{showStatusConfirm}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">{{_confirmTitle}}</text>
      <text class="modal-content">{{_confirmMsg}}</text>
      <view class="modal-btns modal-btns-bottom">
        <view class="modal-btn btn-secondary" bindtap="hideStatusConfirm"><text>取消</text></view>
        <view class="modal-btn btn-primary-confirm" bindtap="doChangeStatus"><text>确认截止报名</text></view>
      </view>
    </view>
  </view>

  <!-- 剔除报名确认 -->
  <view class="modal-mask" wx:if="{{removeTarget}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">剔除报名</text>
      <text class="modal-content">确定将「{{removeTarget.wx_nickname}}」从报名列表中移除？</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideRemoveSignup"><text>取消</text></view>
        <view class="modal-btn btn-danger" bindtap="doRemoveSignup"><text>确认剔除</text></view>
      </view>
    </view>
  </view>

  <!-- 胜负判定弹窗 -->
  <view class="modal-mask" wx:if="{{showJudgeModal}}" catchtouchmove="preventMove">
    <view class="modal-box judge-modal">
      <text class="modal-title">判定胜负</text>
      <block wx:if="{{judgeStep === 0}}">
        <text class="modal-subtitle">第{{battleRound}}轮 · {{judgeMatch.team_a_name}} VS {{judgeMatch.team_b_name}}</text>
        <text class="judge-prompt">请选择胜方队伍：</text>
        <view class="judge-options">
          <view class="judge-option" bindtap="selectWinner" data-team-id="{{judgeMatch.team_a_id}}">
            <text class="jo-name">{{judgeMatch.team_a_name || '队伍A'}}</text>
            <text class="jo-captain" wx:if="{{judgeMatch.team_a_captain_name}}">👑 {{judgeMatch.team_a_captain_name}}</text>
          </view>
          <view class="judge-option" bindtap="selectWinner" data-team-id="{{judgeMatch.team_b_id}}">
            <text class="jo-name">{{judgeMatch.team_b_name || '队伍B'}}</text>
            <text class="jo-captain" wx:if="{{judgeMatch.team_b_captain_name}}">👑 {{judgeMatch.team_b_captain_name}}</text>
          </view>
        </view>
        <view class="modal-btns"><view class="modal-btn btn-secondary" bindtap="closeJudgeModal"><text>取消</text></view></view>
      </block>
      <block wx:if="{{judgeStep === 1}}">
        <text class="modal-content">确认 {{judgeWinnerId === judgeMatch.team_a_id ? (judgeMatch.team_a_name || '队伍A') : (judgeMatch.team_b_name || '队伍B')}} 为胜方？\n\n⚠ 判定后不可修改，请仔细确认。</text>
        <view class="modal-btns">
          <view class="modal-btn btn-secondary" bindtap="backToSelect"><text>重新选择</text></view>
          <view class="modal-btn btn-danger" bindtap="confirmJudge" loading="{{loading}}"><text>确认判定</text></view>
        </view>
      </block>
    </view>
  </view>

  <!-- 下一轮/结束比赛确认 -->
  <view class="modal-mask" wx:if="{{showBattleActionModal}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">{{_battleActionTitle}}</text>
      <text class="modal-content">{{_battleActionContent}}</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideBattleActionModal"><text>取消</text></view>
        <view class="modal-btn {{battleActionType === 'end-battle' ? 'btn-danger' : 'btn-primary-confirm'}}" bindtap="doBattleAction" loading="{{battleActionSubmitting}}"><text>{{battleActionType === 'end-battle' ? '确认结束' : '确认进入'}}</text></view>
      </view>
    </view>
  </view>

  <!-- 归档确认 -->
  <view class="modal-mask" wx:if="{{showArchiveConfirm}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">确认归档</text>
      <text class="modal-content">⚠ 确认将本届赛事归档？\n\n归档后所有数据将固化为只读状态：\n· 报名数据不可修改\n· 队伍信息不可变更\n· 对战结果不可改动\n· 名次记录不可调整\n\n确认后无法撤销，请仔细确认。</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideArchiveBtn"><text>取消</text></view>
        <view class="modal-btn btn-danger" bindtap="doArchive" loading="{{archiveSubmitting}}"><text>确认归档</text></view>
      </view>
    </view>
  </view>

  <!-- 修改报名人数上限弹窗 -->
  <view class="modal-mask" wx:if="{{showSignupLimitModal}}" catchtouchmove="preventMove">
    <view class="modal-box" catchtap="">
      <text class="modal-title">修改报名人数上限</text>

      <!-- 当前报名人数 -->
      <text class="modal-content slim-count-hint">当前已报名 <text class="slim-count-num">{{signupCount}}</text> 人</text>

      <!-- 人数上限选择 -->
      <text class="modal-label">设置人数上限</text>
      <!-- 第一行：无限制 10人 20人 -->
      <view class="limit-pick-row">
        <view class="limit-pick-opt {{editSignupLimitVal === 'unlimited' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="unlimited">
          <text>无限制</text>
        </view>
        <view class="limit-pick-opt {{editSignupLimitVal === '10' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="10">
          <text>10人</text>
        </view>
        <view class="limit-pick-opt {{editSignupLimitVal === '20' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="20">
          <text>20人</text>
        </view>
      </view>
      <!-- 第二行：30人 40人 自定义 -->
      <view class="limit-pick-row">
        <view class="limit-pick-opt {{editSignupLimitVal === '30' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="30">
          <text>30人</text>
        </view>
        <view class="limit-pick-opt {{editSignupLimitVal === '40' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="40">
          <text>40人</text>
        </view>
        <view class="limit-pick-opt {{editSignupLimitVal === 'custom' ? 'limit-pick-on' : ''}}" bindtap="selectEditSignupLimit" data-val="custom">
          <text>自定义</text>
        </view>
      </view>
      <!-- 自定义输入（选中自定义时下方出现） -->
      <view class="limit-pick-custom-row" wx:if="{{editSignupLimitVal === 'custom'}}">
        <input class="limit-pick-input" type="number" placeholder="输入人数" value="{{editCustomSignupLimit}}" bindinput="onEditCustomLimitInput" />
        <text class="limit-pick-unit">人</text>
      </view>

      <!-- 按钮行 -->
      <view class="modal-btns modal-btns-bottom">
        <view class="modal-btn btn-secondary" bindtap="hideEditSignupLimit"><text>取消</text></view>
        <view class="modal-btn btn-primary-confirm" bindtap="doUpdateSignupLimit"><text>确认修改</text></view>
      </view>
    </view>
  </view>

  <!-- 自动分队：输入组数弹窗 -->
  <view class="modal-mask" wx:if="{{showTeamCountModal}}" catchtouchmove="preventMove">
    <view class="modal-box tcm-box">
      <text class="modal-title">自动分队</text>
      <text class="modal-content">当前赛事共 {{signupTotal || signupCount}} 名报名选手，请输入要分成的组数：</text>
      <view class="tcm-input-row">
        <input
          class="tcm-input"
          type="number"
          value="{{autoTeamCount}}"
          placeholder="请输入组数"
          bindinput="onTeamCountInput"
          focus="{{showTeamCountModal}}"
          maxlength="4"
        />
        <text class="tcm-unit">组</text>
      </view>
      <text class="tcm-hint">建议每组5人，当前建议 {{autoTeamSuggestion}} 组</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="closeTeamCountModal"><text>取消</text></view>
        <view class="modal-btn btn-primary-confirm" bindtap="confirmAutoAllocate"><text>开始分队</text></view>
      </view>
    </view>
  </view>

  <!-- 换队选择弹窗（分对战区/自由区） -->
  <view class="modal-mask" wx:if="{{showSwapModal}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">更换队伍</text>
      <text class="modal-subtitle">{{swapCurTeamName}} · {{swapSide === 'A' ? 'A队' : 'B队'}}位置</text>

      <!-- 对战区 -->
      <view class="swap-zone" wx:if="{{swapBattleTeams.length > 0}}">
        <text class="swap-zone-title">⚔️ 对战区（点击互换位置）</text>
        <scroll-view class="swap-team-list" scroll-y="true" style="max-height:240rpx;">
          <view
            class="swap-team-item sti-inmatch"
            wx:for="{{swapBattleTeams}}"
            wx:key="teamId"
            bindtap="doSwapTeam"
            data-team-id="{{item.teamId}}"
          >
            <view class="sti-left">
              <text class="sti-name">{{item.teamName || '未命名'}}</text>
              <text class="sti-captain">👑 {{item.captainName || ''}}</text>
            </view>
            <view class="sti-right">
              <text class="sti-status sti-busy">已出战</text>
              <text class="sti-score">🏅 {{item.wins || 0}}胜{{item.losses || 0}}负</text>
              <text class="sti-mmr">📊 {{item.avgMmr || 0}}分</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 自由区 -->
      <view class="swap-zone" wx:if="{{swapFreeTeams.length > 0}}">
        <text class="swap-zone-title">📋 自由区（点击替换至对战区）</text>
        <scroll-view class="swap-team-list" scroll-y="true" style="max-height:240rpx;">
          <view
            class="swap-team-item"
            wx:for="{{swapFreeTeams}}"
            wx:key="teamId"
            bindtap="doSwapTeam"
            data-team-id="{{item.teamId}}"
          >
            <view class="sti-left">
              <text class="sti-name">{{item.teamName || '未命名'}}</text>
              <text class="sti-captain">👑 {{item.captainName || ''}}</text>
            </view>
            <view class="sti-right">
              <text class="sti-status sti-free">未出战</text>
              <text class="sti-score">🏅 {{item.wins || 0}}胜{{item.losses || 0}}负</text>
              <text class="sti-mmr">📊 {{item.avgMmr || 0}}分</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="swap-team-hint" wx:if="{{swapBattleTeams.length === 0 && swapFreeTeams.length === 0}}">没有可选的队伍</view>
      <view class="modal-btns" style="margin-top:20rpx;">
        <view class="modal-btn btn-secondary" bindtap="closeSwapModal"><text>取消</text></view>
      </view>
    </view>
  </view>

  <!-- 手动配对-队伍选择弹窗 -->
  <view class="modal-mask" wx:if="{{showPairTeamPicker}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-subtitle">第{{pairPickerIndex + 1}}组对战 • {{pairPickerSide === 'A' ? '左侧' : '右侧'}}位置</text>
      <scroll-view class="swap-team-list" scroll-y="true" style="max-height:500rpx;">
        <view
          class="swap-team-item"
          wx:for="{{pairPickerAllTeams}}"
          wx:key="teamId"
          bindtap="selectPairTeam"
          data-team-id="{{item.teamId}}"
        >
          <view class="sti-left">
            <text class="sti-name">{{item.teamName || '未命名'}}</text>
            <text class="sti-captain">👑 {{item.captainName || ''}}</text>
          </view>
          <view class="sti-right">
            <text class="sti-score">🏅 {{item.wins || 0}}胜{{item.losses || 0}}负</text>
            <text class="sti-mmr">📊 {{item.avgMmr || 0}}分</text>
            <text class="sti-status sti-busy" wx:if="{{item._status === 'battle'}}">已参战</text>
            <text class="sti-status sti-free" wx:else>未参战</text>
          </view>
        </view>
      </scroll-view>
      <view class="swap-team-hint" wx:if="{{pairPickerAllTeams.length === 0}}">没有可选的队伍</view>
      <view class="modal-btns" style="margin-top:20rpx;">
        <view class="modal-btn btn-secondary" bindtap="closePairTeamPicker"><text>取消</text></view>
      </view>
    </view>
  </view>

  <!-- 取消赛事确认 -->
  <view class="modal-mask" wx:if="{{showCancelEventModal}}" catchtouchmove="preventMove">
    <view class="modal-box">
      <text class="modal-title">取消赛事</text>
      <text class="modal-content">⚠ 确定要取消「{{event.event_name}}」吗？\n\n取消后赛事及所有关联数据（报名、队伍、对战）将被永久删除，此操作不可撤销。</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="hideCancelEvent"><text>再想想</text></view>
        <view class="modal-btn btn-danger" bindtap="doCancelEvent" loading="{{cancelEventSubmitting}}"><text>确认取消</text></view>
      </view>
    </view>
  </view>

  <!-- 对战确认弹窗 -->
  <view class="modal-mask" wx:if="{{showBattleConfirmModal}}" catchtouchmove="preventMove" bindtap="onBattleConfirmCancel">
    <view class="modal-box" catchtap="preventMove">
      <text class="modal-title">{{_battleConfirmTitle}}</text>
      <view class="bcm-list">
        <view class="bcm-row" wx:for="{{_battleConfirmLines}}" wx:key="index">
          <text class="bcm-num">{{index + 1}}</text>
          <text class="bcm-text">{{item}}</text>
        </view>
      </view>
      <text class="bcm-hint" wx:if="{{_battleConfirmNote}}">{{_battleConfirmNote}}</text>
      <view class="modal-btns">
        <view class="modal-btn btn-secondary" bindtap="onBattleConfirmCancel"><text>取消</text></view>
        <view class="modal-btn btn-primary" bindtap="onBattleConfirmOk"><text>确定</text></view>
      </view>
    </view>
  </view>

  <modal id="modal"></modal>
</view>