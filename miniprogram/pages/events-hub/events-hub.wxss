/* pages/events-hub/events-hub.wxss */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-top: 20rpx;
}

/* ===== 页面头部 ===== */
.hub-header {
  padding: 32rpx 36rpx 8rpx;
}
.hub-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #e6edf3;
  margin-bottom: 8rpx;
}
.hub-sub {
  display: block;
  font-size: 24rpx;
  color: #484f58;
}

/* ===== 游戏列表 ===== */
.hub-list {
  padding: 16rpx 36rpx;
}

/* 游戏区块头部 */
.hub-game-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 8rpx 12rpx;
  margin-top: 8rpx;
}
.hgh-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.hgh-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6edf3;
}

/* 快速跳转栏（竖排列表） */
.hub-jump-list {
  background-color: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.hjl-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.03);
  transition: all 0.12s ease;
}
.hjl-row:last-child {
  border-bottom: none;
}
.hjl-row:active {
  background-color: rgba(79,140,255,0.06);
}
.hjl-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.hjl-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.hjl-label {
  font-size: 28rpx;
  color: #c9d1d9;
  font-weight: 500;
}
.hjl-arrow {
  font-size: 32rpx;
  color: #30363d;
  flex-shrink: 0;
}

/* ===== 空状态 ===== */
.hub-empty {
  padding: 120rpx 36rpx;
  text-align: center;
}
.hub-empty-text {
  display: block;
  font-size: 28rpx;
  color: #484f58;
  margin-bottom: 8rpx;
}
.hub-empty-hint {
  display: block;
  font-size: 22rpx;
  color: #30363d;
}

/* ===== 底部占位 ===== */
.hub-footer-space {
  height: 40rpx;
}
