/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 140rpx;
}

/* 自定义导航栏 */
.nav-custom {
  background-color: #0d1117;
}

.nav-inner {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 8rpx 24rpx 4rpx;
  height: 100rpx;
  position: relative;
}

.nav-left-space {
  flex-shrink: 0;
  width: 180rpx;
}

.nav-gold-title {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f5d799, #e8b84a, #d4a03a);
  -webkit-background-clip: text;
  color: transparent;
  white-space: nowrap;
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  transform: translateX(-50%);
}

/* 标题下方的金色横线 */
.nav-title-line {
  width: 280rpx;
  height: 4rpx;
  margin: 4rpx auto 24rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent, #e8b84a, #f5d799, #e8b84a, transparent);
}

.nav-right-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  margin-right: 12rpx;
}

/* 首页 */

/* 全局工具栏 */
.global-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 0 36rpx 16rpx;
  gap: 2rpx;
}
.gtb-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.15s ease;
}
.gtb-btn:active { background-color: rgba(255, 255, 255, 0.1); transform: scale(0.95); }
.gtb-icon { width: 28rpx; height: 28rpx; display: block; flex-shrink: 0; }
.gtb-divider { width: 2rpx; height: 20rpx; background-color: rgba(255, 255, 255, 0.06); margin: 0 4rpx; border-radius: 1rpx; }

/* ===== 首页通用模块样式 ===== */
.home-module { margin-bottom: 28rpx; }

/* 模块标题栏 */
.hm-bar {
  display: flex; flex-direction: row; align-items: center;
  padding: 0 36rpx; margin-bottom: 12rpx;
}
.hm-tag {
  font-size: 22rpx; font-weight: 600; color: #3498db;
  background-color: rgba(52,152,219,0.12); border-radius: 8rpx;
  padding: 4rpx 16rpx;
}
.hm-bar-spacer { flex: 1; }
.hm-edit-btn {
  font-size: 22rpx; color: #8b949e; padding: 6rpx 16rpx;
  border-radius: 8rpx; border: 1rpx solid rgba(255,255,255,0.08);
  background-color: rgba(255,255,255,0.02);
}
.hm-edit-btn:active { background-color: rgba(255,255,255,0.06); color: #e6edf3; }

/* 分区标题 */
.home-section-title {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  font-size: 32rpx; font-weight: 700; color: #e6edf3;
  padding: 0 36rpx; margin-bottom: 16rpx;
}
.hsr-more { font-size: 24rpx; color: #3498db; font-weight: 400; }

/* ===== 模块1：图文介绍区 ===== */
.home-intro-area { padding: 0 36rpx; }
.intro-content { padding: 20rpx 0; }
.intro-text {
  display: block; font-size: 28rpx; color: #c9d1d9; line-height: 1.8;
  margin-bottom: 12rpx;
}
.intro-image {
  display: block; width: 100%; border-radius: 16rpx; margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.intro-empty {
  padding: 48rpx 0; text-align: center;
}
.intro-empty-text { display: block; font-size: 32rpx; font-weight: 700; color: #e6edf3; margin-bottom: 8rpx; }
.intro-empty-sub { display: block; font-size: 24rpx; color: #8b949e; }

/* ===== 模块2：滚动公告栏 ===== */
.marquee-box {
  margin: 0 36rpx; height: 64rpx; overflow: hidden;
  background-color: rgba(52,152,219,0.06); border-radius: 12rpx;
  border: 1rpx solid rgba(52,152,219,0.1);
  display: flex; align-items: center;
}
.marquee-track {
  display: inline-flex; align-items: center;
  white-space: nowrap;
  animation: marquee-scroll 15s linear infinite;
}
.marquee-spacer {
  width: 100vw; flex-shrink: 0; height: 1rpx;
}
.marquee-text {
  font-size: 24rpx; color: #c9d1d9;
  line-height: 64rpx; white-space: nowrap; flex-shrink: 0;
}
@keyframes marquee-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-100%); }
}
.marquee-empty { margin: 0 36rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.marquee-empty-text { font-size: 24rpx; color: #484f58; }

/* ===== 模块3：快捷链接卡片（横向滚动） ===== */
.sc-shelf {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-start;
  white-space: nowrap;
  padding-bottom: 8rpx;
}
.sc-card {
  display: inline-block;
  vertical-align: top;
  flex-shrink: 0;
  width: 240rpx;
  margin-left: 36rpx;
  background-color: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 16rpx;
  overflow: hidden;
}
.sc-card:last-child {
  margin-right: 36rpx;
}
/* 卡片头部 */
.scc-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 18rpx 14rpx;
  background: linear-gradient(135deg, rgba(79,140,255,0.1) 0%, rgba(79,140,255,0.02) 100%);
  border-bottom: 1rpx solid rgba(79,140,255,0.08);
}
.scc-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}
.scc-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #e6edf3;
}
/* 卡片跳转行 */
.scc-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 18rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.025);
  transition: background-color 0.12s ease;
}
.scc-row:last-child {
  border-bottom: none;
}
.scc-row:active {
  background-color: rgba(79,140,255,0.08);
}
.scc-row-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.scc-row-label {
  flex: 1;
  font-size: 24rpx;
  color: #8b949e;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.scc-row-arrow {
  font-size: 24rpx;
  color: #30363d;
  flex-shrink: 0;
  margin-left: 6rpx;
}

/* ===== 模块4：赛事动态 ===== */
.ed-item {
  display: flex; flex-direction: row; align-items: center;
  margin: 0 36rpx 12rpx; padding: 20rpx 24rpx;
  background-color: #161b22; border: 1rpx solid #21262d;
  border-radius: 14rpx; transition: all 0.15s ease;
}
.ed-item:active { background-color: rgba(79,140,255,0.06); border-color: rgba(79,140,255,0.15); }
.ed-left { flex: 1; overflow: hidden; }
.ed-name { display: block; font-size: 28rpx; color: #e6edf3; font-weight: 500; margin-bottom: 8rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ed-meta { display: flex; flex-direction: row; align-items: center; gap: 12rpx; }
.ed-status-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 6rpx; font-weight: 600; }
.ed-status-0 { background-color: rgba(119,141,169,0.15); color: #778da9; } /* 创建中 */
.ed-status-1 { background-color: rgba(39,174,96,0.15); color: #27ae60; }  /* 报名中 */
.ed-status-2 { background-color: rgba(243,156,18,0.15); color: #f39c12; } /* 报名截止 */
.ed-status-3 { background-color: rgba(155,89,182,0.15); color: #bb86fc; } /* 分组锁定 */
.ed-status-4 { background-color: rgba(231,76,60,0.15); color: #e74c3c; }  /* 对战中 */
.ed-time { font-size: 22rpx; color: #8b949e; }
.ed-count { font-size: 22rpx; color: #484f58; }
.ed-arrow { font-size: 32rpx; color: #21262d; flex-shrink: 0; margin-left: 12rpx; }
.ed-empty { padding: 48rpx 36rpx; text-align: center; }
.ed-empty-text { font-size: 26rpx; color: #484f58; font-style: italic; }

/* ===== 模块5：平台数据统计 ===== */
.stats-row {
  display: flex; flex-direction: row;
  margin: 0 36rpx; gap: 12rpx;
}
.stat-card {
  flex: 1; padding: 20rpx 8rpx;
  background-color: #161b22; border: 1rpx solid #21262d;
  border-radius: 14rpx; text-align: center;
}
.stat-num { display: block; font-size: 40rpx; font-weight: 800; color: #e6edf3; margin-bottom: 6rpx; }
.stat-label { display: block; font-size: 20rpx; color: #484f58; }

/* ===== 子分页栏 ===== */
.sub-tabs {
  display: flex;
  flex-direction: row;
  padding: 12rpx 36rpx 18rpx;
  gap: 16rpx;
}

.sub-tab {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid transparent;
  transition: all 0.25s ease;
}

.sub-tab.sub-active {
  background-color: #d4a03a;
  border-color: #e8b84a;
  box-shadow: 0 4rpx 16rpx rgba(212, 160, 58, 0.35);
}

.sub-tab-text {
  font-size: 26rpx;
  color: #8b949e;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.sub-tab.sub-active .sub-tab-text {
  color: #0d1117;
}


/* ===== 游戏标签（主导航） ===== */
.game-tabs {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 36rpx 12rpx;
  gap: 10rpx;
}

.game-tab {
  height: 52rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid transparent;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.game-tab.tab-active {
  background-color: #1f6feb;
  border-color: #1f6feb;
}

.tab-text {
  font-size: 24rpx;
  color: #8b949e;
  font-weight: 500;
}

.game-tab.tab-active .tab-text {
  color: #ffffff;
}

/* 右侧 + 号 */
.game-plus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.game-plus:active {
  background-color: rgba(255, 255, 255, 0.1);
  transform: scale(0.92);
}

.plus-icon {
  font-size: 28rpx;
  color: #8b949e;
  font-weight: 300;
  line-height: 1;
}

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 6rpx 36rpx 10rpx;
  position: relative;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 64rpx 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.search-clear {
  position: absolute;
  right: 44rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #484f58;
  line-height: 1;
  z-index: 5;
}
.search-clear:active { color: #e6edf3; }

/* ===== 筛选行 ===== */
.filter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 6rpx 36rpx;
  gap: 10rpx;
}

.ftag-fixed {
  flex-shrink: 0;
}

.filter-scroll {
  white-space: nowrap;
  flex: 1;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.filter-scroll::-webkit-scrollbar { display: none; }

.ftag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #8b949e;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-right: 10rpx;
  line-height: 1.4;
  transition: all 0.15s ease;
}
.ftag:active { opacity: 0.7; }

.ftag.ftag-on {
  background-color: rgba(31, 111, 235, 0.15);
  color: #58a6ff;
  border-color: rgba(31, 111, 235, 0.35);
}

/* 操作按钮行：左右分布 */
.action-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 36rpx;
}

/* 段位排序切换按钮 */
.tbtn-sort {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  color: #8b949e;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.15s ease;
}
.tbtn-sort:active { opacity: 0.7; }

.tbtn-sort.sort-desc {
  color: #58a6ff;
  background-color: rgba(31, 111, 235, 0.12);
  border-color: rgba(31, 111, 235, 0.3);
}

.tbtn-sort.sort-asc {
  color: #3bfb83;
  background-color: rgba(59, 251, 131, 0.08);
  border-color: rgba(59, 251, 131, 0.2);
}

.sort-arrow {
  margin-left: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
}

/* 左侧按钮组 */
.action-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

/* 重置按钮 */
.tbtn-reset {
  margin-left: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tbtn-reset:active { opacity: 0.7; }

/* 右侧功能图标区 */
.action-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.tbtn-icon {
  width: 52rpx;
  height: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background-color: rgba(255, 255, 255, 0.04);
  color: #8b949e;
  flex-shrink: 0;
  overflow: hidden;
}

.chart-btn.chart-active { background-color: rgba(88, 166, 255, 0.15); border-color: rgba(88, 166, 255, 0.35); }

/* 图片图标通用样式 */
.icon-img {
  width: 24rpx;
  height: 24rpx;
  display: block;
}

/* ===== 双列卡片网格 ===== */
.card-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 20rpx 28rpx;
  /* 渐进式入场动画 */
  animation: fadeInUp 0.35s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.grid-card {
  width: calc(50% - 12rpx);
  background-color: #161b22;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  transition: transform 0.15s ease;
}
.grid-card:active {
  transform: scale(0.97);
}
/* 第偶数个卡片（右侧）左边距 */
.grid-card:nth-child(2n) {
  margin-left: 12rpx;
}
/* 第奇数个卡片（左侧）右边距 */
.grid-card:nth-child(odd) {
  margin-right: 12rpx;
}

/* 卡片头像区 */
.card-avatar-wrap {
  position: relative;
  width: 100%;
  height: 300rpx;
  background-color: #21262d;
}

.card-avatar {
  width: 100%;
  height: 100%;
}

.card-name-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 16rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-name-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.card-rank-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 4rpx;
}

/* 段位图标（emoji） */
.rank-icon {
  font-size: 30rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* 段位图标（图片） */
.rank-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.card-rank-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #5bb8ff;
}

.card-rank-stars {
  font-size: 20rpx;
  color: #c9a046;
  margin-left: 6rpx;
}

/* ===== 段位分布饼图 ===== */
.chart-section {
  margin: 10rpx 36rpx 24rpx;
  background: linear-gradient(180deg, #1a1f2b 0%, #161b22 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  animation: fadeInDown 0.3s ease;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.chart-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx 4rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f6fc;
  letter-spacing: 1rpx;
}

.chart-close {
  font-size: 26rpx;
  color: #484f58;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
}
.chart-close:active {
  background-color: rgba(255, 255, 255, 0.1);
  color: #8b949e;
}

.chart-body {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx 28rpx;
}

.pie-canvas {
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 16rpx rgba(0, 0, 0, 0.4));
}

/* ===== 饼图右侧颜色+数量 ===== */
.chart-legend {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-left: 32rpx;
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 5rpx;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx currentColor;
}

.legend-label {
  font-size: 24rpx;
  color: #c9d1d9;
  min-width: 110rpx;
  font-weight: 500;
}

.legend-count {
  font-size: 26rpx;
  color: #8b949e;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  min-width: 44rpx;
  text-align: right;
}

/* ===== 批量删除工具栏 ===== */
.batch-toolbar {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 32rpx;
  margin: 0 32rpx 12rpx;
  background-color: rgba(218, 54, 51, 0.1);
  border: 1rpx solid rgba(218, 54, 51, 0.2);
  border-radius: 14rpx;
}

.batch-count {
  font-size: 26rpx;
  color: #f85149;
  font-weight: 600;
}

.batch-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.batch-btn {
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.batch-btn-cancel {
  background-color: rgba(255, 255, 255, 0.08);
  color: #c9d1d9;
}

.batch-btn-del {
  background-color: #da3633;
  color: #ffffff;
}

/* ===== 卡片选中态 ===== */
.grid-card.card-selected {
  border: 3rpx solid #f85149;
}

.card-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.grid-card.card-selected .card-check {
  border-color: #f85149;
  background-color: #da3633;
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #484f58;
}

.empty-sub {
  font-size: 24rpx;
  color: #484f58;
  margin-top: 8rpx;
}

/* ===== 加载骨架屏 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

/* 旋转加载动画 */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.08);
  border-top-color: #58a6ff;
  border-radius: 50%;
  margin-bottom: 20rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #484f58;
}

/* ===== 底部加载提示 ===== */
.load-more-tip {
  display: flex;
  justify-content: center;
  padding: 20rpx 40rpx 40rpx;
  font-size: 24rpx;
  color: #484f58;
}

/* ===== FAB 添加按钮 ===== */
.fab-btn {
  position: fixed;
  bottom: 48rpx;
  right: 36rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1f6feb;
  box-shadow: 0 8rpx 28rpx rgba(31, 111, 235, 0.45);
  z-index: 50;
  transition: all 0.15s ease;
}

.fab-btn:active {
  transform: scale(0.92);
  opacity: 0.85;
}

.fab-text {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  transform: translate(0rpx, -4rpx);
}

/* ===== 其他游戏 占位 ===== */
.csgo-placeholder {
  padding-top: 260rpx;
}

/* ===== 昵称编辑弹窗 ===== */
