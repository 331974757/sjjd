  margin-bottom: 12rpx;
}

.ph-sub {
  font-size: 26rpx;
  color: rgba(139, 148, 158, 0.7);
}

/* =====【第4轮新增】历史赛事列表 ===== */
.event-list-page {
  padding: 16rpx 24rpx 120rpx;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.event-card-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 22rpx;
  background: linear-gradient(135deg, #161b22, #1c2333);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  transition: background 0.15s;
}

.event-card-item:active {
  background: rgba(31,111,235,0.06);
  border-color: rgba(31,111,235,0.15);
}

.eci-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eci-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.eci-time {
  font-size: 24rpx;
  color: #8b949e;
}

.eci-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.eci-status {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 赛事状态颜色（与event-detail保持一致） */
.eci-s0 { background: rgba(139,148,158,0.12); color: #8b949e; }
.eci-s1 { background: rgba(63,185,80,0.12);  color: #3fb950; }
.eci-s2 { background: rgba(218,54,51,0.12);  color: #f85149; }
.eci-s3 { background: rgba(210,153,34,0.12);  color: #d29922; }
.eci-s4 { background: rgba(31,111,235,0.12);  color: #58a6ff; }
.eci-s5 { background: rgba(139,148,158,0.06); color: #6e7681; }

.eci-arrow {
  font-size: 36rpx;
  color: #484f58;
  font-weight: 300;
}

/* =====【第8轮新增】历史赛事搜索栏 ===== */
.history-search-bar {
  padding: 6rpx 0 20rpx;
}

.history-search-wrap {
  position: relative;
  height: 72rpx;
}

.history-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 64rpx 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

.history-search-clear {
  position: absolute;
