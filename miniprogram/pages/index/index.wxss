/* ===== 占位页（赛事章程 / 历史赛事） ===== */
.placeholder-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 320rpx;
}

.ph-icon {
  font-size: 120rpx;
  opacity: 0.35;
  margin-bottom: 28rpx;
}

.ph-main {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.6);
