  color: #484f58;
}

/* ===== 【赛事创建】赛事章程标题栏 + 新建按钮 ===== */
.rules-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 20rpx 0;
}

.rules-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  letter-spacing: 2rpx;
}

/* 新建赛事按钮（仅管理员可见） */
.rules-create-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.15), rgba(31, 111, 235, 0.1));
  border: 1rpx solid rgba(212, 160, 58, 0.3);
  transition: all 0.15s ease;
}

.rules-create-btn:active {
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.25), rgba(31, 111, 235, 0.18));
  transform: scale(0.95);
}

.rules-create-icon {
  font-size: 32rpx;
  font-weight: 400;
  color: #d4a03a;
  line-height: 1;
}

.rules-create-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #d4a03a;
}

/* ===== 【赛事创建】弹窗遮罩 ===== */
.event-create-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 【赛事创建】弹窗主体 ===== */
.event-create-modal {
  width: 620rpx;
  max-height: 85vh;
  background-color: #1e2530;
  border-radius: 24rpx;
  padding: 56rpx 40rpx 36rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

/* 关闭按钮 */
.ecm-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.04);
}

.ecm-close:active {
  background-color: rgba(255, 255, 255, 0.1);
}

.ecm-close-icon {
  font-size: 28rpx;
  color: #5a6678;
  line-height: 1;
}

/* 弹窗标题 */
.ecm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
}

/* 表单字段 */
.ecm-field {
  margin-bottom: 28rpx;
}

.ecm-label {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.ecm-required {
  color: #f85149;
}

.ecm-note {
  color: #8b949e;
  font-weight: 400;
  font-size: 22rpx;
}

/* 单行输入框 */
.ecm-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ecm-input::placeholder {
  color: #4a5568;
  font-size: 26rpx;
}

/* 日期选择器 */
.ecm-picker {
  width: 100%;
}

.ecm-picker-display {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #e6edf3;
  box-sizing: border-box;
}

.ecm-placeholder {
  color: #4a5568;
  font-size: 26rpx;
}

/* 多行文本框 */
.ecm-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 按钮行 */
.ecm-btn-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 20rpx;
  margin-top: 16rpx;
}

.ecm-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.15s;
}

.ecm-btn-cancel {
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: #8b949e;
  background-color: transparent;
}

.ecm-btn-cancel:active {
  background-color: rgba(255, 255, 255, 0.05);
}

.ecm-btn-confirm {
  background: linear-gradient(135deg, #1f6feb, #1a5dcc);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 235, 0.3);
}

.ecm-btn-confirm:active {
  background: linear-gradient(135deg, #1a5dcc, #154aa3);
  transform: scale(0.96);
}

.ecm-btn-loading {
  background: #30363d !important;
  color: #8b949e !important;
  box-shadow: none !important;
  pointer-events: none;
}

/* 报名人数上限选项 - 分行布局 */
.ecm-limit-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.ecm-limit-row2 {
  margin-bottom: 0;
}

.ecm-limit-opt {
  flex: 1;
  min-width: 120rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
  color: #8b949e;
  transition: all 0.15s;
}
.ecm-limit-opt:active {
  background-color: rgba(255, 255, 255, 0.08);
}

.ecm-limit-on {
  background-color: rgba(31, 111, 235, 0.15) !important;
  border-color: rgba(31, 111, 235, 0.4) !important;
  color: #58a6ff !important;
  font-weight: 600 !important;
}

/* 自定义输入行（选中自定义时下方出现） */
.ecm-limit-custom-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  gap: 12rpx;
}
.ecm-limit-input {
  width: 200rpx;
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(31, 111, 235, 0.4);
  border-radius: 12rpx;
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}
.ecm-limit-input::placeholder { color: #4a5568; font-size: 24rpx; }

.ecm-limit-unit {
  font-size: 24rpx;
  color: #8b949e;
}

/* ===== 首页 - 用户管理（权限弹窗内列表样式） ===== */

/* 搜索结果区（权限管理弹窗内搜索复用上方 .search-bar/.search-input） */
.umg-search { margin: 0 0 12rpx; }
.umg-search .search-input { height: 72rpx; background-color: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }

/* 用户列表项 */
.user-item {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  padding: 24rpx; background-color: #161b22; border-radius: 16rpx; margin-bottom: 12rpx;
}
.user-info { display: flex; flex-direction: row; align-items: center; flex: 1; overflow: hidden; }
.user-badge {
  padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: 600;
  flex-shrink: 0; margin-right: 12rpx;
}
.badge-super { background-color: rgba(155,89,182,0.2); color: #bb86fc; border: 1rpx solid rgba(155,89,182,0.3); }
.badge-admin { background-color: rgba(52,152,219,0.2); color: #3498db; border: 1rpx solid rgba(52,152,219,0.3); }
.badge-user { background-color: rgba(119,141,169,0.15); color: #778da9; border: 1rpx solid rgba(119,141,169,0.2); }
.user-nick {
  font-size: 28rpx; color: #e6edf3; overflow: hidden; text-overflow: ellipsis;
  white-space: nowrap; margin-right: 8rpx; max-width: 200rpx; flex-shrink: 1; min-width: 0;
}
.user-me { font-size: 22rpx; color: #f39c12; margin-left: 8rpx; }
.nick-count-info { margin-left: 8rpx; }
.nick-count-text { font-size: 20rpx; color: #8b949e; }
.user-nick.unregistered { color: #484f58; font-style: italic; }

/* 操作按钮 */
.user-actions { display: flex; flex-direction: row; flex-shrink: 0; margin-left: 12rpx; }
.reset-btn {
  padding: 8rpx 20rpx; border-radius: 8rpx; background-color: rgba(243,156,18,0.1);
  border: 1rpx solid rgba(243,156,18,0.2); font-size: 22rpx; color: #f39c12; margin-right: 8rpx;
}
.toggle-btn { padding: 8rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; }
.toggle-on { background-color: rgba(39,174,96,0.15); border: 1rpx solid rgba(39,174,96,0.3); color: #27ae60; }
.toggle-off { background-color: rgba(231,76,60,0.15); border: 1rpx solid rgba(231,76,60,0.3); color: #e74c3c; }
.toggle-super { background-color: rgba(155,89,182,0.15); border: 1rpx solid rgba(155,89,182,0.3); color: #bb86fc; }
.toggle-disabled { background-color: rgba(119,141,169,0.08); border: 1rpx solid rgba(119,141,169,0.15); color: #415a77; }
.toggle-loading { background-color: rgba(119,141,169,0.04); border: 1rpx solid rgba(119,141,169,0.1); color: #8b949e !important; opacity: 0.6; }

/* 分页 */
.pagination { display: flex; flex-direction: row; justify-content: center; align-items: center; padding: 24rpx 0 8rpx; gap: 24rpx; }
.page-btn {
  padding: 12rpx 32rpx; border-radius: 12rpx; background-color: rgba(52,152,219,0.12);
  border: 1rpx solid rgba(52,152,219,0.25); font-size: 24rpx; color: #3498db;
}
.page-btn-disabled { background-color: rgba(119,141,169,0.06); border-color: rgba(119,141,169,0.12); color: #415a77; }
.page-btn:active:not(.page-btn-disabled) { background-color: rgba(52,152,219,0.22); }
.page-info { font-size: 24rpx; color: #8b949e; }

/* ===== 首页加载失败提示 ===== */
.home-load-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}
.hle-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}
.hle-text {
  font-size: 28rpx;
  color: #e6edf3;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.hle-sub {
  font-size: 24rpx;
  color: #8b949e;
  margin-bottom: 28rpx;
}
.hle-retry-btn {
  padding: 14rpx 48rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(79, 140, 255, 0.15), rgba(124, 92, 252, 0.1));
  border: 1rpx solid rgba(79, 140, 255, 0.25);
  font-size: 26rpx;
  color: #58a6ff;
  font-weight: 600;
}
.hle-retry-btn:active {
  background: linear-gradient(135deg, rgba(79, 140, 255, 0.25), rgba(124, 92, 252, 0.18));
}

/* ===== 公告编辑弹窗 ===== */
.ann-modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.65); z-index: 10000;
  display: flex; align-items: center; justify-content: center;
}
.ann-modal {
  position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);
  width: 620rpx;
  background-color: #1e2530; border-radius: 24rpx; z-index: 10000;
  display: flex; flex-direction: column; overflow: hidden;
}
.ann-topbar {
  display: flex; flex-direction: row; justify-content: space-between; align-items: center;
  padding: 28rpx 36rpx 0; flex-shrink: 0;
}
.ann-title { font-size: 32rpx; font-weight: 700; color: #e6edf3; }

.ann-close-btn {
  width: 48rpx; height: 48rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  background-color: rgba(255,255,255,0.04);
}
.ann-close-btn:active { background-color: rgba(255,255,255,0.12); }
.ann-close-icon { font-size: 24rpx; color: #8b949e; font-weight: 700; line-height: 1; }

/* 文本域 */
.ann-body { padding: 24rpx 36rpx 20rpx; }
.ann-textarea {
  width: 100%; min-height: 240rpx; padding: 20rpx 24rpx; box-sizing: border-box;
  background-color: rgba(255,255,255,0.04); border-radius: 12rpx;
  font-size: 28rpx; color: #e6edf3; line-height: 1.6;
  border: 1rpx solid rgba(255,255,255,0.08);
}

/* 底部按钮 */
.ann-footer {
  display: flex; flex-direction: row; gap: 20rpx;
  padding: 0 36rpx 32rpx; flex-shrink: 0;
}
.ann-btn {
  flex: 1; padding: 20rpx 0; text-align: center;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 500;
}
.ann-btn-cancel { background-color: rgba(255,255,255,0.04); color: #8b949e; border: 1rpx solid rgba(255,255,255,0.08); }
.ann-btn-cancel:active { background-color: rgba(255,255,255,0.08); }
.ann-btn-confirm { background-color: rgba(52,152,219,0.15); color: #3498db; border: 1rpx solid rgba(52,152,219,0.25); }
.ann-btn-confirm:active { background-color: rgba(52,152,219,0.25); }
