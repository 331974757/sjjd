/* pages/event-match-edit/event-match-edit.wxss */
/* 对战编排页 - 深色主题 */

.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}
.loading-text {
  color: #8b949e;
  font-size: 28rpx;
}

/* ===== 顶部信息栏 ===== */
.info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #1a1f2e, #1c2333);
  border-radius: 16rpx;
  border: 1rpx solid rgba(88,166,255,0.12);
}
.info-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.info-event {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6edf3;
}
.info-round {
  font-size: 24rpx;
  color: #58a6ff;
}
.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 对战编排刷新按钮 */
.match-refresh {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  transition: all 0.15s ease;
}
.match-refresh:active {
  background-color: rgba(31, 111, 235, 0.3);
  transform: scale(0.92);
}
.match-refresh .refresh-icon {
  font-size: 28rpx;
  color: #8b949e;
  font-weight: 300;
  line-height: 1;
}

.info-team-count {
  font-size: 36rpx;
  font-weight: 700;
  color: #d29922;
}

/* ===== 快捷操作栏 ===== */
.quick-bar {
  display: flex;
  gap: 12rpx;
  margin: 0 24rpx 20rpx;
}
.quick-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.btn-select-all {
  background: rgba(255,255,255,0.06);
  color: #c9d1d9;
}
.btn-auto-match {
  background: rgba(31,111,235,0.15);
  color: #58a6ff;
}
.btn-auto-gen {
  background: rgba(63,185,80,0.15);
  color: #3fb950;
}

/* ===== 通用区块 ===== */
.section {
  margin: 0 24rpx 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e6edf3;
}
.section-count {
  font-size: 24rpx;
  color: #58a6ff;
}
.section-hint {
  font-size: 22rpx;
  color: #6e7681;
}

/* ===== 队伍勾选列表 ===== */
.team-select-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.team-select-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.team-select-item.selected {
  background: rgba(31,111,235,0.08);
  border-color: rgba(88,166,255,0.3);
}

/* 复选框 */
.tsi-checkbox {
  margin-right: 16rpx;
  flex-shrink: 0;
}
.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.checkbox-inner.checked {
  background: #238636;
  border-color: #238636;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

/* 队伍信息 */
.tsi-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.tsi-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
}
.tsi-meta {
  font-size: 22rpx;
  color: #8b949e;
}
.tsi-mmr {
  font-size: 26rpx;
  font-weight: 700;
  color: #d29922;
  flex-shrink: 0;
}

/* ===== 对战配对卡片 ===== */
.pair-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.pair-card {
  background: rgba(255,255,255,0.04);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  overflow: hidden;
}
.pair-vs-line {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 16rpx;
}
.pair-team {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.pair-team-a {}
.pair-team-b {}
.pt-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #e6edf3;
}
.pt-mmr {
  font-size: 22rpx;
  color: #d29922;
}
.pt-count {
  font-size: 20rpx;
  color: #8b949e;
}
.pair-vs {
  flex-shrink: 0;
  padding: 0 24rpx;
}
.vs-text {
  font-size: 32rpx;
  font-weight: 900;
  color: rgba(248,81,73,0.5);
}
.pair-remove {
  text-align: center;
  padding: 12rpx 0;
  background: rgba(248,81,73,0.08);
  border-top: 1rpx solid rgba(248,81,73,0.1);
}
.pair-remove text {
  font-size: 24rpx;
  color: #f85149;
}

/* ===== 轮空提示 ===== */
.bye-hint {
  margin: 0 24rpx 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(210,153,34,0.08);
  border: 1rpx solid rgba(210,153,34,0.15);
  border-radius: 10rpx;
}
.bye-label {
  font-size: 24rpx;
  color: #d29922;
  font-weight: 600;
}
.bye-team {
  font-size: 24rpx;
  color: #c9d1d9;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(13,17,23,0.95);
  backdrop-filter: blur(20rpx);
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.bottom-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  padding: 0;
}
.bottom-btn::after { border: none; }
.btn-gray {
  background: rgba(255,255,255,0.08);
  color: #c9d1d9;
}
.btn-primary {
  background: linear-gradient(135deg, #1f6feb, #388bfd);
  color: #ffffff;
}
.btn-disabled {
  background: rgba(48,54,61,0.6);
  color: #484f58;
}

/* ===== 空状态 ===== */
.empty-state {
  padding: 60rpx 0;
  text-align: center;
}
.empty-text {
  font-size: 26rpx;
  color: #484f58;
}

/* ===== 弹窗（复用项目通用弹窗样式） ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 600rpx;
  background: #161b22;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  padding: 40rpx 36rpx 28rpx;
}
.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 16rpx;
}
.modal-content {
  display: block;
  font-size: 26rpx;
  color: #8b949e;
  line-height: 1.8;
  margin-bottom: 32rpx;
  white-space: pre-line;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-secondary {
  background: rgba(255,255,255,0.08);
  color: #c9d1d9;
}
.btn-danger {
  background: #da3633;
  color: #fff;
}
