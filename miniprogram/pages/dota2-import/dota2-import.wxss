/* pages/dota2-import/dota2-import.wxss */
.import-page {
  min-height: 100vh;
  background-color: #0d1b2a;
  padding-bottom: 60rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e0e1dd;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #778da9;
}

.template-section {
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  background-color: #1b263b;
  border-radius: 16rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e1dd;
  margin-bottom: 16rpx;
}

.column-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.column-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

.column-idx {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background-color: #415a77;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #e0e1dd;
  font-weight: 700;
  flex-shrink: 0;
}

.column-info {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.column-name {
  font-size: 24rpx;
  color: #e0e1dd;
}

.column-field {
  font-size: 20rpx;
  color: #778da9;
  font-family: monospace;
}

.column-required {
  font-size: 18rpx;
  color: #e74c3c;
  background-color: rgba(231, 76, 60, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx 24rpx;
}

.pick-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background-color: #415a77;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pick-btn:active {
  background-color: #778da9;
}

.pick-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e1dd;
}

.action-hint {
  font-size: 22rpx;
  color: #778da9;
  margin-top: 12rpx;
}

.file-name {
  font-size: 24rpx;
  color: #3498db;
  margin-top: 8rpx;
}

/* 预览 */
.preview-section {
  padding: 0 32rpx;
}

.preview-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e1dd;
}

.preview-warn {
  font-size: 22rpx;
  color: #f39c12;
}

.error-list {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(231, 76, 60, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(231, 76, 60, 0.3);
}

.error-text {
  font-size: 22rpx;
  color: #e74c3c;
}

.preview-table {
  width: 100%;
  background-color: #1b263b;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.table-row {
  display: flex;
  flex-direction: row;
  min-width: 1100rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background-color: rgba(65, 90, 119, 0.5);
}

.table-header .table-cell {
  font-weight: 600;
  color: #e0e1dd;
  font-size: 20rpx;
}

.table-cell {
  min-width: 140rpx;
  padding: 12rpx 10rpx;
  font-size: 20rpx;
  color: #778da9;
  flex-shrink: 0;
}

.import-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background-color: #27ae60;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.import-btn:active {
  background-color: #2ecc71;
}

.btn-disabled {
  opacity: 0.6;
}

.import-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.xlsx-section {
  padding: 0 32rpx;
}

.result-section {
  margin: 24rpx 32rpx 0;
  padding: 20rpx;
  background-color: rgba(39, 174, 96, 0.15);
  border-radius: 12rpx;
  border: 1rpx solid rgba(39, 174, 96, 0.3);
  text-align: center;
}

.result-text {
  font-size: 26rpx;
  color: #27ae60;
  font-weight: 600;
}
