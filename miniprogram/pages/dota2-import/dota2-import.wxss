/* pages/dota2-import/dota2-import.wxss */
.import-page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 80rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 28rpx;
}

.header-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #8b949e;
}

.template-section {
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  background-color: #161b22;
  border-radius: 16rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
  margin-bottom: 16rpx;
}

/* 模板按钮 */
.template-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 12rpx;
  background-color: rgba(52, 152, 219, 0.15);
  border: 1rpx solid rgba(52, 152, 219, 0.3);
  margin-top: 20rpx;
}

.template-btn:active {
  background-color: rgba(52, 152, 219, 0.25);
}

.template-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.template-text {
  font-size: 26rpx;
  color: #3498db;
  font-weight: 600;
}

.template-hint {
  display: block;
  font-size: 20rpx;
  color: #484f58;
  margin-top: 10rpx;
  text-align: center;
}

.column-list {
  display: flex;
  flex-direction: column;
}

.column-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 14rpx;
}

.column-idx {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background-color: #484f58;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #e6edf3;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.column-info {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.column-name {
  font-size: 24rpx;
  color: #e6edf3;
  margin-right: 10rpx;
}

.column-field {
  font-size: 20rpx;
  color: #8b949e;
  font-family: monospace;
}

.column-required {
  font-size: 18rpx;
  color: #e74c3c;
  background-color: rgba(231, 76, 60, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.column-optional {
  font-size: 18rpx;
  color: #8b949e;
  background-color: rgba(139, 148, 158, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx 24rpx;
}

.pick-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.15);
  background-color: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pick-btn:active {
  background-color: rgba(255, 255, 255, 0.08);
  border-color: rgba(31, 111, 235, 0.4);
}

.pick-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #e6edf3;
}

.action-hint {
  font-size: 22rpx;
  color: #8b949e;
  margin-top: 12rpx;
}

.file-name {
  font-size: 24rpx;
  color: #3498db;
  margin-top: 8rpx;
}

/* 预览 */
.preview-section {
  padding: 0 32rpx;
}

.preview-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e6edf3;
}

.preview-warn {
  font-size: 22rpx;
  color: #f39c12;
}

.error-list {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(231, 76, 60, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(231, 76, 60, 0.3);
}

.error-text {
  font-size: 22rpx;
  color: #e74c3c;
}

.preview-table {
  width: 100%;
  background-color: #161b22;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.table-row {
  display: flex;
  flex-direction: row;
  min-width: 1100rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background-color: #21262d;
}

.table-header .table-cell {
  font-weight: 600;
  color: #e6edf3;
  font-size: 20rpx;
}

.table-cell {
  min-width: 140rpx;
  padding: 12rpx 10rpx;
  font-size: 20rpx;
  color: #8b949e;
  flex-shrink: 0;
}

.import-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.25);
}

.import-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-disabled {
  opacity: 0.6;
  box-shadow: none;
}

.import-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.xlsx-section {
  padding: 0 32rpx;
}

.result-section {
  margin: 24rpx 32rpx 0;
  padding: 20rpx;
  background-color: rgba(39, 174, 96, 0.15);
  border-radius: 12rpx;
  border: 1rpx solid rgba(39, 174, 96, 0.3);
  text-align: center;
}

.result-text {
  font-size: 26rpx;
  color: #27ae60;
  font-weight: 600;
}
