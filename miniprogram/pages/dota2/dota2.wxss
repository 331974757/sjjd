/* pages/dota2/dota2.wxss */
.page {
  min-height: 100vh;
  background-color: #0d1117;
  padding-bottom: 140rpx;
}

/* ===== 自定义导航栏 ===== */
.nav-custom {
  background-color: #0d1117;
}

.nav-inner {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  padding: 8rpx 24rpx 4rpx;
  height: 100rpx;
  position: relative;
}

.nav-left-space {
  flex-shrink: 0;
  width: 180rpx;
}

.nav-gold-title {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f5d799, #e8b84a, #d4a03a);
  -webkit-background-clip: text;
  color: transparent;
  white-space: nowrap;
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  transform: translateX(-50%);
}

/* 标题下方的金色横线 */
.nav-title-line {
  width: 280rpx;
  height: 4rpx;
  margin: 4rpx auto 24rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent, #e8b84a, #f5d799, #e8b84a, transparent);
}

.nav-right-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  margin-right: 12rpx;
}

/* ===== 全局工具栏（昵称修改 | 管理员展示 | 权限管理）===== */
.global-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  padding: 6rpx 36rpx 4rpx;
  gap: 2rpx;
}

.gtb-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.15s ease;
}

.gtb-btn:active {
  background-color: rgba(255, 255, 255, 0.1);
  transform: scale(0.95);
}

.gtb-btn-admin {
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.12), rgba(31, 111, 235, 0.08));
  border-color: rgba(212, 160, 58, 0.25);
}

.gtb-btn-admin:active {
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.22), rgba(31, 111, 235, 0.15));
  border-color: rgba(212, 160, 58, 0.45);
}

.gtb-icon {
  font-size: 24rpx;
  line-height: 1;
}

.gtb-divider {
  width: 2rpx;
  height: 20rpx;
  background-color: rgba(255, 255, 255, 0.06);
  margin: 0 4rpx;
  border-radius: 1rpx;
}

/* ===== 子分页栏 ===== */
.sub-tabs {
  display: flex;
  flex-direction: row;
  padding: 12rpx 36rpx 18rpx;
  gap: 16rpx;
}

.sub-tab {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid transparent;
  transition: all 0.25s ease;
}

.sub-tab.sub-active {
  background-color: #d4a03a;
  border-color: #e8b84a;
  box-shadow: 0 4rpx 16rpx rgba(212, 160, 58, 0.35);
}

.sub-tab-text {
  font-size: 26rpx;
  color: #8b949e;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.sub-tab.sub-active .sub-tab-text {
  color: #0d1117;
}


/* ===== 游戏标签（主导航） ===== */
.game-tabs {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx 36rpx 12rpx;
  gap: 10rpx;
}

.game-tab {
  height: 52rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid transparent;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.game-tab.tab-active {
  background-color: #1f6feb;
  border-color: #1f6feb;
}

.tab-text {
  font-size: 24rpx;
  color: #8b949e;
  font-weight: 500;
}

.game-tab.tab-active .tab-text {
  color: #ffffff;
}

/* 右侧 + 号 */
.game-plus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.game-plus:active {
  background-color: rgba(255, 255, 255, 0.1);
  transform: scale(0.92);
}

.plus-icon {
  font-size: 28rpx;
  color: #8b949e;
  font-weight: 300;
  line-height: 1;
}

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 6rpx 36rpx 10rpx;
  position: relative;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 64rpx 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.search-clear {
  position: absolute;
  right: 44rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #484f58;
  line-height: 1;
  z-index: 5;
}
.search-clear:active { color: #e6edf3; }

/* ===== 筛选行 ===== */
.filter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 6rpx 36rpx;
  gap: 10rpx;
}

.ftag-fixed {
  flex-shrink: 0;
}

.filter-scroll {
  white-space: nowrap;
  flex: 1;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.filter-scroll::-webkit-scrollbar { display: none; }

.ftag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #8b949e;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-right: 10rpx;
  line-height: 1.4;
  transition: all 0.15s ease;
}
.ftag:active { opacity: 0.7; }

.ftag.ftag-on {
  background-color: rgba(31, 111, 235, 0.15);
  color: #58a6ff;
  border-color: rgba(31, 111, 235, 0.35);
}

/* 操作按钮行：左右分布 */
.action-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 36rpx;
}

/* 段位排序切换按钮 */
.tbtn-sort {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  color: #8b949e;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.15s ease;
}
.tbtn-sort:active { opacity: 0.7; }

.tbtn-sort.sort-desc {
  color: #58a6ff;
  background-color: rgba(31, 111, 235, 0.12);
  border-color: rgba(31, 111, 235, 0.3);
}

.tbtn-sort.sort-asc {
  color: #3bfb83;
  background-color: rgba(59, 251, 131, 0.08);
  border-color: rgba(59, 251, 131, 0.2);
}

.sort-arrow {
  margin-left: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
}

/* 左侧按钮组 */
.action-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

/* 重置按钮 */
.tbtn-reset {
  margin-left: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  font-size: 30rpx;
  color: #8b949e;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tbtn-reset:active { opacity: 0.7; }

/* 右侧功能图标区 */
.action-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.tbtn-icon {
  width: 52rpx;
  height: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  border: 1rpx solid rgba(212, 160, 58, 0.25);
  background-color: rgba(212, 160, 58, 0.08);
  color: #d4a03a;
  flex-shrink: 0;
  overflow: hidden;
}

.chart-btn.chart-active { background-color: rgba(212, 160, 58, 0.22); border-color: rgba(212, 160, 58, 0.5); }

/* ===== 双列卡片网格 ===== */
.card-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 20rpx 28rpx;
  /* 用padding替代gap，子元素用margin控制间距 */
}

.grid-card {
  width: calc(50% - 12rpx);
  background-color: #161b22;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  transition: transform 0.15s ease;
}
.grid-card:active {
  transform: scale(0.97);
}
/* 第偶数个卡片（右侧）左边距 */
.grid-card:nth-child(2n) {
  margin-left: 12rpx;
}
/* 第奇数个卡片（左侧）右边距 */
.grid-card:nth-child(odd) {
  margin-right: 12rpx;
}

/* 卡片头像区 */
.card-avatar-wrap {
  position: relative;
  width: 100%;
  height: 300rpx;
  background-color: #21262d;
}

.card-avatar {
  width: 100%;
  height: 100%;
}

.card-name-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 16rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-name-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.card-rank-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 4rpx;
}

/* 段位图标（emoji） */
.rank-icon {
  font-size: 30rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* 段位图标（图片） */
.rank-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.card-rank-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #5bb8ff;
}

.card-rank-stars {
  font-size: 20rpx;
  color: #c9a046;
  margin-left: 6rpx;
}

/* ===== 段位分布饼图 ===== */
.chart-section {
  margin: 10rpx 36rpx 24rpx;
  background: linear-gradient(180deg, #1a1f2b 0%, #161b22 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.chart-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx 4rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f6fc;
  letter-spacing: 1rpx;
}

.chart-close {
  font-size: 26rpx;
  color: #484f58;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
}
.chart-close:active {
  background-color: rgba(255, 255, 255, 0.1);
  color: #8b949e;
}

.chart-body {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx 28rpx;
}

.pie-canvas {
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 16rpx rgba(0, 0, 0, 0.4));
}

/* ===== 饼图右侧颜色+数量 ===== */
.chart-legend {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-left: 32rpx;
  flex-shrink: 0;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 5rpx;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx currentColor;
}

.legend-label {
  font-size: 24rpx;
  color: #c9d1d9;
  min-width: 110rpx;
  font-weight: 500;
}

.legend-count {
  font-size: 26rpx;
  color: #8b949e;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  min-width: 44rpx;
  text-align: right;
}

/* ===== 批量删除工具栏 ===== */
.batch-toolbar {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 32rpx;
  margin: 0 32rpx 12rpx;
  background-color: rgba(218, 54, 51, 0.1);
  border: 1rpx solid rgba(218, 54, 51, 0.2);
  border-radius: 14rpx;
}

.batch-count {
  font-size: 26rpx;
  color: #f85149;
  font-weight: 600;
}

.batch-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.batch-btn {
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.batch-btn-cancel {
  background-color: rgba(255, 255, 255, 0.08);
  color: #c9d1d9;
}

.batch-btn-del {
  background-color: #da3633;
  color: #ffffff;
}

/* ===== 卡片选中态 ===== */
.grid-card.card-selected {
  border: 3rpx solid #f85149;
}

.card-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.grid-card.card-selected .card-check {
  border-color: #f85149;
  background-color: #da3633;
}

.check-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #484f58;
}

.empty-sub {
  font-size: 24rpx;
  color: #484f58;
  margin-top: 8rpx;
}

/* ===== 加载中 ===== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #484f58;
}

/* ===== 底部加载提示 ===== */
.load-more-tip {
  display: flex;
  justify-content: center;
  padding: 20rpx 40rpx 40rpx;
  font-size: 24rpx;
  color: #484f58;
}

/* ===== FAB 添加按钮 ===== */
.fab-btn {
  position: fixed;
  bottom: 48rpx;
  right: 36rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1f6feb;
  box-shadow: 0 8rpx 28rpx rgba(31, 111, 235, 0.45);
  z-index: 50;
  transition: all 0.15s ease;
}

.fab-btn:active {
  transform: scale(0.92);
  opacity: 0.85;
}

.fab-text {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  transform: translate(0rpx, -4rpx);
}

/* ===== CS:GO 占位 ===== */
.csgo-placeholder {
  padding-top: 260rpx;
}

/* ===== 昵称编辑弹窗 ===== */
.nick-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nick-modal {
  width: 600rpx;
  background-color: #1e2530;
  border-radius: 24rpx;
  padding: 56rpx 48rpx 40rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nick-modal-close {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nick-close-icon {
  font-size: 32rpx;
  color: #5a6678;
  line-height: 1;
}

.nick-modal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.nick-modal-desc {
  font-size: 26rpx;
  color: #7d8590;
  margin-bottom: 36rpx;
}

.nick-modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 16rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
  margin-bottom: 28rpx;
}

.nick-input-placeholder {
  color: #4a5568;
  font-size: 28rpx;
}

.nick-remain-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 36rpx;
}

.nick-openid-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nick-openid-label {
  font-size: 24rpx;
  color: #7d8590;
}

.nick-openid-value {
  font-size: 24rpx;
  color: #58a6ff;
  word-break: break-all;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.nick-remain-label {
  font-size: 26rpx;
  color: #7d8590;
}

.nick-remain-value {
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 500;
}

.remain-unlimited {
  color: #e8b84a;
  font-weight: 700;
}

.nick-superadmin-tip {
  width: 100%;
  padding: 16rpx 24rpx;
  margin-bottom: 28rpx;
  border-radius: 12rpx;
  background-color: rgba(252, 186, 3, 0.08);
  border: 1rpx solid rgba(252, 186, 3, 0.2);
  text-align: center;
  font-size: 24rpx;
  color: #e8b84a;
  line-height: 1.5;
}

.nick-btn-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 20rpx;
}

.nick-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.nick-btn-cancel {
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: #8b949e;
}

.nick-btn-cancel:active {
  background-color: rgba(255, 255, 255, 0.05);
}

.nick-btn-save {
  background-color: #3b82f6;
  color: #ffffff;
}

.nick-btn-save:active {
  background-color: #2563eb;
}

.nick-btn-disabled {
  background-color: #30363d !important;
  color: #8b949e !important;
  opacity: 0.6;
}

/* ===== 管理员信息弹窗 ===== */
.admin-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-modal {
  width: 600rpx;
  max-height: 80vh;
  background-color: #1e2530;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.admin-modal-close {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-close-icon {
  font-size: 32rpx;
  color: #5a6678;
  line-height: 1;
}

.admin-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 36rpx;
}

/* 管理员列表 */
.admin-list {
  flex: 1;
  overflow-y: auto;
}

.admin-section {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.admin-section:last-child {
  margin-bottom: 0;
}

.admin-section-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.admin-section-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.admin-section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 4rpx;
}

.admin-section-desc {
  font-size: 22rpx;
  color: #7d8590;
}

.admin-name-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.admin-name {
  display: inline-block;
  padding: 10rpx 22rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #c9d1d9;
  background-color: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

/* 空状态 */
.admin-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.admin-empty-text {
  font-size: 26rpx;
  color: #484f58;
}

/* 底部提示 */
.admin-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  text-align: center;
}

.admin-footer-text {
  font-size: 22rpx;
  color: #5a6678;
  line-height: 1.6;
}

/* ===== 占位页（赛事章程 / 历史赛事） ===== */
.placeholder-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 320rpx;
}

.ph-icon {
  font-size: 120rpx;
  opacity: 0.35;
  margin-bottom: 28rpx;
}

.ph-main {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.ph-sub {
  font-size: 26rpx;
  color: rgba(139, 148, 158, 0.7);
}

/* =====【第4轮新增】历史赛事列表 ===== */
.event-list-page {
  padding: 16rpx 24rpx 120rpx;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.event-card-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 22rpx;
  background: linear-gradient(135deg, #161b22, #1c2333);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  transition: background 0.15s;
}

.event-card-item:active {
  background: rgba(31,111,235,0.06);
  border-color: rgba(31,111,235,0.15);
}

.eci-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eci-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.eci-time {
  font-size: 24rpx;
  color: #8b949e;
}

.eci-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.eci-status {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 赛事状态颜色（与event-detail保持一致） */
.eci-s0 { background: rgba(139,148,158,0.12); color: #8b949e; }
.eci-s1 { background: rgba(63,185,80,0.12);  color: #3fb950; }
.eci-s2 { background: rgba(218,54,51,0.12);  color: #f85149; }
.eci-s3 { background: rgba(210,153,34,0.12);  color: #d29922; }
.eci-s4 { background: rgba(31,111,235,0.12);  color: #58a6ff; }
.eci-s5 { background: rgba(139,148,158,0.06); color: #6e7681; }

.eci-arrow {
  font-size: 36rpx;
  color: #484f58;
  font-weight: 300;
}

/* =====【第8轮新增】历史赛事搜索栏 ===== */
.history-search-bar {
  padding: 6rpx 0 20rpx;
}

.history-search-wrap {
  position: relative;
  height: 72rpx;
}

.history-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 64rpx 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

.history-search-clear {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #484f58;
  line-height: 1;
}
.history-search-clear:active { color: #e6edf3; }

/* =====【第8轮新增】历史赛事增强卡片 ===== */
.history-card {
  background: linear-gradient(135deg, #161b22 0%, #1c2333 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 24rpx 24rpx 20rpx;
  transition: all 0.15s ease;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.history-card:active {
  background: rgba(31, 111, 235, 0.04);
  border-color: rgba(31, 111, 235, 0.2);
  transform: scale(0.985);
}

/* 卡片头部 */
.hcard-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.hcard-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.hcard-desc {
  margin-bottom: 12rpx;
}

.hdesc-text {
  font-size: 24rpx;
  color: #6e7681;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-height: 1.5;
}

.hcard-status {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(139, 148, 158, 0.08);
  font-size: 22rpx;
  color: #6e7681;
  font-weight: 600;
}

/* 赛事基本信息行 */
.hcard-meta {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
  margin-bottom: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.hcard-meta-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.hmeta-icon {
  font-size: 26rpx;
  opacity: 0.7;
}

.hmeta-text {
  font-size: 24rpx;
  color: #8b949e;
}

/* 前三名领奖台 */
.hcard-podium {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.hpodium-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  gap: 12rpx;
}

/* 金银铜配色 */
.hpodium-item.hp-gold {
  background: linear-gradient(135deg, rgba(232, 184, 74, 0.12), rgba(212, 160, 58, 0.06));
  border: 1rpx solid rgba(232, 184, 74, 0.2);
}

.hpodium-item.hp-silver {
  background: linear-gradient(135deg, rgba(168, 180, 198, 0.1), rgba(139, 148, 158, 0.04));
  border: 1rpx solid rgba(168, 180, 198, 0.15);
}

.hpodium-item.hp-bronze {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.1), rgba(180, 110, 40, 0.04));
  border: 1rpx solid rgba(205, 127, 50, 0.15);
}

.hp-medal {
  font-size: 36rpx;
  flex-shrink: 0;
}

.hp-team-name {
  font-size: 26rpx;
  color: #c9d1d9;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 无排名提示 */
.hcard-no-ranks {
  padding: 12rpx 0;
  margin-bottom: 12rpx;
}

.hnr-text {
  font-size: 24rpx;
  color: #484f58;
}

/* 卡片底部 */
.hcard-footer {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.hcard-detail-link {
  font-size: 24rpx;
  color: #58a6ff;
  font-weight: 500;
}

/* =====【第8轮新增】分页加载区域 ===== */
.history-load-more {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.hlm-btn {
  padding: 16rpx 60rpx;
  border-radius: 32rpx;
  background: rgba(31, 111, 235, 0.1);
  border: 1rpx solid rgba(31, 111, 235, 0.25);
  font-size: 26rpx;
  color: #58a6ff;
  font-weight: 500;
  transition: all 0.15s;
}

.hlm-btn:active {
  background: rgba(31, 111, 235, 0.2);
}

.hlm-loading {
  font-size: 24rpx;
  color: #484f58;
  padding: 16rpx 0;
}

.history-all-loaded {
  display: flex;
  justify-content: center;
  padding: 28rpx 0;
}

.hal-text {
  font-size: 24rpx;
  color: #484f58;
}

/* ===== 【赛事创建】赛事章程标题栏 + 新建按钮 ===== */
.rules-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 20rpx 0;
}

.rules-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  letter-spacing: 2rpx;
}

/* 新建赛事按钮（仅管理员可见） */
.rules-create-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.15), rgba(31, 111, 235, 0.1));
  border: 1rpx solid rgba(212, 160, 58, 0.3);
  transition: all 0.15s ease;
}

.rules-create-btn:active {
  background: linear-gradient(135deg, rgba(212, 160, 58, 0.25), rgba(31, 111, 235, 0.18));
  transform: scale(0.95);
}

.rules-create-icon {
  font-size: 32rpx;
  font-weight: 400;
  color: #d4a03a;
  line-height: 1;
}

.rules-create-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #d4a03a;
}

/* ===== 【赛事创建】弹窗遮罩 ===== */
.event-create-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 【赛事创建】弹窗主体 ===== */
.event-create-modal {
  width: 620rpx;
  max-height: 85vh;
  background-color: #1e2530;
  border-radius: 24rpx;
  padding: 56rpx 40rpx 36rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

/* 关闭按钮 */
.ecm-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.04);
}

.ecm-close:active {
  background-color: rgba(255, 255, 255, 0.1);
}

.ecm-close-icon {
  font-size: 28rpx;
  color: #5a6678;
  line-height: 1;
}

/* 弹窗标题 */
.ecm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
}

/* 表单字段 */
.ecm-field {
  margin-bottom: 28rpx;
}

.ecm-label {
  display: block;
  font-size: 26rpx;
  color: #c9d1d9;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.ecm-required {
  color: #f85149;
}

.ecm-note {
  color: #8b949e;
  font-weight: 400;
  font-size: 22rpx;
}

/* 单行输入框 */
.ecm-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ecm-input::placeholder {
  color: #4a5568;
  font-size: 26rpx;
}

/* 日期选择器 */
.ecm-picker {
  width: 100%;
}

.ecm-picker-display {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #e6edf3;
  box-sizing: border-box;
}

.ecm-placeholder {
  color: #4a5568;
  font-size: 26rpx;
}

/* 多行文本框 */
.ecm-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 24rpx;
  border-radius: 14rpx;
  background-color: #272f3c;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #e6edf3;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 按钮行 */
.ecm-btn-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 20rpx;
  margin-top: 16rpx;
}

.ecm-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.15s;
}

.ecm-btn-cancel {
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: #8b949e;
  background-color: transparent;
}

.ecm-btn-cancel:active {
  background-color: rgba(255, 255, 255, 0.05);
}

.ecm-btn-confirm {
  background: linear-gradient(135deg, #1f6feb, #1a5dcc);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 235, 0.3);
}

.ecm-btn-confirm:active {
  background: linear-gradient(135deg, #1a5dcc, #154aa3);
  transform: scale(0.96);
}

/* 报名人数上限选项 */
.ecm-limit-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ecm-limit-opt {
  flex: 1;
  min-width: 120rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
  color: #8b949e;
  transition: all 0.15s;
}
.ecm-limit-opt:active {
  background-color: rgba(255, 255, 255, 0.08);
}

.ecm-limit-on {
  background-color: rgba(31, 111, 235, 0.15) !important;
  border-color: rgba(31, 111, 235, 0.4) !important;
  color: #58a6ff !important;
  font-weight: 600 !important;
}

.ecm-limit-custom-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 12rpx;
}

.ecm-limit-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(31, 111, 235, 0.4);
  border-radius: 12rpx;
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ecm-limit-unit {
  font-size: 24rpx;
  color: #8b949e;
}
