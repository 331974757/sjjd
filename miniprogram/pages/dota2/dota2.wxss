/* pages/dota2/dota2.wxss */
.page {
  min-height: 100vh;
  background-color: #0d1b2a;
  padding-bottom: 120rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 8rpx;
}

.top-left {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #e0e1dd;
}

.count {
  font-size: 24rpx;
  color: #778da9;
}

.top-right {
  display: flex;
  flex-direction: row;
}

.menu-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background-color: rgba(255, 255, 255, 0.05);
}

.menu-icon {
  font-size: 36rpx;
  color: #778da9;
  font-weight: 700;
}

/* 搜索 + 筛选 */
.filter-bar {
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.05);
  color: #e0e1dd;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.filter-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.filter-label {
  font-size: 22rpx;
  color: #778da9;
}

.pos-scroll {
  white-space: nowrap;
}

.pos-filter-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #778da9;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-right: 12rpx;
}

.pos-filter-tag.pos-active {
  background-color: rgba(65, 90, 119, 0.5);
  color: #FFFFFF;
  border-color: #415a77;
}

.sort-tags {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.sort-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #778da9;
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.sort-tag.sort-active {
  background-color: rgba(65, 90, 119, 0.5);
  color: #FFFFFF;
  border-color: #415a77;
}

/* 选手列表 */
.player-list {
  padding: 20rpx 32rpx;
}

.player-card {
  background-color: #1b263b;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.player-card:active {
  background-color: #222d42;
}

/* 卡片顶部 */
.card-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  overflow: hidden;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e1dd;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pos-tags {
  display: flex;
  flex-direction: row;
  gap: 6rpx;
  flex-shrink: 0;
}

.pos-tag {
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  padding: 0 8rpx;
}

.pos-tag.pos-1 { background-color: #e74c3c; }
.pos-tag.pos-2 { background-color: #f39c12; }
.pos-tag.pos-3 { background-color: #27ae60; }
.pos-tag.pos-4 { background-color: #3498db; }
.pos-tag.pos-5 { background-color: #9b59b6; }

.card-signup {
  background-color: rgba(243, 156, 18, 0.15);
  border: 1rpx solid rgba(243, 156, 18, 0.3);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
}

.signup-text {
  font-size: 22rpx;
  color: #f39c12;
  font-weight: 500;
}

/* 分数行 */
.card-score-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 32rpx;
  margin-bottom: 8rpx;
}

.score-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 160rpx;
}

.score-val {
  font-size: 56rpx;
  font-weight: 800;
  color: #3498db;
  line-height: 1.1;
}

.score-label {
  font-size: 20rpx;
  color: #778da9;
  margin-top: 4rpx;
}

.score-sub {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  flex: 1;
}

.score-sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sub-val {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e1dd;
}

.sub-label {
  font-size: 18rpx;
  color: #778da9;
  margin-top: 2rpx;
}

/* ID行 */
.card-id-row {
  margin-top: 4rpx;
}

.id-text {
  font-size: 22rpx;
  color: #415a77;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #778da9;
}

/* 加载中 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #778da9;
}

/* 底部加载 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #415a77;
}

/* FAB 按钮 */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: #3498db;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(52, 152, 219, 0.4);
  z-index: 50;
}

.fab-btn:active {
  background-color: #2980b9;
  transform: scale(0.95);
}

.fab-text {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}
