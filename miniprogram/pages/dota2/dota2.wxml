<!--pages/dota2/dota2.wxml-->
<view class="page">
  <!-- 自定义导航栏：金色大标题居中 -->
  <view class="nav-custom" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-left-space"></view>
      <text class="nav-gold-title">蜀国争霸系统</text>
      <view class="nav-right-area">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" wx:if="{{userInfo.avatarUrl}}" mode="aspectFill" />
      </view>
    </view>
    <view class="nav-title-line"></view>
  </view>

  <!-- 🌐 全局工具栏：修改昵称 | 管理员 | 权限管理(仅超管) -->
  <view class="global-toolbar">
    <view class="gtb-btn" bindtap="editNickname">
      <text class="gtb-icon">🖋</text>
    </view>
    <view class="gtb-divider"></view>
    <view class="gtb-btn" bindtap="showSuperAdminInfo">
      <text class="gtb-icon">👤</text>
    </view>
    <view class="gtb-divider" wx:if="{{userRole === 'super_admin'}}"></view>
    <view class="gtb-btn gtb-btn-admin" wx:if="{{userRole === 'super_admin'}}" bindtap="goAdmin">
      <text class="gtb-icon">🔑</text>
    </view>
    <view class="gtb-divider"></view>
    <view class="gtb-btn" bindtap="onRefreshTap">
      <text class="gtb-icon">⟳</text>
    </view>
  </view>

  <!-- 游戏切换标签（主导航） -->
  <view class="game-tabs">
    <view class="game-tab {{currentGame === 'dota2' ? 'tab-active' : ''}}" bindtap="switchGame" data-game="dota2">
      <text class="tab-text">Dota2</text>
    </view>
    <view class="game-tab {{currentGame === 'csgo' ? 'tab-active' : ''}}" bindtap="switchGame" data-game="csgo">
      <text class="tab-text">CS:GO</text>
    </view>
    <view class="game-plus" bindtap="onGamePlusTap">
      <text class="plus-icon">+</text>
    </view>
  </view>

  <!-- ====== Dota2 区域 ====== -->
  <block wx:if="{{currentGame === 'dota2'}}">

    <!-- 子分页栏 -->
    <view class="sub-tabs">
      <view class="sub-tab {{subTab === 'profile' ? 'sub-active' : ''}}" bindtap="switchSubTab" data-tab="profile">
        <text class="sub-tab-text">选手档案</text>
      </view>
      <view class="sub-tab {{subTab === 'rules' ? 'sub-active' : ''}}" bindtap="switchSubTab" data-tab="rules">
        <text class="sub-tab-text">赛事章程</text>
      </view>
      <view class="sub-tab {{subTab === 'history' ? 'sub-active' : ''}}" bindtap="switchSubTab" data-tab="history">
        <text class="sub-tab-text">历史赛事</text>
      </view>
    </view>

    <!-- 选手档案 -->
    <block wx:if="{{subTab === 'profile'}}">

    <!-- 搜索栏 -->
    <view class="search-bar">
      <input class="search-input" type="text" placeholder="搜索微信昵称 / Dota2 游戏昵称" placeholder-style="color:#4a5568;font-size:26rpx;" value="{{_searchText}}" bindinput="onKeywordInput" bindconfirm="onSearchConfirm" cursor-spacing="100" adjust-position="{{true}}" />
      <view class="search-clear" wx:if="{{_searchText}}" bindtap="clearSearch">✕</view>
    </view>

    <!-- 第一行：位置筛选 -->
    <view class="filter-row">
      <scroll-view class="filter-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="ftag {{positionFilter === 'all' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="all">擅长位置</view>
        <view class="ftag {{positionFilter === '1' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="1">1号位</view>
        <view class="ftag {{positionFilter === '2' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="2">2号位</view>
        <view class="ftag {{positionFilter === '3' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="3">3号位</view>
        <view class="ftag {{positionFilter === '4' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="4">4号位</view>
        <view class="ftag {{positionFilter === '5' ? 'ftag-on' : ''}}" bindtap="onPosFilter" data-pos="5">5号位</view>
      </scroll-view>
    </view>
    <!-- 第二行：段位筛选 -->
    <view class="filter-row">
      <view class="ftag ftag-fixed {{rankFilter === 'all' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="all">校准段位</view>
      <scroll-view class="filter-scroll" scroll-x="true" enhanced show-scrollbar="{{false}}">
        <view class="ftag {{rankFilter === 'herald' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="herald">先锋</view>
        <view class="ftag {{rankFilter === 'guardian' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="guardian">卫士</view>
        <view class="ftag {{rankFilter === 'crusader' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="crusader">中军</view>
        <view class="ftag {{rankFilter === 'archon' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="archon">统帅</view>
        <view class="ftag {{rankFilter === 'legend' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="legend">传奇</view>
        <view class="ftag {{rankFilter === 'ancient' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="ancient">万古流芳</view>
        <view class="ftag {{rankFilter === 'divine' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="divine">超凡入圣</view>
        <view class="ftag {{rankFilter === 'immortal' ? 'ftag-on' : ''}}" bindtap="onRankFilter" data-rank="immortal">冠绝一世</view>
      </scroll-view>
    </view>
    <!-- 第三行：操作按钮（左排序+重置 / 右功能） -->
    <view class="action-row">
      <view class="action-left">
        <view class="tbtn-sort {{sortFilter === 'rank-desc' ? 'sort-desc' : 'sort-asc'}}" bindtap="onSortToggle">
          <text>段位</text><text class="sort-arrow">{{sortFilter === 'rank-desc' ? '↓' : '↑'}}</text>
        </view>
        <view class="tbtn-reset" bindtap="resetFilters">✕</view>
      </view>
      <view class="action-right">
        <view class="tbtn-icon chart-btn {{showChart ? 'chart-active' : ''}}" bindtap="toggleChart">◔</view>
        <view class="tbtn-icon" wx:if="{{isAdmin}}" bindtap="showAdminMenu">⚙</view>
      </view>
    </view>

    <!-- 段位分布饼图 -->
    <view class="chart-section" wx:if="{{showChart}}">
      <view class="chart-header">
        <text class="chart-title">段位分布</text>
        <text class="chart-close" bindtap="closeChart">✕</text>
      </view>
      <view class="chart-body">
        <canvas type="2d" id="rankPieCanvas" class="pie-canvas" style="width:360rpx;height:360rpx;"></canvas>
        <view class="chart-legend">
          <view class="legend-item" wx:for="{{rankDistribution}}" wx:key="tier">
            <view class="legend-dot" style="background-color:{{item.color}};"></view>
            <text class="legend-label">{{item.label}}</text>
            <text class="legend-count">{{item.count}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 批量删除工具栏 -->
    <view class="batch-toolbar" wx:if="{{deleteMode}}">
      <text class="batch-count">已选 {{selectedCount}} 项</text>
      <view class="batch-actions">
        <view class="batch-btn batch-btn-cancel" bindtap="toggleDeleteMode">取消</view>
        <view class="batch-btn batch-btn-del" bindtap="batchDelete">删除</view>
      </view>
    </view>

    <!-- 双列卡片网格 -->
    <view class="card-grid" wx:if="{{displayPlayers.length > 0}}">
      <view class="grid-card {{selectedIds[item._id] ? 'card-selected' : ''}}" wx:for="{{displayPlayers}}" wx:key="_id"
        bindtap="{{deleteMode ? 'onSelectCard' : 'goDetail'}}"
        data-id="{{item._id}}" data-gameid="{{item.gameId}}">
        <view class="card-avatar-wrap">
          <image class="card-avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
          <view class="card-check" wx:if="{{deleteMode}}">
            <text class="check-icon">{{selectedIds[item._id] ? '✓' : ''}}</text>
          </view>
          <view class="card-name-overlay">
            <text class="card-name-text">{{item.wxNickname}}</text>
            <view class="card-rank-row">
              <image class="rank-icon-img" wx:if="{{item._rankIconIsImg && item.calibrateRankName}}" src="{{item._rankIcon}}" mode="aspectFit" />
              <text class="rank-icon" wx:elif="{{item._rankIcon && item.calibrateRankName}}">{{item._rankIcon}}</text>
              <text class="card-rank-text">{{item.calibrateRankName || '核准中'}}</text>
              <text class="card-rank-stars" wx:if="{{item.calibrateRankStar > 0}}">{{item.calibrateRankStar}}★</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 数据统计 & 分页状态 -->
    <view class="load-more-tip" wx:if="{{loaded && filteredCount > 0}}">
      <text wx:if="{{hasMore}}">已显示 {{displayPlayers.length}} / 共 {{filteredCount}} 名选手，上拉加载更多</text>
      <text wx:else>已显示全部，共 {{filteredCount}} 名选手</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{displayPlayers.length === 0 && loaded}}">
      <text class="empty-icon">🎮</text>
      <text class="empty-text">暂无符合条件的选手</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{!loaded}}">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 添加选手按钮 -->
    <view class="fab-btn" wx:if="{{isAdmin}}" bindtap="goAdd">
      <text class="fab-text">+</text>
    </view>

    </block>

    <!-- Dota2 赛事章程（进行中赛事） -->
    <view class="event-list-page" wx:if="{{subTab === 'rules'}}">
      <!-- 标题栏 + 新建按钮（仅管理员可见） -->
      <view class="rules-header">
        <text class="rules-header-title">赛事章程</text>
        <view class="rules-create-btn" wx:if="{{isAdmin}}" bindtap="showCreateEventModal">
          <text class="rules-create-icon">+</text>
          <text class="rules-create-text">新建赛事</text>
        </view>
      </view>

      <!-- 加载中 -->
      <view class="loading-state" wx:if="{{!rulesLoaded}}">
        <text class="loading-text">加载赛事中...</text>
      </view>

      <!-- 赛事列表 -->
      <view class="event-list" wx:if="{{rulesLoaded && ruleEventList.length > 0}}">
        <view class="event-card-item" wx:for="{{ruleEventList}}" wx:key="event_id" bindtap="goEventDetail" data-event-id="{{item.event_id}}">
          <view class="eci-left">
            <text class="eci-name">{{item.event_name}}</text>
            <text class="eci-time">{{item._timeLabel}}</text>
          </view>
          <view class="eci-right">
            <view class="eci-status eci-s{{item.event_status}}">
              <text>{{item._statusName}}</text>
            </view>
            <text class="eci-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 空状态（管理员提示可直接新建） -->
      <view class="empty-state" wx:if="{{rulesLoaded && ruleEventList.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无进行中的赛事</text>
        <text class="empty-sub" wx:if="{{isAdmin}}">点击上方「+ 新建赛事」创建第一场赛事</text>
        <text class="empty-sub" wx:else>请联系管理员创建赛事</text>
      </view>
    </view>

    <!-- Dota2 历史赛事（第8轮：完整增强版，支持搜索+前三名展示+分页加载） -->
    <view class="event-list-page" wx:if="{{subTab === 'history'}}">
      <!-- 搜索栏 -->
      <view class="history-search-bar">
        <view class="history-search-wrap">
          <input
            class="history-search-input"
            placeholder="搜索历史赛事名称"
            value="{{historySearchText}}"
            bindinput="onHistorySearchInput"
            bindconfirm="onHistorySearchConfirm"
          />
          <view class="history-search-clear" wx:if="{{historySearchText}}" bindtap="clearHistorySearch">✕</view>
        </view>
      </view>

      <!-- 加载中 -->
      <view class="loading-state" wx:if="{{!eventsLoaded}}">
        <text class="loading-text">加载赛事中...</text>
      </view>

      <!-- 赛事列表（增强卡片） -->
      <view class="event-list" wx:if="{{eventsLoaded && eventList.length > 0}}">
        <view
          class="history-card"
          wx:for="{{eventList}}"
          wx:key="event_id"
          bindtap="goEventDetail"
          data-event-id="{{item.event_id}}"
        >
          <!-- 卡片头部：赛事名称 + 状态 -->
          <view class="hcard-header">
            <text class="hcard-name">{{item.event_name}}</text>
            <view class="hcard-status">
              <text>名次归档</text>
            </view>
          </view>

          <!-- 赛事简介（有则显示） -->
          <view class="hcard-desc" wx:if="{{item.event_desc}}">
            <text class="hdesc-text">{{item.event_desc}}</text>
          </view>

          <!-- 赛事基本信息行 -->
          <view class="hcard-meta">
            <view class="hcard-meta-item">
              <text class="hmeta-icon">📅</text>
              <text class="hmeta-text">{{item._timeLabel}}</text>
            </view>
            <view class="hcard-meta-item">
              <text class="hmeta-icon">👥</text>
              <text class="hmeta-text">{{item._signupCount || 0}} 人参赛</text>
            </view>
            <view class="hcard-meta-item" wx:if="{{item.archived_at}}">
              <text class="hmeta-icon">📦</text>
              <text class="hmeta-text">已归档</text>
            </view>
          </view>

          <!-- 前三名展示（领奖台） -->
          <view class="hcard-podium" wx:if="{{item._topRanks.length > 0}}">
            <view
              class="hpodium-item {{rank.rankNum === 1 ? 'hp-gold' : rank.rankNum === 2 ? 'hp-silver' : 'hp-bronze'}}"
              wx:for="{{item._topRanks}}"
              wx:key="rankNum"
              wx:for-item="rank"
            >
              <text class="hp-medal">
                {{rank.rankNum === 1 ? '🥇' : rank.rankNum === 2 ? '🥈' : '🥉'}}
              </text>
              <text class="hp-team-name">{{rank.teamName}}</text>
            </view>
          </view>

          <!-- 无排名提示 -->
          <view class="hcard-no-ranks" wx:if="{{item._topRanks.length === 0}}">
            <text class="hnr-text">未记录名次</text>
          </view>

          <!-- 查看详情箭头 -->
          <view class="hcard-footer">
            <text class="hcard-detail-link">查看详情 ›</text>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="history-load-more" wx:if="{{eventHasMore}}">
          <view class="hlm-btn" wx:if="{{!eventLoadingMore}}" bindtap="loadMoreEvents">
            <text>加载更多</text>
          </view>
          <view class="hlm-loading" wx:if="{{eventLoadingMore}}">
            <text>加载中...</text>
          </view>
        </view>

        <!-- 已加载全部 -->
        <view class="history-all-loaded" wx:if="{{!eventHasMore && eventList.length > 0}}">
          <text class="hal-text">已显示全部 {{eventTotal}} 届历史赛事</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{eventsLoaded && eventList.length === 0}}">
        <text class="empty-icon">🏆</text>
        <text class="empty-text" wx:if="{{!historySearchText}}">暂无历史赛事</text>
        <text class="empty-text" wx:if="{{historySearchText}}">未找到匹配的赛事</text>
        <text class="empty-sub" wx:if="{{!historySearchText}}">赛事归档后将显示在这里</text>
        <text class="empty-sub" wx:if="{{historySearchText}}">请尝试其他关键词</text>
      </view>
    </view>

  </block>

  <!-- ====== CS:GO 区域（尚未开放） ====== -->
  <block wx:if="{{currentGame === 'csgo'}}">
    <view class="placeholder-page csgo-placeholder">
      <text class="ph-icon">🎯</text>
      <text class="ph-main">CS:GO 选手档案</text>
      <text class="ph-sub">暂未开放，敬请期待</text>
    </view>
  </block>

  <!-- 昵称编辑弹窗 -->
  <view class="nick-modal-mask" wx:if="{{showNickModal}}" catchtouchmove="preventMove">
    <view class="nick-modal">
      <view class="nick-modal-close" bindtap="closeNickModal">
        <text class="nick-close-icon">✕</text>
      </view>
      <text class="nick-modal-title">{{nickName ? '修改昵称' : '请输入昵称'}}</text>
      <text class="nick-modal-desc">{{nickName ? '与微信群昵称一致可修改本人信息' : '需要与录入选手微信昵称一致方可修改资料'}}</text>
      <input
        class="nick-modal-input"
        value="{{nickInputValue}}"
        placeholder="{{nickName || '请输入你在群里的昵称'}}"
        placeholder-class="nick-input-placeholder"
        bindinput="onNickInput"
        focus="{{showNickModal}}"
        maxlength="20"
      />
      <view class="nick-openid-row" wx:if="{{userOpenid}}">
        <text class="nick-openid-label">我的 OpenID：</text>
        <text class="nick-openid-value" bindtap="copyOpenid">{{userOpenid}}</text>
      </view>
      <view class="nick-remain-row" wx:if="{{nickName}}">
        <text class="nick-remain-label">剩余修改次数：</text>
        <text class="nick-remain-value {{unlimitedNick ? 'remain-unlimited' : ''}}">{{unlimitedNick ? '无限' : remainingCount}}</text>
      </view>
      <view class="nick-superadmin-tip" wx:if="{{nickName && !unlimitedNick && nickChangeCount >= nickChangeLimit}}">
        <text>修改次数已用完，请联系超级管理员重置</text>
      </view>
      <view class="nick-btn-row">
        <view class="nick-btn nick-btn-cancel" bindtap="closeNickModal"><text>取消</text></view>
        <view class="nick-btn nick-btn-save {{!unlimitedNick && nickChangeCount >= nickChangeLimit ? 'nick-btn-disabled' : ''}}" bindtap="saveNickFromModal"><text>保存</text></view>
      </view>
    </view>
  </view>

  <!-- 【赛事创建】新建赛事弹窗 -->
  <view class="event-create-mask" wx:if="{{showCreateModal}}" catchtouchmove="preventMove">
    <view class="event-create-modal" catchtap="">
      <!-- 关闭按钮 -->
      <view class="ecm-close" bindtap="closeCreateEventModal">
        <text class="ecm-close-icon">✕</text>
      </view>
      <text class="ecm-title">新建赛事</text>

      <!-- 赛事名称（必填） -->
      <view class="ecm-field">
        <text class="ecm-label">赛事名称 <text class="ecm-required">*</text></text>
        <input
          class="ecm-input"
          placeholder="请输入赛事名称（2-50字）"
          value="{{createEventName}}"
          bindinput="onCreateEventNameInput"
          maxlength="50"
          focus="{{showCreateModal}}"
        />
      </view>

      <!-- 开始时间（可选） -->
      <view class="ecm-field">
        <text class="ecm-label">开始时间</text>
        <picker class="ecm-picker" mode="multiSelector" range="{{createDateTimeRange}}" value="{{createDateTimeIndex}}" bindchange="onCreateDateTimeChange" bindcolumnchange="onCreateDateTimeColumnChange">
          <view class="ecm-picker-display">
            <text class="{{createDateTimeText ? '' : 'ecm-placeholder'}}">{{createDateTimeText || '请选择开始时间（可选）'}}</text>
          </view>
        </picker>
      </view>

      <!-- 赛事简介（可选） -->
      <view class="ecm-field">
        <text class="ecm-label">赛事简介</text>
        <textarea
          class="ecm-textarea"
          placeholder="请输入赛事简介（可选）"
          value="{{createEventDesc}}"
          bindinput="onCreateEventDescInput"
          maxlength="200"
          auto-height
        />
      </view>

      <!-- 报名人数上限（可选） -->
      <view class="ecm-field">
        <text class="ecm-label">报名人数上限 <text class="ecm-note">(可选)</text></text>
        <view class="ecm-limit-options">
          <view class="ecm-limit-opt {{createEventLimit === 0 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="0">
            <text>无限制</text>
          </view>
          <view class="ecm-limit-opt {{createEventLimit === 10 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="10">
            <text>10人</text>
          </view>
          <view class="ecm-limit-opt {{createEventLimit === 20 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="20">
            <text>20人</text>
          </view>
          <view class="ecm-limit-opt {{createEventLimit === 30 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="30">
            <text>30人</text>
          </view>
          <view class="ecm-limit-opt {{createEventLimit === 40 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="40">
            <text>40人</text>
          </view>
        </view>
        <view class="ecm-limit-custom-row" wx:if="{{createEventLimit === -1}}">
          <input class="ecm-limit-input" type="number" placeholder="自定义" value="{{createEventLimitCustom}}" bindinput="onCreateEventLimitCustomInput" />
          <text class="ecm-limit-unit">人</text>
        </view>
        <view class="ecm-limit-opt ecm-limit-custom-btn {{createEventLimit === -1 ? 'ecm-limit-on' : ''}}" bindtap="pickEventLimit" data-val="-1" wx:if="{{createEventLimit !== -1}}">
          <text>自定义</text>
        </view>
      </view>

      <!-- 按钮行 -->
      <view class="ecm-btn-row">
        <view class="ecm-btn ecm-btn-cancel" bindtap="closeCreateEventModal">
          <text>取消</text>
        </view>
        <view class="ecm-btn ecm-btn-confirm" bindtap="submitCreateEvent">
          <text>确认创建</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 管理员信息弹窗 -->
  <view class="admin-modal-mask" wx:if="{{showAdminModal}}" bindtap="closeAdminModal">
    <view class="admin-modal" catchtap="">
      <view class="admin-modal-close" bindtap="closeAdminModal">
        <text class="admin-close-icon">✕</text>
      </view>
      <text class="admin-modal-title">超级管理员</text>
      <view class="admin-list">
        <view class="admin-section" wx:if="{{_superAdminOnly.length > 0}}">
          <view class="admin-section-header">
            <text class="admin-section-icon">👑</text>
            <text class="admin-section-label">超级管理员</text>
            <text class="admin-section-desc">可管理权限、重置昵称次数、修改核准段位和微信昵称</text>
          </view>
          <view class="admin-name-list">
            <text class="admin-name" wx:for="{{_superAdminOnly}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="admin-section" wx:if="{{_adminOnly.length > 0}}">
          <view class="admin-section-header">
            <text class="admin-section-icon">🛡</text>
            <text class="admin-section-label">管理员</text>
            <text class="admin-section-desc">可修改核准段位和微信昵称</text>
          </view>
          <view class="admin-name-list">
            <text class="admin-name" wx:for="{{_adminOnly}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="admin-empty" wx:if="{{_superAdminOnly.length === 0 && _adminOnly.length === 0}}">
          <text class="admin-empty-text">暂无管理员</text>
        </view>
      </view>
      <view class="admin-footer">
        <text class="admin-footer-text">如遇问题，请在微信群中联系以上管理员</text>
      </view>
    </view>
  </view>
</view>
