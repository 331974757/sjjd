<!--pages/admin/admin.wxml-->
<view class="admin-page">

  <!-- 所有用户列表 -->
  <view class="section">
    <view class="section-title">
      <text>用户权限管理</text>
      <text class="user-count">{{keyword ? _filteredTotal + '/' + allUsers.length : allUsers.length}} 人</text>
    </view>

    <!-- 搜索栏 -->
    <view class="search-bar">
      <input class="search-input" placeholder="搜索昵称" value="{{keyword}}" bindinput="onKeywordInput" />
    </view>

    <text class="subtitle" wx:if="{{isSuperAdmin}}">点击用户即可调整权限（管理员/超级管理员）</text>

    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="user-list" wx:else>
      <view class="user-item" wx:for="{{users}}" wx:key="_id">
        <view class="user-info">
          <view class="user-badge {{item.role === 'super_admin' ? 'badge-super' : (item.role === 'admin' ? 'badge-admin' : 'badge-user')}}">
            <text>{{item.role === 'super_admin' ? '超' : (item.role === 'admin' ? '管' : '普')}}</text>
          </view>
          <text class="user-nick" wx:if="{{item.nickName}}">{{item.nickName}}</text>
          <text class="user-openid">{{item.openidShort}}</text>
          <text class="user-me" wx:if="{{item.isMe}}">（我）</text>
          <view class="nick-count-info" wx:if="{{item.nickName && isSuperAdmin && item.role !== 'admin' && item.role !== 'super_admin'}}">
            <text class="nick-count-text">已改{{item.nickChangeCount}}次</text>
          </view>
        </view>
        <view class="user-actions">
          <view
            wx:if="{{isSuperAdmin && item.nickName && item.role !== 'admin' && item.role !== 'super_admin'}}"
            class="reset-btn"
            bindtap="resetNickCount"
            data-openid="{{item.openid}}"
            data-nickname="{{item.nickName}}"
          >
            <text>重置次数</text>
          </view>
          <view
            wx:if="{{isSuperAdmin}}"
            class="toggle-btn {{item.isMe ? 'toggle-disabled' : (item.role === 'super_admin' ? 'toggle-super' : (item.role === 'admin' ? 'toggle-off' : 'toggle-on'))}}"
            bindtap="toggleAdmin"
            data-openid="{{item.openid}}"
            data-role="{{item.role}}"
            data-isme="{{item.isMe}}"
            data-nickname="{{item.nickName}}"
          >
            <text>{{item.isMe ? '不可操作' : (item.role === 'admin' || item.role === 'super_admin' ? '调整权限' : '设置权限')}}</text>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{users.length === 0 && !loading}}">
        <text class="empty-text">暂无注册用户</text>
        <text class="empty-hint">暂无注册用户，用户打开小程序后将自动注册</text>
      </view>

      <view class="load-more" wx:if="{{hasMore}}">
        <text>上拉加载更多</text>
      </view>
    </view>
  </view>

  <!-- 邀请说明 -->
  <view class="section section-hint">
    <text class="hint-title">怎么让别人注册？</text>
    <text class="hint-desc">让对方打开小程序即可自动注册。注册后你就能在这里看到他，点击设为管理员。</text>
  </view>

</view>
