/* pages/admin/admin.wxss */
.admin-page {
  min-height: 100vh;
  background-color: #0d1117;
  padding: 24rpx 32rpx 60rpx;
}

/* Section */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #e6edf3;
  margin-bottom: 16rpx;
}

.section-title-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 权限管理刷新按钮 */
.admin-refresh {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
  transition: all 0.15s ease;
}
.admin-refresh:active {
  background-color: rgba(31, 111, 235, 0.3);
  transform: scale(0.92);
}
.admin-refresh .refresh-icon {
  font-size: 28rpx;
  color: #8b949e;
  font-weight: 300;
  line-height: 1;
}

.user-count {
  font-size: 24rpx;
  color: #484f58;
  font-weight: 400;
}

.subtitle {
  display: block;
  font-size: 22rpx;
  color: #484f58;
  margin-bottom: 16rpx;
}

/* Search */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 72rpx 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background-color: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-clear {
  position: absolute;
  right: 0;
  top: 0;
  width: 72rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8b949e;
  z-index: 2;
}

.search-clear:active {
  color: #e6edf3;
}

/* Loading & Empty */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #8b949e;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8b949e;
}

.empty-hint {
  font-size: 22rpx;
  color: #484f58;
  margin-top: 8rpx;
}

/* User List */
.user-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #161b22;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.user-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

/* Badges */
.user-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.badge-super {
  background-color: rgba(155, 89, 182, 0.2);
  color: #bb86fc;
  border: 1rpx solid rgba(155, 89, 182, 0.3);
}

.badge-admin {
  background-color: rgba(52, 152, 219, 0.2);
  color: #3498db;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
}

.badge-user {
  background-color: rgba(119, 141, 169, 0.15);
  color: #778da9;
  border: 1rpx solid rgba(119, 141, 169, 0.2);
}

.user-nick {
  font-size: 28rpx;
  color: #e6edf3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.user-me {
  font-size: 22rpx;
  color: #f39c12;
  margin-left: 8rpx;
}

.nick-count-info {
  margin-left: 8rpx;
}

.nick-count-text {
  font-size: 20rpx;
  color: #8b949e;
}

/* Actions */
.user-actions {
  display: flex;
  flex-direction: row;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.reset-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background-color: rgba(243, 156, 18, 0.1);
  border: 1rpx solid rgba(243, 156, 18, 0.2);
  font-size: 22rpx;
  color: #f39c12;
  margin-right: 8rpx;
}

.toggle-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.toggle-on {
  background-color: rgba(39, 174, 96, 0.15);
  border: 1rpx solid rgba(39, 174, 96, 0.3);
  color: #27ae60;
}

.toggle-off {
  background-color: rgba(231, 76, 60, 0.15);
  border: 1rpx solid rgba(231, 76, 60, 0.3);
  color: #e74c3c;
}

.toggle-super {
  background-color: rgba(155, 89, 182, 0.15);
  border: 1rpx solid rgba(155, 89, 182, 0.3);
  color: #bb86fc;
}

.toggle-disabled {
  background-color: rgba(119, 141, 169, 0.08);
  border: 1rpx solid rgba(119, 141, 169, 0.15);
  color: #415a77;
}

.toggle-loading {
  background-color: rgba(119, 141, 169, 0.04);
  border: 1rpx solid rgba(119, 141, 169, 0.1);
  color: #8b949e !important;
  opacity: 0.6;
}

.user-nick.unregistered {
  color: #484f58;
  font-style: italic;
}

/* Pagination */
.pagination {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0 8rpx;
  gap: 24rpx;
}

.page-btn {
  padding: 12rpx 32rpx;
  border-radius: 12rpx;
  background-color: rgba(52, 152, 219, 0.12);
  border: 1rpx solid rgba(52, 152, 219, 0.25);
  font-size: 24rpx;
  color: #3498db;
}

.page-btn-disabled {
  background-color: rgba(119, 141, 169, 0.06);
  border-color: rgba(119, 141, 169, 0.12);
  color: #415a77;
}

.page-btn:active:not(.page-btn-disabled) {
  background-color: rgba(52, 152, 219, 0.22);
}

.page-info {
  font-size: 24rpx;
  color: #8b949e;
}

/* Hint section */
.section-hint {
  padding: 24rpx;
  background-color: rgba(52, 152, 219, 0.08);
  border: 1rpx solid rgba(52, 152, 219, 0.15);
  border-radius: 12rpx;
}

.hint-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3498db;
  margin-bottom: 8rpx;
}

.hint-desc {
  display: block;
  font-size: 22rpx;
  color: #8b949e;
  line-height: 1.6;
}
